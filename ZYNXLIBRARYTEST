-- ── CONFIG SAVE / LOAD ───────────────────────────────────────────────
local _sLast,_sPending=0,false
local function EnsureDir()
    if not isfolder then return false end
    if not isfolder(NL.SaveFolder) then makefolder(NL.SaveFolder) end
    return true
end
local function DoSave(name)
    if not NL.SaveEnabled or not writefile or not EnsureDir() then return end
    local d={Ver=NL.Version,At=os.date("%Y-%m-%d %H:%M:%S"),Flags={},Theme={},BgLib=NL._BgLib}
    for fn,fo in pairs(NL.Flags) do
        if fo.Save then
            d.Flags[fn]= fo.Type=="Colorpicker"
                and {Type="Colorpicker",Value=ColorPack(fo.Value)}
                or  {Type=fo.Type or "?",Value=fo.Value}
        end
    end
    for k,v in pairs(NL.Theme) do
        if typeof(v)=="Color3" then d.Theme[k]=ColorPack(v)
        elseif type(v)=="number" or type(v)=="string" or type(v)=="boolean" then d.Theme[k]=v end
    end
    pcall(function() writefile(NL.SaveFolder.."/"..name..".json",HttpService:JSONEncode(d)) end)
end
local function Save(name)
    local now=tick()
    if now-_sLast<1.2 then
        if not _sPending then _sPending=true
            task.delay(1.4,function() _sPending=false; DoSave(name or NL._CfgName) end)
        end; return
    end
    _sLast=now; task.spawn(DoSave,name or NL._CfgName)
end
local function Load(name)
    if not readfile or not isfile then return end
    local path=NL.SaveFolder.."/"..name..".json"
    if not isfile(path) then return end
    local ok,d=pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not ok or not d then return end
    if d.Theme then
        for k,v in pairs(d.Theme) do
            if type(v)=="table" and v.R then
                if NL.Theme[k]~=nil then NL.Theme[k]=ColorUnpack(v) end
            elseif type(v)~="nil" and NL.Theme[k]~=nil then NL.Theme[k]=v end
        end; ApplyTheme()
    end
    if d.BgLib then NL._BgLib=d.BgLib end
    task.defer(function()
        task.wait(0.3)
        for fn,fd in pairs(d.Flags or {}) do
            if NL.Flags[fn] then pcall(function()
                if fd.Type=="Colorpicker" then NL.Flags[fn]:Set(ColorUnpack(fd.Value))
                elseif fd.Value~=nil then NL.Flags[fn]:Set(fd.Value) end
            end) end
        end
    end)
end

-- ── DRAG ─────────────────────────────────────────────────────────────
local function Drag(handle,target)
    pcall(function()
        local drag,dStart,wStart=false
        Conn(handle.InputBegan,function(inp)
            if inp.UserInputType==Enum.UserInputType.MouseButton1
            or inp.UserInputType==Enum.UserInputType.Touch then
                drag=true
                dStart=Vector2.new(inp.Position.X,inp.Position.Y)
                wStart=Vector2.new(target.Position.X.Offset,target.Position.Y.Offset)
                Conn(inp.Changed,function()
                    if inp.UserInputState==Enum.UserInputState.End then drag=false end
                end)
            end
        end)
        Conn(UIS.InputChanged,function(inp)
            if not drag then return end
            if inp.UserInputType~=Enum.UserInputType.MouseMovement
            and inp.UserInputType~=Enum.UserInputType.Touch then return end
            local d=Vector2.new(inp.Position.X,inp.Position.Y)-dStart
            target.Position=UDim2.new(target.Position.X.Scale,wStart.X+d.X,
                                       target.Position.Y.Scale,wStart.Y+d.Y)
        end)
    end)
end

