	-- Busca inline (direita da tab bar)
	local SrchF=N("Frame",{Parent=TabBar,Position=UDim2.new(1,-86,0.5,-14),Size=UDim2.new(0,80,0,26),BackgroundColor3=T.Input,BorderSizePixel=0,ZIndex=11},{
		N("UICorner",{CornerRadius=UDim.new(0,3)}),N("UIStroke",{Color=T.Line,Thickness=.5}),
	})
	B(SrchF,"BackgroundColor3","Input"); B(SrchF:FindFirstChildOfClass("UIStroke"),"Color","Line")
	local SrchBox=N("TextBox",{Parent=SrchF,Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-12,1,0),BackgroundTransparency=1,PlaceholderText="buscar...",PlaceholderColor3=T.TxtC,Text="",Font=Enum.Font.Code,TextSize=11,TextColor3=T.TxtA,ClearTextOnFocus=false})
	B(SrchBox,"TextColor3","TxtA")
	C(SrchBox.Focused,function() Tw(SrchF:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Acc}) end)
	C(SrchBox.FocusLost,function() Tw(SrchF:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Line}) end)
	C(SrchBox:GetPropertyChangedSignal("Text"),function()
		local q=SrchBox.Text:lower():match("^%s*(.-)%s*$")
		if q=="" then
			for _,td in pairs(AllTabs) do td.Btn.Visible=true end
			for _,info in ipairs(AllElements) do if info.frame and info.frame.Parent then info.frame.Visible=true end end
			return
		end
		for _,info in ipairs(AllElements) do
			if info.frame and info.frame.Parent then info.frame.Visible=(info.label:lower():find(q,1,true)~=nil) end
		end
		for tname,td in pairs(AllTabs) do
			local has=false
			for _,info in ipairs(AllElements) do if info.tabName==tname and info.frame and info.frame.Parent and info.frame.Visible then has=true; break end end
			td.Btn.Visible=has
		end
	end)

