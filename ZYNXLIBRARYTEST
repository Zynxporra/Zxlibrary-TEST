                function dropdown:UpdateDisplay()
                    local selectedList = {}
                    for opt, selected in pairs(self.Selected) do
                        if selected then
                            table.insert(selectedList, opt)
                        end
                    end

                    if #selectedList == 0 then
                        selectedLabel.Text = "None"
                    elseif #selectedList == 1 then
                        selectedLabel.Text = selectedList[1]
                    elseif #selectedList <= 3 then
                        selectedLabel.Text = table.concat(selectedList, ", ")
                    else
                        selectedLabel.Text = #selectedList .. " selected"
                    end

                    for opt, btn in pairs(self.Buttons) do
                        local label = btn:FindFirstChildOfClass("TextLabel")
