local TI = {
	Snap   = TweenInfo.new(0.04, Enum.EasingStyle.Linear),
	Fast   = TweenInfo.new(0.13, Enum.EasingStyle.Quint,   Enum.EasingDirection.Out),
	Mid    = TweenInfo.new(0.22, Enum.EasingStyle.Quint,   Enum.EasingDirection.Out),
	Back   = TweenInfo.new(0.30, Enum.EasingStyle.Back,    Enum.EasingDirection.Out),
	Slow   = TweenInfo.new(0.50, Enum.EasingStyle.Quint,   Enum.EasingDirection.Out),
	Spring = TweenInfo.new(0.35, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out),
}
local function Tw(o,i,p) if o and o.Parent then TS:Create(o,i,p):Play() end end
local function N(cls,props,kids)
	local o=Instance.new(cls)
	for k,v in pairs(props or {}) do o[k]=v end
	for _,c in pairs(kids or {}) do c.Parent=o end
	return o
end
local function Rnd(n,f) if not f or f==0 then return n end return math.clamp(math.floor(n/f+.5)*f,-1e9,1e9) end
local function Cl(n,a,b) return math.max(a,math.min(b,n)) end
local function CPk(c) return{R=math.round(c.R*255),G=math.round(c.G*255),B=math.round(c.B*255)} end
local function CUp(t) return type(t)=="table" and Color3.fromRGB(Cl(t.R,0,255),Cl(t.G,0,255),Cl(t.B,0,255)) or Color3.fromRGB(200,200,200) end
local function LC(a,b,t) return Color3.new(a.R+(b.R-a.R)*t,a.G+(b.G-a.G)*t,a.B+(b.B-a.B)*t) end
local function Snd(id,v) local s=N("Sound",{SoundId=id,Volume=v or .2,Parent=SS}); s:Play(); game.Debris:AddItem(s,4) end

