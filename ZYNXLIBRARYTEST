                    SetProps(SetChildren(MakeElement("TFrame"), {
                        AddThemeObject(SetProps(MakeElement("Label", ColorpickerConfig.Name, 15), {
                            Size = UDim2.new(1,-12,1,0),
                            Position = UDim2.new(0,12,0,0),
                            Font = Enum.Font.GothamBold,
                            Name = "Content"
                        }), "Text"),
                        ColorBox,
                        Click,
                        AddThemeObject(SetProps(MakeElement("Frame"), {
                            Size = UDim2.new(1,0,0,1),
                            Position = UDim2.new(0,0,1,-1),
                            Name = "Line",
                            Visible = false
                        }), "Stroke")
                    }), {Size = UDim2.new(1,0,0,42), ClipsDescendants = true, Name = "F"}),
                    Container,
                    AddThemeObject(MakeElement("Stroke"), "Stroke")
                }), "Second")

                AddConnection(Click.MouseButton1Click, function()
                    Colorpicker.Toggled = not Colorpicker.Toggled
                    Color.Visible = Colorpicker.Toggled
                    Hue.Visible = Colorpicker.Toggled
                    ColorFrame.F.Line.Visible = Colorpicker.Toggled
                    TweenService:Create(ColorFrame, TweenInfo.new(0.3), {Size = Colorpicker.Toggled and UDim2.new(1,0,0,160) or UDim2.new(1,0,0,42)}):Play()
                end)

                local function UpdateColor()
                    Colorpicker.Value = Color3.fromHSV(ColorH, ColorS, ColorV)
                    ColorBox.BackgroundColor3 = Colorpicker.Value
                    Color.BackgroundColor3 = Color3.fromHSV(ColorH, 1, 1)
                    ColorpickerConfig.Callback(Colorpicker.Value)
                    SaveCfg(game.GameId)
                end

                AddConnection(Color.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local conn
                        conn = AddConnection(RunService.RenderStepped, function()
                            local x = math.clamp((Mouse.X - Color.AbsolutePosition.X) / Color.AbsoluteSize.X, 0, 1)
                            local y = math.clamp((Mouse.Y - Color.AbsolutePosition.Y) / Color.AbsoluteSize.Y, 0, 1)
                            ColorSelection.Position = UDim2.new(x,0,y,0)
                            ColorS = x
                            ColorV = 1 - y
                            UpdateColor()
                        end)
                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End and conn then
                                conn:Disconnect()
                            end
                        end)
                    end
                end)

                AddConnection(Hue.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        local conn
                        conn = AddConnection(RunService.RenderStepped, function()
                            local y = math.clamp((Mouse.Y - Hue.AbsolutePosition.Y) / Hue.AbsoluteSize.Y, 0, 1)
                            HueSelection.Position = UDim2.new(0.5,0,y,0)
                            ColorH = 1 - y
                            UpdateColor()
                        end)
                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End and conn then
                                conn:Disconnect()
                            end
                        end)
                    end
                end)

                function Colorpicker:Set(c)
                    self.Value = c
                    ColorBox.BackgroundColor3 = c
                    local h,s,v = Color3.toHSV(c)
                    ColorH,ColorS,ColorV = h,s,v
                    ColorSelection.Position = UDim2.new(s,0,1-v,0)
                    HueSelection.Position = UDim2.new(0.5,0,1-h,0)
                    Color.BackgroundColor3 = Color3.fromHSV(h,1,1)
                    ColorpickerConfig.Callback(c)
                end

                if ColorpickerConfig.Flag then OrionLib.Flags[ColorpickerConfig.Flag] = Colorpicker end
                return Colorpicker
            end

            return ElementFunction
        end

        local ElementFunction = {}

        -- SECTION (seu código original)
        function ElementFunction:AddSection(SectionConfig)
            SectionConfig = SectionConfig or {}
            SectionConfig.Name = SectionConfig.Name or "Section"

            local SectionFrame = SetChildren(SetProps(MakeElement("TFrame"), {
                Size = UDim2.new(1,0,0,26),
                Parent = Container
            }), {
                AddThemeObject(SetProps(MakeElement("Label", SectionConfig.Name, 14), {
                    Size = UDim2.new(1,-12,0,18),
                    Position = UDim2.new(0,0,0,0),
                    Font = Enum.Font.GothamSemibold
                }), "TextDark"),
                SetChildren(SetProps(MakeElement("TFrame"), {
                    AnchorPoint = Vector2.new(0,0),
                    Size = UDim2.new(1,0,1,-24),
                    Position = UDim2.new(0,0,0,22),
                    Name = "Holder"
                }), {
                    MakeElement("List", 0, 8)
                })
            })

            AddConnection(SectionFrame.Holder.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
                SectionFrame.Size = UDim2.new(1,0,0, SectionFrame.Holder.UIListLayout.AbsoluteContentSize.Y + 28)
                SectionFrame.Holder.Size = UDim2.new(1,0,0, SectionFrame.Holder.UIListLayout.AbsoluteContentSize.Y)
            end)

            local SectionFunc = {}
            for k,v in pairs(GetElements(SectionFrame.Holder)) do
                SectionFunc[k] = v
            end
            return SectionFunc
        end

        for k,v in pairs(GetElements(Container)) do
            ElementFunction[k] = v
        end

        if TabConfig.PremiumOnly then
            for k,_ in pairs(ElementFunction) do
                ElementFunction[k] = function() end
            end
            Container:ClearAllChildren()
            SetChildren(Container, {
                AddThemeObject(SetProps(MakeElement("Label", "Premium Only", 20), {Size = UDim2.new(1,0,0,30), Position = UDim2.new(0,0,0.5,-15)}), "Text")
            })
        end

        return ElementFunction
    end

    -- Add themes tab
    local ThemesTab = TabFunction:MakeTab({Name = "Temas", Icon = "rbxassetid://7072706796"})
    ThemesTab:AddColorPicker({
        Name = "Cor Principal",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Main,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Main = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Cor Secundária",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Second,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Second = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Cor de Contorno",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Stroke,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Stroke = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Cor do Divisor",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Divider,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Divider = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Cor do Texto",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Text,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Text = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Cor do Texto Escuro",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].TextDark,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].TextDark = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddColorPicker({
        Name = "Fundo",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].Background,
        Callback = function(Value)
            OrionLib.Themes[OrionLib.SelectedTheme].Background = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    ThemesTab:AddTextBox({
        Name = "Imagem de Fundo",
        Default = OrionLib.Themes[OrionLib.SelectedTheme].BackgroundImage,
        Placeholder = "rbxassetid://... ou apenas o ID",
        Callback = function(Value)
            if Value ~= "" and not string.find(Value, "rbxassetid://") then
                Value = "rbxassetid://" .. Value
            end
            OrionLib.Themes[OrionLib.SelectedTheme].BackgroundImage = Value
            SetTheme()
            SaveCfg(game.GameId)
        end
    })
    AddConnection(ConfigBtn.MouseButton1Click, function()
        if Tabs["Temas"] and TabContainers["Temas"] then
            for _, TabBtn in pairs(Tabs) do
                TabBtn.BackgroundTransparency = 1
            end
            Tabs["Temas"].BackgroundTransparency = 0
            for _, Container in pairs(TabContainers) do
                Container.Visible = false
            end
            TabContainers["Temas"].Visible = true
        end
    end)

    return TabFunction
end

return OrionLib
