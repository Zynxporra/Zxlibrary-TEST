                ColorConfig.Callback = ColorConfig.Callback or function() end

                local hex = string.format("#%02x%02x%02x", math.floor(ColorConfig.Default.R*255), math.floor(ColorConfig.Default.G*255), math.floor(ColorConfig.Default.B*255))

                local picker = ElementFunction:AddTextBox({
                    Name = ColorConfig.Name,
                    Default = hex,
                    Placeholder = "#RRGGBB",
                    Callback = function(value)
                        local ok, c = pcall(function() return ColorUnpack(value) end)
                        if ok and typeof(c) == "Color3" then
                            ColorConfig.Callback(c)
                        end
                    end
                })

                local obj = {}
                function obj:Set(c)
                    local h = string.format("#%02x%02x%02x", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
