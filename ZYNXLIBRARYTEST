-- ── CONNECTIONS ───────────────────────────────────────────────
local function Alive() return Root and Root.Parent~=nil end
local function Conn(sig,fn)
    if not Alive() then return end
    local c=sig:Connect(fn); table.insert(Nexus.Conns,c); return c
end
task.spawn(function()
    while Alive() do task.wait(0.5) end
    for _,c in pairs(Nexus.Conns) do pcall(function() c:Disconnect() end) end
end)

-- ── THEME BINDING ─────────────────────────────────────────────
local function Bind(obj,prop,key,fn)
    if not obj or not prop or not key then return obj end
    table.insert(Nexus._Watchers,{obj=obj,prop=prop,key=key,fn=fn})
    local v=Nexus.Theme[key]
    if v~=nil then pcall(function() obj[prop]=fn and fn(v) or v end) end
    return obj
end
local function BindFn(fn) table.insert(Nexus._WatchFns,fn); pcall(fn) end
local function ApplyTheme()
    local T=Nexus.Theme
    for _,w in ipairs(Nexus._Watchers) do
        if w.obj and w.obj.Parent then
            local v=T[w.key]
            if v~=nil then pcall(function() w.obj[w.prop]=w.fn and w.fn(v) or v end) end
        end
    end
    for _,fn in ipairs(Nexus._WatchFns) do pcall(fn) end
end
function Nexus:Set(key,val) Nexus.Theme[key]=val; ApplyTheme() end
function Nexus:SetTheme(tbl) for k,v in pairs(tbl) do Nexus.Theme[k]=v end; ApplyTheme() end

