local AuroraRegistry = {} -- {frame, type}

local function RegisterAurora(frame, aType)
	table.insert(AuroraRegistry, {frame=frame, aType=aType or "gradient"})
end

local _auroraT = 0
task.spawn(function()
	while Alive() do
		local dt = task.wait(0.03)
		_auroraT = _auroraT + dt * 0.4

		local t = _auroraT
		local A  = ZNX.Theme.A  or Color3.fromRGB(0,210,255)
		local A2 = ZNX.Theme.A2 or Color3.fromRGB(255,50,180)
		local ABr = ZNX.Theme.ABr or Color3.fromRGB(100,235,255)

		-- Oscilação suave com seno
		local s1 = (math.sin(t * 1.0) + 1) / 2
		local s2 = (math.sin(t * 0.7 + 1.0) + 1) / 2
		local s3 = (math.sin(t * 0.5 + 2.1) + 1) / 2

		local midCol = LerpC(A, A2, s1)
		local col1   = LerpC(A, ABr, s2)
		local col3   = LerpC(A2, A, s3)

		for i = #AuroraRegistry, 1, -1 do
			local entry = AuroraRegistry[i]
			if not entry.frame or not entry.frame.Parent then
				table.remove(AuroraRegistry, i)
			else
				pcall(function()
					local f = entry.frame
					if entry.aType == "gradient" then
						local g = f:FindFirstChildOfClass("UIGradient")
						if g then
							g.Color = ColorSequence.new{
								ColorSequenceKeypoint.new(0,    col1),
								ColorSequenceKeypoint.new(0.45, midCol),
								ColorSequenceKeypoint.new(1,    col3),
							}
						end
					elseif entry.aType == "stroke" then
						local s = f:FindFirstChildOfClass("UIStroke")
						if s then s.Color = LerpC(A, A2, s1) end
					elseif entry.aType == "color" then
						f.BackgroundColor3 = LerpC(A, A2, s1)
					elseif entry.aType == "text" then
						f.TextColor3 = LerpC(A, A2, s1)
					end
				end)
			end
		end
	end
end)

