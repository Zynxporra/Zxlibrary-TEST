                    self.Value = Value
                    DropdownFrame.F.Selected.Text = self.Value
                    for _,v in pairs(self.Buttons) do
                        TweenService:Create(v, TweenInfo.new(0.15), {BackgroundTransparency = 0.5}):Play()
                        TweenService:Create(v.Title, TweenInfo.new(0.15), {TextTransparency = 0.4}):Play()
