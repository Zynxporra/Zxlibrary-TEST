                Connect(textbox.Focused, function()
                    TweenPlay(inputContainer:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = theme.Accent })
                end)

                Connect(textbox.FocusLost, function(enter)
                    TweenPlay(inputContainer:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = theme.Border })
                    if enter then
                        textboxConfig.Callback(textbox.Text)
                        if textboxConfig.ClearOnSubmit then
                            textbox.Text = ""
                        end
