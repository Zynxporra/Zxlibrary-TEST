						TextColor3 = T.TextDark,
						TextXAlignment = Enum.TextXAlignment.Left,
						TextTruncate = Enum.TextTruncate.AtEnd,
					})

					Connect(ob.MouseButton1Up, function()
						if ob:GetAttribute("Disconnected") then return end
						DD:Set(playerName)
						SaveConfig(cfg.ConfigName)
					end)

					Connect(ob.MouseEnter, function()
						if ob:GetAttribute("Disconnected") then return end
						if table.find(SelectedValues, playerName) then return end
						Tween(ob, TweenCache.Fast, { BackgroundColor3 = T.BgHover }):Play()
					end)

					Connect(ob.MouseLeave, function()
						if ob:GetAttribute("Disconnected") then return end
						local sel = table.find(SelectedValues, playerName) ~= nil
						Tween(ob, TweenCache.Fast, {
							BackgroundColor3 = sel and GetSelectedBg() or T.BgPanel
						}):Play()
					end)

					DD.Buttons[playerName] = ob
					Options = Options + 1
				end

				for _, p in pairs(Players:GetPlayers()) do
					AddOption(p)
				end

				Connect(Players.PlayerAdded, function(p)
					AddOption(p)
				end)

				Connect(Players.PlayerRemoving, function(p)
					task.delay(0.1, function()
						RemoveOption(p.Name)
					end)
				end)

				function DD:Set(val, once)
					local btn = DD.Buttons[val]
					if not btn then
						for _ = 0, 10 do
							task.wait(0.15)
							if DD.Buttons[val] then
								btn = DD.Buttons[val]
								break
							end
						end
					end
					if not btn then return end
					if btn:GetAttribute("Disconnected") then return end

					local n = table.find(SelectedValues, val)
					local text = ""

					local function ApplySelectedStyle(b, selected)
						local sbar = b:FindFirstChild("SelBar")
						if selected then
							Tween(b, TweenCache.Medium, { BackgroundColor3 = GetSelectedBg() }):Play()
							if sbar then
								Tween(sbar, TweenCache.Fast, { BackgroundTransparency = 0 }):Play()
							end
							for _, lbl in ipairs(b:GetChildren()) do
								if lbl:IsA("TextLabel") and lbl.Font == Enum.Font.GothamBold then
									Tween(lbl, TweenCache.Fast, { TextColor3 = T.Accent }):Play()
								end
							end
						else
							Tween(b, TweenCache.Medium, { BackgroundColor3 = T.BgPanel }):Play()
							if sbar then
								Tween(sbar, TweenCache.Fast, { BackgroundTransparency = 1 }):Play()
							end
							for _, lbl in ipairs(b:GetChildren()) do
								if lbl:IsA("TextLabel") and lbl.Font == Enum.Font.GothamBold then
									Tween(lbl, TweenCache.Fast, { TextColor3 = T.Text }):Play()
								end
							end
						end
					end

					if DD.MultipleSelection then
						if not n then
							table.insert(SelectedValues, val)
							ApplySelectedStyle(btn, true)
						elseif not once then
							table.remove(SelectedValues, n)
							ApplySelectedStyle(btn, false)
						end

						for i, v in pairs(SelectedValues) do
							if i <= 3 then
								text = text .. (#SelectedValues > 3 and i == 3 and v.."..." or v)
								if i < math.min(#SelectedValues, 3) then
									text = text .. ", "
								end
							end
						end

						DD.Value = val
						selLbl.Text = #SelectedValues > 0 and text or "Selected"
						return dCfg.Callback(SelectedValues)
					else
						table.clear(SelectedValues)

						for pName, b in pairs(DD.Buttons) do
							if not b:GetAttribute("Disconnected") then
								ApplySelectedStyle(b, false)
							end
						end

						if DD.Buttons[val] and not DD.Buttons[val]:GetAttribute("Disconnected") then
							table.insert(SelectedValues, val)
							ApplySelectedStyle(DD.Buttons[val], true)
							DD.Value = val
							selLbl.Text = val
						else
							DD.Value = nil
							selLbl.Text = "Selected"
						end

						return dCfg.Callback(DD.Value)
					end
				end

				local Hbtn = New("TextButton", {
					Parent = header,
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "",
					AutoButtonColor = false,
				})

				Connect(Hbtn.MouseButton1Up, function()
					DD.Toggled = not DD.Toggled
					sep.Visible = DD.Toggled
					Tween(arrow, TweenCache.Fast, { Rotation = DD.Toggled and 180 or 0 }):Play()
					
					if Options > MaxElements then
						Tween(outer, TweenCache.Medium, {
							Size = DD.Toggled and UDim2.new(1, 0, 0, 38 + (MaxElements * 47)) or UDim2.new(1, 0, 0, 38)
						}):Play()
					else
						Tween(outer, TweenCache.Medium, {
							Size = DD.Toggled and UDim2.new(1, 0, 0, 38 + (Options * 47)) or UDim2.new(1, 0, 0, 38)
						}):Play()
					end
				end})

				if dCfg.Flag then NexusLib.Flags[dCfg.Flag] = DD end
				return DD
			end

