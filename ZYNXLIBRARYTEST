				Connect(tb.Focused,   function() TPlay(inputBg:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NexusLib.Theme.Accent}) end)
				Connect(tb.FocusLost, function(enter)
					TPlay(inputBg:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NexusLib.Theme.Border})
					xCfg.Callback(tb.Text)
					if xCfg.ClearOnSubmit then tb.Text = "" end
				end)
			end

			-- BIND
			function E:AddBind(bCfg)
				bCfg          = bCfg or {}
				bCfg.Name     = bCfg.Name     or "Keybind"
				bCfg.Default  = bCfg.Default  or Enum.KeyCode.Unknown
				bCfg.Hold     = bCfg.Hold     or false
				bCfg.Callback = bCfg.Callback or function() end
				bCfg.Flag     = bCfg.Flag     or nil
				bCfg.Save     = bCfg.Save     or false

				local Blacklist = {
					Enum.KeyCode.Unknown,Enum.KeyCode.W,Enum.KeyCode.A,Enum.KeyCode.S,Enum.KeyCode.D,
					Enum.KeyCode.Slash,Enum.KeyCode.Tab,Enum.KeyCode.Backspace,Enum.KeyCode.Escape,
					Enum.KeyCode.Up,Enum.KeyCode.Down,Enum.KeyCode.Left,Enum.KeyCode.Right
				}
				local function InBlacklist(k)
					for _,v in pairs(Blacklist) do if v==k then return true end end
				end

				local T_    = NexusLib.Theme
				local Bind  = {Value = bCfg.Default.Name or tostring(bCfg.Default), Binding = false, Holding = false, Type = "Bind", Save = bCfg.Save}

				local card = MakeCard(parent)
				card.Size  = UDim2.new(1, 0, 0, 36)

				New("TextLabel",{
					Parent=card,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-100,1,0),
					BackgroundTransparency=1,Text=bCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(card:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")

				local keyBox = New("Frame",{
					Parent=card,Position=UDim2.new(1,-82,0.5,-13),Size=UDim2.new(0,70,0,26),
					BackgroundColor3=T_.BgDeep,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,5)}),New("UIStroke",{Color=T_.Border,Thickness=1})})
				local keyLbl = New("TextLabel",{
					Parent=keyBox,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text=Bind.Value,
					Font=Enum.Font.GothamBold,TextSize=12,
					TextColor3=T_.Accent,TextXAlignment=Enum.TextXAlignment.Center,
				})
				ThemeBind(keyLbl,"TextColor3","Accent")

				local Btn = New("TextButton",{Parent=card,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				Connect(Btn.InputEnded, function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1 and not Bind.Binding then
						Bind.Binding = true
						keyLbl.Text  = "..."
						TPlay(keyBox:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NexusLib.Theme.Accent})
					end
				end)
				Connect(UserInputService.InputBegan, function(inp, gp)
					if gp then return end
					if Bind.Binding then
						local Key
						pcall(function()
							if not InBlacklist(inp.KeyCode) then Key = inp.KeyCode end
						end)
						Key = Key or Bind.Value
						Bind:Set(Key)
						TPlay(keyBox:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NexusLib.Theme.Border})
						SaveConfig(cfg.ConfigName)
					elseif inp.KeyCode.Name == Bind.Value or inp.UserInputType.Name == Bind.Value then
						if bCfg.Hold then Bind.Holding = true; bCfg.Callback(true)
						else bCfg.Callback() end
					end
				end)
				Connect(UserInputService.InputEnded, function(inp)
					if (inp.KeyCode.Name == Bind.Value or inp.UserInputType.Name == Bind.Value) and bCfg.Hold and Bind.Holding then
						Bind.Holding = false; bCfg.Callback(false)
					end
				end)
				function Bind:Set(k)
					Bind.Binding = false
					Bind.Value   = (type(k)=="string") and k or (k.Name or tostring(k))
					keyLbl.Text  = Bind.Value
				end
				Bind:Set(bCfg.Default)
				if bCfg.Flag then NexusLib.Flags[bCfg.Flag] = Bind end
				return Bind
			end

			-- COLOR PICKER
			function E:AddColorpicker(cpCfg)
				cpCfg          = cpCfg or {}
				cpCfg.Name     = cpCfg.Name     or "Color"
				cpCfg.Default  = cpCfg.Default  or Color3.fromRGB(0, 220, 180)
				cpCfg.Callback = cpCfg.Callback or function() end
				cpCfg.Flag     = cpCfg.Flag     or nil
				cpCfg.Save     = cpCfg.Save     or false

				local T_  = NexusLib.Theme
				local CP  = {Value = cpCfg.Default, Toggled = false, Type = "Colorpicker", Save = cpCfg.Save}
				local H_, S_, V_ = Color3.toHSV(cpCfg.Default)

				local outer = New("Frame",{
					Parent=parent,Size=UDim2.new(1,0,0,36),
					BackgroundColor3=T_.BgCard,BorderSizePixel=0,ClipsDescendants=true,
				},{New("UICorner",{CornerRadius=UDim.new(0,6)}),New("UIStroke",{Color=T_.Border,Thickness=1})})
				ThemeBind(outer,"BackgroundColor3","BgCard")
				ThemeBind(outer:FindFirstChildOfClass("UIStroke"),"Color","Border")

				local header = New("Frame",{Parent=outer,Size=UDim2.new(1,0,0,36),BackgroundTransparency=1})
				New("TextLabel",{
					Parent=header,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-60,1,0),
					BackgroundTransparency=1,Text=cpCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local Preview = New("Frame",{
					Parent=header,Position=UDim2.new(1,-46,0.5,-12),Size=UDim2.new(0,24,0,24),
					BackgroundColor3=cpCfg.Default,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,5)}),New("UIStroke",{Color=T_.Border,Thickness=1.5})})

				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-18,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=T_.TextMuted,
				})
				local sep = New("Frame",{Parent=outer,Position=UDim2.new(0,0,0,36),Size=UDim2.new(1,0,0,1),BackgroundColor3=T_.Border,BorderSizePixel=0,Visible=false})
				ThemeBind(sep,"BackgroundColor3","Border")

				local pickerArea = New("Frame",{
					Parent=outer,Position=UDim2.new(0,10,0,44),
					Size=UDim2.new(1,-20,0,110),
					BackgroundTransparency=1,Visible=false,
				})

				local SVBox = New("ImageLabel",{
					Parent=pickerArea,Position=UDim2.new(0,0,0,0),
					Size=UDim2.new(1,-26,1,0),
					Image="rbxassetid://4155801252",
					BackgroundColor3=Color3.fromHSV(H_,1,1),
					BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,5)})})

				local SVPin = New("Frame",{
					Parent=SVBox,Position=UDim2.new(S_,0,1-V_,0),
					Size=UDim2.new(0,14,0,14),
					BackgroundColor3=Color3.fromRGB(255,255,255),
					BorderSizePixel=0,AnchorPoint=Vector2.new(0.5,0.5),
				},{New("UICorner",{CornerRadius=UDim.new(1,0)}),New("UIStroke",{Color=Color3.fromRGB(50,50,50),Thickness=2})})

				local HueBar = New("Frame",{
					Parent=pickerArea,Position=UDim2.new(1,-22,0,0),
					Size=UDim2.new(0,14,1,0),
					BorderSizePixel=0,
				},{
					New("UICorner",{CornerRadius=UDim.new(0,4)}),
					New("UIGradient",{Rotation=270,Color=ColorSequence.new{
						ColorSequenceKeypoint.new(0.00,Color3.fromRGB(255,0,4)),
						ColorSequenceKeypoint.new(0.17,Color3.fromRGB(255,255,0)),
						ColorSequenceKeypoint.new(0.33,Color3.fromRGB(0,255,0)),
						ColorSequenceKeypoint.new(0.50,Color3.fromRGB(0,255,255)),
						ColorSequenceKeypoint.new(0.67,Color3.fromRGB(0,0,255)),
						ColorSequenceKeypoint.new(0.83,Color3.fromRGB(255,0,255)),
						ColorSequenceKeypoint.new(1.00,Color3.fromRGB(255,0,4)),
					}}),
				})
				local HPin = New("Frame",{
					Parent=HueBar,Position=UDim2.new(0.5,0,1-H_,0),
					Size=UDim2.new(1,4,0,4),AnchorPoint=Vector2.new(0.5,0.5),
					BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,2)}),New("UIStroke",{Color=Color3.fromRGB(50,50,50),Thickness=1.5})})

				local function UpdateCP()
					local c = Color3.fromHSV(H_,S_,V_)
					CP.Value            = c
					Preview.BackgroundColor3 = c
					SVBox.BackgroundColor3   = Color3.fromHSV(H_,1,1)
					cpCfg.Callback(c)
					SaveConfig(cfg.ConfigName)
				end

				local svDrag, svInp = false
				Connect(SVBox.InputBegan, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						svDrag = true
						inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then svDrag=false end end)
					end
				end)
				Connect(SVBox.InputChanged, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then svInp=inp end
				end)
				Connect(UserInputService.InputChanged, function(inp)
					if svDrag and inp==svInp then
						S_ = math.clamp((inp.Position.X-SVBox.AbsolutePosition.X)/math.max(SVBox.AbsoluteSize.X,1),0,1)
						V_ = 1-math.clamp((inp.Position.Y-SVBox.AbsolutePosition.Y)/math.max(SVBox.AbsoluteSize.Y,1),0,1)
						SVPin.Position = UDim2.new(S_,0,1-V_,0)
						UpdateCP()
					end
				end)
				local hDrag, hInp = false
				Connect(HueBar.InputBegan, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						hDrag = true
						inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then hDrag=false end end)
					end
				end)
				Connect(HueBar.InputChanged, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then hInp=inp end
				end)
				Connect(UserInputService.InputChanged, function(inp)
					if hDrag and inp==hInp then
						H_ = 1-math.clamp((inp.Position.Y-HueBar.AbsolutePosition.Y)/math.max(HueBar.AbsoluteSize.Y,1),0,1)
						HPin.Position = UDim2.new(0.5,0,1-H_,0)
						UpdateCP()
					end
				end)

				local Hbtn = New("TextButton",{Parent=header,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				Connect(Hbtn.MouseButton1Up, function()
					CP.Toggled = not CP.Toggled
					sep.Visible = CP.Toggled
					pickerArea.Visible = CP.Toggled
					TPlay(arrow,TW.Fast,{Rotation=CP.Toggled and 180 or 0})
					TPlay(outer,TW.Mid,{Size=CP.Toggled and UDim2.new(1,0,0,165) or UDim2.new(1,0,0,36)})
				end)

				function CP:Set(c)
					CP.Value = c
					H_, S_, V_ = Color3.toHSV(c)
					Preview.BackgroundColor3 = c
					SVBox.BackgroundColor3   = Color3.fromHSV(H_,1,1)
					SVPin.Position = UDim2.new(S_,0,1-V_,0)
					HPin.Position  = UDim2.new(0.5,0,1-H_,0)
					cpCfg.Callback(c)
				end

				CP:Set(cpCfg.Default)
				if cpCfg.Flag then NexusLib.Flags[cpCfg.Flag] = CP end
				return CP
			end

			-- SECTION
			function E:AddSection(sCfg)
				sCfg = sCfg or {}
				sCfg.Name = sCfg.Name or "Section"

				local wrap = New("Frame",{
					Parent=parent,Size=UDim2.new(1,0,0,0),
					AutomaticSize=Enum.AutomaticSize.Y,
					BackgroundTransparency=1,
				})
				local row = New("Frame",{Parent=wrap,Size=UDim2.new(1,0,0,22),BackgroundTransparency=1})
				New("Frame",{
					Parent=row,Position=UDim2.new(0,0,0.5,-1),Size=UDim2.new(0,3,0,12),
					BackgroundColor3=NexusLib.Theme.Accent,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
				local slbl = New("TextLabel",{
					Parent=row,Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-10,1,0),
					BackgroundTransparency=1,Text=sCfg.Name,
					Font=Enum.Font.GothamBlack,TextSize=12,
					TextColor3=NexusLib.Theme.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(slbl,"TextColor3","TextMuted")

				local holder = New("Frame",{
					Parent=wrap,Position=UDim2.new(0,0,0,22),
					Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
					BackgroundTransparency=1,
				},{New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5)})})

				local SE = {}
				for k,v in pairs(BuildElements(holder)) do SE[k]=v end
				return SE
			end

			return E
		end -- BuildElements

		local EF = {}
		for k, v in pairs(BuildElements(ContentScroll)) do
			EF[k] = v
		end
		return EF
	end -- MakeTab

