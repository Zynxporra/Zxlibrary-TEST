    local function LoadSequence()
        MainWindow.Visible = false
        local LoadBg = SetProps(MakeElement("Frame"), {
            Parent = Orion,
            Size = UDim2.new(1,0,1,0),
            BackgroundColor3 = Color3.fromRGB(20,10,25),
            BackgroundTransparency = 1,
            ZIndex = 999
        })
        local LoadLogo = SetProps(MakeElement("Image", WindowConfig.IntroIcon), {
            Parent = LoadBg,
            AnchorPoint = Vector2.new(0.5,0.5),
            Position = UDim2.new(0.5,0,0.45,0),
            Size = UDim2.new(0,0,0,0),
            ImageColor3 = Color3.fromRGB(255,255,255),
            ImageTransparency = 1,
            ZIndex = 1000
        })
        local TextContainer = SetProps(MakeElement("Frame"), {
            Parent = LoadBg,
            Size = UDim2.new(1,0,0,35),
            AnchorPoint = Vector2.new(0.5,0.5),
            Position = UDim2.new(0.5,0,0.58,0),
            BackgroundTransparency = 1,
            ZIndex = 1000
        })
        local text = WindowConfig.IntroText
        local letters = {}
        local totalWidth = 0
        for i=1,#text do
            local char = text:sub(i,i)
            local width = char == " " and 8 or 14
            totalWidth = totalWidth + width
        end
        local currentX = -totalWidth/2
        for i=1,#text do
            local char = text:sub(i,i)
            local width = char == " " and 8 or 14
            local letter = SetProps(MakeElement("Label", char, 20), {
                Parent = TextContainer,
                Size = UDim2.new(0,width,1,0),
                Position = UDim2.new(0.5,currentX,0,0),
                Font = Enum.Font.GothamBold,
                TextTransparency = 1,
                TextColor3 = Color3.fromRGB(255,255,255),
                BackgroundTransparency = 1,
                ZIndex = 1001
            })
            table.insert(letters, letter)
            currentX = currentX + width
        end
        local LoadingBar = SetChildren(SetProps(MakeElement("Frame"), {
            Parent = LoadBg,
            AnchorPoint = Vector2.new(0.5,0.5),
            Position = UDim2.new(0.5,0,0.65,0),
            Size = UDim2.new(0,200,0,3),
            BackgroundColor3 = Color3.fromRGB(60,60,80),
            BackgroundTransparency = 0.5,
            ZIndex = 1000
        }), {
            SetProps(MakeElement("Frame"), {Size = UDim2.new(0,0,1,0), BackgroundColor3 = OrionLib.Themes[OrionLib.SelectedTheme].Stroke, Name = "Fill", ZIndex = 1001}),
            MakeElement("Corner",1)
        })

        TweenService:Create(LoadLogo, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Size = UDim2.new(0,56,0,56), ImageTransparency = 0}):Play()
        wait(0.4)
        for i, letter in ipairs(letters) do
            task.spawn(function()
                wait(i*0.04)
                TweenService:Create(letter, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
            end)
        end
        wait(0.2 + #letters*0.04)
        TweenService:Create(LoadingBar.Fill, TweenInfo.new(1.2), {Size = UDim2.new(1,0,1,0)}):Play()
        wait(1.3)
        for i = #letters,1,-1 do
            task.spawn(function()
                wait((#letters-i)*0.03)
                TweenService:Create(letters[i], TweenInfo.new(0.25), {TextTransparency = 1, Position = letters[i].Position + UDim2.new(0,0,0,-10)}):Play()
            end)
        end
        TweenService:Create(LoadBg, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        TweenService:Create(LoadLogo, TweenInfo.new(0.4), {ImageTransparency = 1}):Play()
        TweenService:Create(LoadingBar, TweenInfo.new(0.4), {BackgroundTransparency = 1}):Play()
        MainWindow.Visible = true
        freeMouse.Modal = true
        UserInputService.MouseIconEnabled = true
        freeMouse.Visible = true
        wait(0.5)
        LoadBg:Destroy()
    end

    if WindowConfig.IntroEnabled then
        LoadSequence()
    end

    freeMouse.Visible = true

