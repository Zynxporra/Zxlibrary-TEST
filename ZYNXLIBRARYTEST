			Callback=function(v) if v then PacketDetector:start() else PacketDetector:stop() end end
		})
		Security:AddSlider({Name="Limite (KB)", Min=1, Max=50, Increment=1, Default=5, Suffix="KB", Flag="PacketKBLimit", Save=true, Callback=function(v)
			PacketDetector.KB_THRESHOLD=v; PacketDetector.BYTE_THRESHOLD=v*1024
		end})
		Security:AddSlider({Name="Cooldown entre alertas", Min=5, Max=60, Increment=5, Default=30, Suffix="s", Flag="PacketCooldown", Save=true, Callback=function(v)
			PacketDetector.COOLDOWN=v
		end})
		Security:AddButton({Name="🧪 Simular pacote suspeito", Callback=function()
			local testData=string.rep("X",10*1024)
			task.spawn(function()
				task.wait(0.4)
				PacketDetector:showNotification(LP, 10/1024, {"[SIMULADO]",testData:sub(1,120)}, "TestMode")
			end)
			ZNX:Notify({Title="🧪 Simulando...",Message="Pacote de teste enviado",Duration=2,Type="warn"})
		end})

		-- ── Presets ─────────────────────────────────────────
		local PS = ST:AddSection({Name = "🎭 Presets de Tema"})
		local Presets = {
			["🌑 Obsidian (padrão)"]={Bg0=Color3.fromRGB(3,3,7),Bg1=Color3.fromRGB(6,6,13),Bg2=Color3.fromRGB(10,10,19),A=Color3.fromRGB(0,210,255),A2=Color3.fromRGB(255,50,180),Line=Color3.fromRGB(22,22,44)},
			["🔴 Crimson Night"]={Bg0=Color3.fromRGB(5,2,2),Bg1=Color3.fromRGB(9,4,4),Bg2=Color3.fromRGB(15,7,7),A=Color3.fromRGB(230,45,60),A2=Color3.fromRGB(255,100,40),Line=Color3.fromRGB(44,14,14)},
			["🟢 Forest Matrix"]={Bg0=Color3.fromRGB(2,5,2),Bg1=Color3.fromRGB(4,9,4),Bg2=Color3.fromRGB(7,15,8),A=Color3.fromRGB(0,220,80),A2=Color3.fromRGB(60,255,140),Line=Color3.fromRGB(12,40,14)},
			["🔵 Ocean Deep"]={Bg0=Color3.fromRGB(2,3,7),Bg1=Color3.fromRGB(4,6,13),Bg2=Color3.fromRGB(7,10,22),A=Color3.fromRGB(50,140,255),A2=Color3.fromRGB(0,220,255),Line=Color3.fromRGB(16,24,58)},
			["🟡 Solar Flare"]={Bg0=Color3.fromRGB(6,5,2),Bg1=Color3.fromRGB(11,9,3),Bg2=Color3.fromRGB(18,16,6),A=Color3.fromRGB(255,185,20),A2=Color3.fromRGB(255,80,20),Line=Color3.fromRGB(56,46,12)},
			["🟣 Neon Purple"]={Bg0=Color3.fromRGB(4,2,8),Bg1=Color3.fromRGB(7,4,15),Bg2=Color3.fromRGB(11,7,22),A=Color3.fromRGB(190,50,255),A2=Color3.fromRGB(255,80,220),Line=Color3.fromRGB(30,14,55)},
			["⬜ White Mode"]={Bg0=Color3.fromRGB(244,245,252),Bg1=Color3.fromRGB(230,232,244),Bg2=Color3.fromRGB(216,218,236),A=Color3.fromRGB(80,50,230),A2=Color3.fromRGB(0,160,220),Line=Color3.fromRGB(182,184,212),TxA=Color3.fromRGB(18,20,42),TxB=Color3.fromRGB(76,80,118),TxC=Color3.fromRGB(130,134,170)},
		}
		for pName,pData in pairs(Presets) do
			PS:AddButton({Name=pName, Callback=function()
				for k2,v2 in pairs(pData) do ZNX:SetColor(k2,v2) end
				local a=pData.A or ZNX.Theme.A
				ZNX:SetColor("ADim",Color3.fromRGB(math.floor(a.R*255*.38),math.floor(a.G*255*.38),math.floor(a.B*255*.38)))
				ZNX:SetColor("ABr",Color3.fromRGB(Cl(a.R*255+55,0,255),Cl(a.G*255+55,0,255),Cl(a.B*255+55,0,255)))
				ZNX:SetColor("ASel",Color3.fromRGB(math.floor(a.R*255*.14),math.floor(a.G*255*.14),math.floor(a.B*255*.14)))
				ZNX:SetColor("Scr",a)
				local a2=pData.A2 or ZNX.Theme.A2
				ZNX:SetColor("A2Dim",Color3.fromRGB(math.floor(a2.R*255*.38),math.floor(a2.G*255*.38),math.floor(a2.B*255*.38)))
				local bg=pData.Bg2 or ZNX.Theme.Bg2
				ZNX:SetColor("Bg3",Color3.fromRGB(Cl(bg.R*255+6,0,255),Cl(bg.G*255+6,0,255),Cl(bg.B*255+6,0,255)))
				ZNX:SetColor("Bg4",Color3.fromRGB(Cl(bg.R*255+12,0,255),Cl(bg.G*255+12,0,255),Cl(bg.B*255+12,0,255)))
				ZNX:SetColor("BgI",Color3.fromRGB(Cl(bg.R*255-5,0,255),Cl(bg.G*255-5,0,255),Cl(bg.B*255-5,0,255)))
				ZNX:Notify({Title="🎨 Preset aplicado",Message=pName,Duration=3,Type="ok"})
			end})
		end

		-- ── Save/Load de Configs ─────────────────────────────
		local CfgSec = ST:AddSection({Name = "💾 Configurações"})

		-- Input para nome do perfil
		local profileNameBox = CfgSec:AddTextbox({
			Name="Nome do perfil",
			Default=wCfg.ConfigName,
			Placeholder="ex: minha_config",
		})

		CfgSec:AddButton({Name="💾 Salvar configuração", Callback=function()
			local name = profileNameBox:Get()
			if not name or name=="" then name=wCfg.ConfigName end
			sDb=0 -- força save imediato
			local ok=SaveCfg(name, false)
			-- notificação já está dentro do SaveCfg
		end})

		CfgSec:AddButton({Name="📂 Carregar configuração", Callback=function()
			local name = profileNameBox:Get()
			if not name or name=="" then name=wCfg.ConfigName end
			local ok=LoadCfg(name, false)
			if not ok then
				ZNX:Notify({Title="❌ Perfil não encontrado",Message=name..".json não existe",Duration=4,Type="err"})
			end
		end})

		CfgSec:AddButton({Name="🗑️ Apagar configuração", Callback=function()
			local name = profileNameBox:Get()
			if not name or name=="" then name=wCfg.ConfigName end
			local ok=SaveSystem:Delete(name)
			ZNX:Notify({
				Title=ok and "🗑️ Apagado" or "❌ Erro ao apagar",
				Message=name..".json",Duration=3,
				Type=ok and "ok" or "err"
			})
		end})

		-- Listagem de perfis disponíveis
		local profilesList = CfgSec:AddDropdown({
			Name="Perfis disponíveis",
			Options={"(nenhum)"},
			Default="(nenhum)",
			Callback=function(v)
				if v ~= "(nenhum)" then
					profileNameBox:Set(v)
				end
			end
		})

		CfgSec:AddButton({Name="🔄 Atualizar lista de perfis", Callback=function()
			local profs=SaveSystem:ListProfiles()
			if #profs==0 then profs={"(nenhum)"} end
			profilesList:Refresh(profs, true)
			ZNX:Notify({Title="📋 Perfis encontrados",Message=#profs.." perfil(s)",Duration=2,Type="info"})
		end})

		CfgSec:AddButton({Name="🔄 Resetar tema", Callback=function()
			for k2,v2 in pairs(DT) do ZNX.Theme[k2]=v2 end
			ApplyTheme()
			ZNX:Notify({Title="🎨 Tema resetado",Duration=3,Type="info"})
		end})

		-- ── Misc ────────────────────────────────────────────
		local Misc = ST:AddSection({Name = "⚙️ Misc"})
		Misc:AddDropdown({Name="Posição das notificações", Options={"BottomRight","BottomLeft","TopRight","TopLeft"}, Default=ZNX.NPos, Save=true, Flag="NotifyPos", Callback=function(v)
			ZNX:SetNotifyPosition(v)
		end})
		Misc:AddTextbox({Name="ID imagem de fundo", Default=wCfg.BgImage, Placeholder="ex: 12345678", Callback=function(id)
			wCfg.BgImage=id; BgImg.Image=id~="" and "rbxassetid://"..id or ""; BgDim.BackgroundTransparency=id~="" and 0.38 or 1
			ZNX:Notify({Title="🖼️ Fundo",Message=id~="" and "Imagem aplicada." or "Imagem removida.",Duration=3})
		end})
		Misc:AddBind({Name="Tecla toggle", Default=Enum.KeyCode[wCfg.ToggleKey] or Enum.KeyCode.M, Callback=function()end})

		-- ── Info da sessão ──────────────────────────────────
		local Info = ST:AddSection({Name = "ℹ️ Sessão"})
		Info:AddLabel("👤 "..LP.DisplayName.." (@"..LP.Name..")")
		Info:AddLabel("🆔 UID: "..LP.UserId)
		Info:AddLabel("🔧 ZNXHUB v5.2 · Obsidian Aurora")
		Info:AddLabel("📁 Dir: "..ZNX.SaveDir.."/")
		local detectorLbl=Info:AddLabel("🛡️ Packet Detector: "..(PacketDetector.Active and "✅ Ativo" or "❌ Inativo"))
		task.spawn(function()
			while Alive() do task.wait(2)
				detectorLbl:Set("🛡️ Packet Detector: "..(PacketDetector.Active and "✅ Ativo" or "❌ Inativo"))
			end
		end)
	end

	BuildSettings()

	-- Auto-load ao iniciar
	if wCfg.SaveConfig then
		task.defer(function()
			task.wait(0.5)
			LoadCfg(wCfg.ConfigName, true)
		end)
	end

	return TabFn
end

function ZNX:Init() end
return ZNX
