	-- ══════════════════════════════════════════════════════════
	-- ABA SETTINGS — dentro do painel flutuante (SpScroll)
	-- ══════════════════════════════════════════════════════════
	local function BuildSettingsPanel()
		-- Usa BuildElem diretamente no SpScroll (não cria tab)
		local function SE(par2,secName)
			-- Retorna builder igual a BuildElem mas parenta em par2
			-- Criamos uma "tab fantasma" só para reusar BuildElem
			local fakeTCfg={Name="__settings__"}
			local oldFirst=firstTab; firstTab=true -- não ativa nada
			-- Chamar MakeTab criaria botão/scroll, não queremos isso
			-- Então criamos BuildElem manualmente
			local AllElemsBk=AllElements; AllElements={}  -- isolar
			local EF2={}
			-- Mini BuildElem inline para o settings panel
			local T2=ZNX.Theme
			local function reg2(frame,lbl) table.insert(AllElemsBk,{frame=frame,label=lbl,tabName="settings",sec=secName or ""}) end

			-- Reaproveitar o builder da tab Settings já construída
			-- Mais simples: chamar via closure criando tab "fantasy"
			-- MakeTab já tem BuildElem — fazer um wrapper que retorna BuildElem(SpScroll, secName)
			return EF2
		end

		-- Solução mais simples: criar uma tab oculta e montar nela
		-- mas usar o SpScroll como parent dos elementos
		-- Vamos usar BuildElem diretamente via MakeTab + trocar parent

		-- Criar os elementos diretamente no SpScroll reutilizando
		-- as mesmas funções inline que MakeTab já define
		-- Para evitar duplicação, reutilizamos MakeTab com uma tab "Settings"
		-- invisível e depois conectamos o scroll

		-- ABORDAGEM LIMPA: criar elemento builder para SpScroll
		-- usando um MakeTab invisível
		local ST=TabFn:MakeTab({Name="__Settings_Hidden__",Icon=""})
		-- Esconder o botão e o scroll padrão
		if AllTabs["__Settings_Hidden__"] then
			AllTabs["__Settings_Hidden__"].Btn.Visible=false
			AllTabs["__Settings_Hidden__"].Content.Visible=false
		end

		-- Criar builders que apontam para SpScroll
		-- Reutilizar o mesmo BuildElem que MakeTab criou
		-- Precisamos de um "E" que aponta para SpScroll
		-- Como BuildElem é local dentro de MakeTab, vamos
		-- criar os elementos diretamente no SpScroll usando as funções do E retornado

		-- ST retorna o EF (builder). Vamos criar uma seção e adicionar elementos nela.
		-- MAS o parent é CS (scroll interno), não SpScroll.
		-- Para resolver: após criação, reparentar os elementos para SpScroll.

		-- SOLUÇÃO DEFINITIVA: montar tudo em um frame temporário, depois reparentar
		-- Não — reparentar quebra UIListLayout.

		-- SOLUÇÃO MAIS SIMPLES: Criar um segundo MakeTab com nome visível "Settings"
		-- mas fazer ele aparecer na sidebar normal. O painel flutuante
		-- fica para TEMAS apenas. O usuário clica "Configuracoes" e vai para a tab.

		-- Reverter: fazer Settings ser uma tab NORMAL na sidebar
		-- e o SettingsPanel flutuante apenas para TEMA (colorpickers)
		-- Isso é mais clean.
		if AllTabs["__Settings_Hidden__"] then AllTabs["__Settings_Hidden__"] = nil end

		-- Criar uma Tab normal chamada "Settings"
		local STReal=TabFn:MakeTab({Name="Settings",Icon=""})

		local App=STReal:AddSection({Name="Aparencia"})
		App:AddColorpicker({Name="Cor base da janela",Default=ZNX.Theme.Base,Callback=function(c) ZNX:SetColor("Base",c) end})
		App:AddColorpicker({Name="Superficie (sidebar)",Default=ZNX.Theme.Surface,Callback=function(c) ZNX:SetColor("Surface",c) end})
		App:AddColorpicker({Name="Cards e elementos",Default=ZNX.Theme.Card,Callback=function(c)
			ZNX:SetColor("Card",c)
			ZNX:SetColor("CardHov",Color3.fromRGB(math.min(255,c.R*255+8),math.min(255,c.G*255+8),math.min(255,c.B*255+8)))
			ZNX:SetColor("Input",Color3.fromRGB(math.max(0,c.R*255-10),math.max(0,c.G*255-10),math.max(0,c.B*255-10)))
		end})
		App:AddSlider({Name="Opacidade da imagem de fundo",Min=0,Max=100,Increment=5,Default=math.floor((1-wCfg.BgImageAlpha)*100),Suffix="%",Callback=function(v) local t=1-(v/100); BgImg.ImageTransparency=t; BgDim.BackgroundTransparency=0.3+t*.5 end})

		local Acc=STReal:AddSection({Name="Destaque"})
		Acc:AddColorpicker({Name="Cor principal (ciano)",Default=ZNX.Theme.Accent,Callback=function(c)
			ZNX:SetColor("Accent",c); ZNX:SetColor("AccentLo",Color3.fromRGB(math.floor(c.R*255*.45),math.floor(c.G*255*.45),math.floor(c.B*255*.45))); ZNX:SetColor("AccentHi",Color3.fromRGB(math.min(255,c.R*255+55),math.min(255,c.G*255+55),math.min(255,c.B*255+55))); ZNX:SetColor("AccentGlow",c); ZNX:SetColor("Scroll",c)
		end})
		Acc:AddColorpicker({Name="Cor secundaria (roxo)",Default=ZNX.Theme.Accent2,Callback=function(c) ZNX:SetColor("Accent2",c); ZNX:SetColor("Acc2Lo",Color3.fromRGB(math.floor(c.R*255*.45),math.floor(c.G*255*.45),math.floor(c.B*255*.45))) end})

		local BT=STReal:AddSection({Name="Bordas e Texto"})
		BT:AddColorpicker({Name="Bordas",Default=ZNX.Theme.Border,Callback=function(c) ZNX:SetColor("Border",c) end})
		BT:AddColorpicker({Name="Texto principal",Default=ZNX.Theme.TxtA,Callback=function(c) ZNX:SetColor("TxtA",c) end})
		BT:AddColorpicker({Name="Texto secundario",Default=ZNX.Theme.TxtB,Callback=function(c) ZNX:SetColor("TxtB",c) end})

		local PS=STReal:AddSection({Name="Presets de Tema"})
		local Presets={
			["ZNXHUB Default"]={Base=Color3.fromRGB(7,7,11),Surface=Color3.fromRGB(11,11,17),Card=Color3.fromRGB(18,18,28),Accent=Color3.fromRGB(0,200,255),Accent2=Color3.fromRGB(120,80,255),Border=Color3.fromRGB(30,34,52)},
			["Blood Red"]={Base=Color3.fromRGB(10,4,4),Surface=Color3.fromRGB(16,6,6),Card=Color3.fromRGB(24,10,10),Accent=Color3.fromRGB(255,50,50),Accent2=Color3.fromRGB(200,20,80),Border=Color3.fromRGB(60,16,16)},
			["Emerald"]={Base=Color3.fromRGB(4,10,6),Surface=Color3.fromRGB(6,16,9),Card=Color3.fromRGB(10,24,14),Accent=Color3.fromRGB(0,230,120),Accent2=Color3.fromRGB(0,180,80),Border=Color3.fromRGB(16,54,24)},
			["Gold Rush"]={Base=Color3.fromRGB(10,8,4),Surface=Color3.fromRGB(16,13,5),Card=Color3.fromRGB(26,20,8),Accent=Color3.fromRGB(255,190,30),Accent2=Color3.fromRGB(220,120,20),Border=Color3.fromRGB(64,48,14)},
			["Pure White"]={Base=Color3.fromRGB(245,246,252),Surface=Color3.fromRGB(234,235,246),Card=Color3.fromRGB(222,224,238),Accent=Color3.fromRGB(0,140,220),Accent2=Color3.fromRGB(100,60,220),Border=Color3.fromRGB(188,190,214),TxtA=Color3.fromRGB(22,24,46),TxtB=Color3.fromRGB(86,90,126),TxtC=Color3.fromRGB(140,144,174)},
		}
		for pName,pData in pairs(Presets) do
			PS:AddButton({Name=pName,Callback=function()
				for k2,v2 in pairs(pData) do ZNX:SetColor(k2,v2) end
				local a=pData.Accent or ZNX.Theme.Accent; ZNX:SetColor("AccentLo",Color3.fromRGB(math.floor(a.R*255*.45),math.floor(a.G*255*.45),math.floor(a.B*255*.45))); ZNX:SetColor("AccentHi",Color3.fromRGB(math.min(255,a.R*255+55),math.min(255,a.G*255+55),math.min(255,a.B*255+55))); ZNX:SetColor("Scroll",a)
				local bg=pData.Card or ZNX.Theme.Card; ZNX:SetColor("CardHov",Color3.fromRGB(math.min(255,bg.R*255+8),math.min(255,bg.G*255+8),math.min(255,bg.B*255+8))); ZNX:SetColor("Input",Color3.fromRGB(math.max(0,bg.R*255-10),math.max(0,bg.G*255-10),math.max(0,bg.B*255-10)))
				ZNX:Notify({Title="Preset Aplicado",Message=pName,Duration=3})
			end})
		end

		local Cfg=STReal:AddSection({Name="Configuracao"})
		Cfg:AddButton({Name="Salvar Config",Callback=function() sDb=0; SaveCfg(wCfg.ConfigName); ZNX:Notify({Title="Config Salva",Message=ZNX.SaveDir.."/"..wCfg.ConfigName..".json",Duration=4}) end})
		Cfg:AddButton({Name="Resetar Tema",Callback=function() for k2,v2 in pairs(DT) do ZNX.Theme[k2]=v2 end; ApplyTheme(); ZNX:Notify({Title="Tema Resetado",Message="Padrao restaurado.",Duration=3}) end})
		Cfg:AddDropdown({Name="Posicao das Notificacoes",Options={"BottomRight","BottomLeft","TopRight","TopLeft"},Default="BottomRight",Callback=function(v) ZNX:SetNotifyPosition(v) end})
		Cfg:AddTextbox({Name="ID Imagem de Fundo",Default=wCfg.BgImage,Placeholder="ex: 123456789",Callback=function(id)
			wCfg.BgImage=id; BgImg.Image=id~="" and "rbxassetid://"..id or""; BgDim.BackgroundTransparency=id~="" and 0.4 or 1
			ZNX:Notify({Title="Fundo",Message=id~="" and "Imagem aplicada." or "Imagem removida.",Duration=3})
		end})
		-- Imagens salvas
		local IS=STReal:AddSection({Name="Imagens de Fundo Salvas"})
		IS:AddImageDropdown({Name="Gerenciar Imagens",SaveKey="__ZNX2BgImages",OnApply=function(id) wCfg.BgImage=id; BgImg.Image="rbxassetid://"..id; BgDim.BackgroundTransparency=0.4 end})

		-- O SettingsPanel flutuante agora é só para tema rápido (um link)
		-- Simplificar: esconder o painel flutuante e o botão Settings da sidebar
		-- O botão "Configuracoes" na sidebar agora ativa a tab Settings
		C(SettingsBtn.MouseButton1Up,function()
			-- Ativar a tab Settings ao clicar no botão
			if AllTabs["Settings"] then
				for _,td in pairs(AllTabs) do
					Tw(td.Btn,TI.Fast,{BackgroundTransparency=0.5,BackgroundColor3=ZNX.Theme.Surface})
					local b=td.Btn:FindFirstChild("__IB"); if b then Tw(b,TI.Fast,{BackgroundTransparency=1}) end
					local ic=td.Btn:FindFirstChildOfClass("ImageLabel"); if ic then Tw(ic,TI.Fast,{ImageColor3=ZNX.Theme.TxtC}) end
					local lb=td.Btn:FindFirstChildOfClass("TextLabel"); if lb then Tw(lb,TI.Fast,{TextColor3=ZNX.Theme.TxtC}) end
					td.Content.Visible=false
				end
				local std=AllTabs["Settings"]
				Tw(std.Btn,TI.Fast,{BackgroundTransparency=0,BackgroundColor3=ZNX.Theme.Card})
				local b2=std.Btn:FindFirstChild("__IB"); if b2 then Tw(b2,TI.Fast,{BackgroundTransparency=0}) end
				local ic2=std.Btn:FindFirstChildOfClass("ImageLabel"); if ic2 then Tw(ic2,TI.Fast,{ImageColor3=ZNX.Theme.Accent}) end
				local lb2=std.Btn:FindFirstChildOfClass("TextLabel"); if lb2 then Tw(lb2,TI.Fast,{TextColor3=ZNX.Theme.TxtA}) end
				std.Content.Visible=true; ActiveTab="Settings"
			end
		end)
		-- Desativar as antigas conexões do SettingsBtn (já conectamos acima)
		-- Esconder painel flutuante pois não usamos mais
		SettingsPanel.Visible=false
	end

	BuildSettingsPanel()
	if wCfg.SaveConfig then task.defer(function() LoadCfg(wCfg.ConfigName) end) end
	return TabFn
end

