	local TabFn={}; local firstTab=true

	function TabFn:MakeTab(tCfg)
		tCfg=tCfg or{}; tCfg.Name=tCfg.Name or "Tab"; tCfg.Icon=tCfg.Icon or ""
		local T=ZNX.Theme

		-- Botão tab: retângulo horizontal sem bordas laterais
		-- Active: fundo laranja dim + borda inferior laranja
		local TBut=N("TextButton",{Parent=TabScroll,Size=UDim2.new(0,math.max(70,#tCfg.Name*8+28),1,0),BackgroundColor3=T.Panel,BorderSizePixel=0,Text="",AutoButtonColor=false,ZIndex=11})
		B(TBut,"BackgroundColor3","Panel")
		-- Borda inferior (indicador ativo)
		local IndLine=N("Frame",{Parent=TBut,Position=UDim2.new(0,0,1,-2),Size=UDim2.new(1,0,0,2),BackgroundColor3=T.Acc,BackgroundTransparency=1,BorderSizePixel=0})
		B(IndLine,"BackgroundColor3","Acc")
		-- Separador vertical direito
		N("Frame",{Parent=TBut,Position=UDim2.new(1,-1,0.2,0),Size=UDim2.new(0,1,0.6,0),BackgroundColor3=T.Line,BorderSizePixel=0})
		local TLbl=N("TextLabel",{Parent=TBut,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-12,1,0),BackgroundTransparency=1,Text=tCfg.Name,Font=Enum.Font.Code,TextSize=12,TextColor3=T.TxtC,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12})

		-- Scroll de conteúdo (ocupa toda a ContentArea)
		local CS=MkScroll(ContentArea)
		CS.Size=UDim2.new(1,0,1,0); CS.Position=UDim2.new(0,0,0,0); CS.Visible=false; CS.ZIndex=9
		local CSList=N("UIListLayout",{Parent=CS,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,0)})
		-- SEM padding global — elementos encostam nas bordas, estilo terminal
		C(CSList:GetPropertyChangedSignal("AbsoluteContentSize"),function() CS.CanvasSize=UDim2.new(0,0,0,CSList.AbsoluteContentSize.Y+20) end)

		AllTabs[tCfg.Name]={Btn=TBut,Content=CS}

		local function Activate()
			for _,td in pairs(AllTabs) do
				Tw(td.Btn,TI.Fast,{BackgroundColor3=ZNX.Theme.Panel})
				local ib=td.Btn:FindFirstChildOfClass("Frame"); if ib then Tw(ib,TI.Fast,{BackgroundTransparency=1}) end
				local lb=td.Btn:FindFirstChildOfClass("TextLabel"); if lb then Tw(lb,TI.Fast,{TextColor3=ZNX.Theme.TxtC}) end
				td.Content.Visible=false
			end
			Tw(TBut,TI.Fast,{BackgroundColor3=ZNX.Theme.RowSel})
			Tw(IndLine,TI.Fast,{BackgroundTransparency=0})
			Tw(TLbl,TI.Fast,{TextColor3=ZNX.Theme.Acc})
			CS.Visible=true; ActiveTab=tCfg.Name
		end
		C(TBut.MouseButton1Up,Activate)
		C(TBut.MouseEnter,function() if ActiveTab~=tCfg.Name then Tw(TBut,TI.Fast,{BackgroundColor3=ZNX.Theme.RowHov}) end end)
		C(TBut.MouseLeave,function() if ActiveTab~=tCfg.Name then Tw(TBut,TI.Fast,{BackgroundColor3=ZNX.Theme.Panel}) end end)
		if firstTab then firstTab=false; Activate() end

