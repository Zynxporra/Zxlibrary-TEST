				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-22,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=NexusLib.Theme.TextMuted,
				})
				local sep = New("Frame",{Parent=outer,Position=UDim2.new(0,0,0,38),Size=UDim2.new(1,0,0,1),BackgroundColor3=NexusLib.Theme.Border,BorderSizePixel=0,Visible=false})
				ThemeBind(sep,"BackgroundColor3","Border")

				local optScroll = MakeScrollFrame(outer)
				optScroll.Position = UDim2.new(0,0,0,39)
				optScroll.Size = UDim2.new(1,0,1,-39)
				New("UIListLayout",{Parent=optScroll,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
				New("UIPadding",{Parent=optScroll,PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4)})
				Connect(optScroll.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
					optScroll.CanvasSize=UDim2.new(0,0,0,optScroll.UIListLayout.AbsoluteContentSize.Y+8)
				end)

				local function AddOptions(playerList)
					for _, p in ipairs(playerList) do
						local isSelected = DD.SelectedPlayers[p]
						local ob = New("TextButton",{
							Parent=optScroll,Size=UDim2.new(1,0,0,40),
							BackgroundColor3=isSelected and GetSelectedBg() or NexusLib.Theme.BgPanel,
							BorderSizePixel=0, Text="", AutoButtonColor=false,
						},{
							New("UICorner",{CornerRadius=UDim.new(0,5)}),
							New("UIStroke",{Color=NexusLib.Theme.Border,Thickness=1}),
						})
						ThemeBind(ob:FindFirstChildOfClass("UIStroke"),"Color","Border")

						local selBar = New("Frame",{
							Parent=ob, Position=UDim2.new(0,0,0.1,0), Size=UDim2.new(0,3,0.8,0),
							BackgroundColor3=NexusLib.Theme.Accent,
							BackgroundTransparency=isSelected and 0 or 1, BorderSizePixel=0,
						},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
						selBar.Name = "SelBar"
						ThemeBind(selBar,"BackgroundColor3","Accent")

						New("ImageLabel",{
							Parent=ob,Position=UDim2.new(0,5,0.5,-15),Size=UDim2.new(0,30,0,30),
							BackgroundTransparency=1,Image="https://www.roblox.com/headshot-thumbnail/image?userId="..p.UserId.."&width=420&height=420&format=png",
						},{New("UICorner",{CornerRadius=UDim.new(1,0)})})

						local dname = New("TextLabel",{
							Parent=ob,Position=UDim2.new(0,42,0,5),Size=UDim2.new(0.65,-10,0,18),
							BackgroundTransparency=1,Text=p.DisplayName,Font=Enum.Font.GothamBold,TextSize=14,
							TextColor3=isSelected and NexusLib.Theme.Accent or NexusLib.Theme.TextPrimary,
							TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,
						})
						ThemeBind(dname,"TextColor3","TextPrimary")

						local uname = New("TextLabel",{
							Parent=ob,Position=UDim2.new(0,42,0,22),Size=UDim2.new(0.65,-10,0,14),
							BackgroundTransparency=1,Text="@"..p.Name,Font=Enum.Font.GothamMedium,TextSize=11,
							TextColor3=NexusLib.Theme.TextSecondary,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd,
						})
						ThemeBind(uname,"TextColor3","TextSecondary")

						Connect(ob.MouseButton1Up,function()
							if DD.SelectedPlayers[p] then
								DD.SelectedPlayers[p] = nil
							else
								DD.SelectedPlayers[p] = true
							end
							DD:Set()
							if pdCfg.Save then SaveConfig(cfg.ConfigName) end
						end)
						Connect(ob.MouseEnter,function()
							if not DD.SelectedPlayers[p] then
								TPlay(ob,TW.Fast,{BackgroundColor3=NexusLib.Theme.BgHover})
							end
						end)
						Connect(ob.MouseLeave,function()
							TPlay(ob,TW.Fast,{BackgroundColor3=DD.SelectedPlayers[p] and GetSelectedBg() or NexusLib.Theme.BgPanel})
						end)

						DD.Buttons[p] = ob
					end
				end

				function DD:Refresh(list, clear)
					if clear then
						for _, btn in pairs(self.Buttons) do btn:Destroy() end
						table.clear(self.Buttons)
					end
					AddOptions(list)
				end

				function DD:Set()
					local selectedUsernames = {}
					for p in pairs(self.SelectedPlayers) do
						if Players:FindFirstChild(p.Name) then
							table.insert(selectedUsernames, p.Name)
						else
							self.SelectedPlayers[p] = nil
						end
					end
					if #selectedUsernames > 0 then
						selLbl.Text = table.concat(selectedUsernames, ", ")
					else
						selLbl.Text = "Selecione"
					end
					for p, btn in pairs(self.Buttons) do
						local isSelected = self.SelectedPlayers[p]
						local sbar = btn:FindFirstChild("SelBar")
						TPlay(btn,TW.Fast,{BackgroundColor3=isSelected and GetSelectedBg() or NexusLib.Theme.BgPanel})
						if sbar then TPlay(sbar,TW.Fast,{BackgroundTransparency=isSelected and 0 or 1}) end
						for _, lbl in ipairs(btn:GetChildren()) do
							if lbl:IsA("TextLabel") and lbl.Font == Enum.Font.GothamBold then
								TPlay(lbl,TW.Fast,{TextColor3=isSelected and NexusLib.Theme.Accent or NexusLib.Theme.TextPrimary})
							end
						end
					end
					return pdCfg.Callback(selectedUsernames)
				end

				local Hbtn = New("TextButton",{
					Parent=header,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})
				Connect(Hbtn.MouseButton1Up,function()
					DD.Toggled = not DD.Toggled
					sep.Visible = DD.Toggled
					TPlay(arrow,TW.Fast,{Rotation=DD.Toggled and 180 or 0})
					local targetHeight = 38
					if DD.Toggled then
						local listHeight = math.min(optScroll.UIListLayout.AbsoluteContentSize.Y, MaxElements*40)
						targetHeight = 38 + listHeight
					end
					TPlay(outer,TW.Mid,{Size=UDim2.new(1,0,0,targetHeight)})
				end)

				local function updateList()
					local allPlayers = Players:GetPlayers()
					local filtered = {}
					for _, p in ipairs(allPlayers) do
						if p ~= Players.LocalPlayer then
							table.insert(filtered, p)
						end
					end
					DD:Refresh(filtered, true)
					DD:Set()
				end

				Connect(Players.PlayerAdded,    updateList)
				Connect(Players.PlayerRemoving, updateList)
				updateList()

				if pdCfg.Flag then NexusLib.Flags[pdCfg.Flag] = DD end
				return DD
			end

