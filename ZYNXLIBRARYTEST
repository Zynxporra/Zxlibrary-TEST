-- ── CONNECTIONS ──────────────────────────────────────────────
local function Alive() return Root and Root.Parent~=nil end
local function C(sig,fn) if not Alive() then return end; local c=sig:Connect(fn); table.insert(ZNX.Conns,c); return c end
task.spawn(function()
	while Alive() do task.wait(.5) end
	for _,c in pairs(ZNX.Conns) do pcall(function() c:Disconnect() end) end
