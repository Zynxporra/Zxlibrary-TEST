                Bind(HexBg,"BackgroundColor3","InputBg")
                local HexSt=HexBg:FindFirstChildOfClass("UIStroke"); Bind(HexSt,"Color","Border")
                New("TextLabel",{Parent=HexBg,Position=UDim2.new(0,6,0,0),Size=UDim2.new(0,16,1,0),
                    BackgroundTransparency=1,Text="#",Font=Enum.Font.GothamBold,TextSize=12,
                    TextColor3=NL.Theme.TextDim,ZIndex=23})
                local HexTB=New("TextBox",{Parent=HexBg,Position=UDim2.new(0,20,0,0),
                    Size=UDim2.new(1,-26,1,0),ZIndex=23,BackgroundTransparency=1,
                    Text=C3toHex(CP.Default),PlaceholderText="RRGGBB",
                    PlaceholderColor3=NL.Theme.TextMuted,Font=Enum.Font.GothamBold,
                    TextSize=12,TextColor3=NL.Theme.TextH1,ClearTextOnFocus=true})
                Bind(HexTB,"TextColor3","TextH1")

                local lastUp=0
                local function UpdateCP()
                    local now=tick(); if now-lastUp<0.02 then return end; lastUp=now
                    local nc=HSV(cpH,cpS,cpV)
                    Cpk.Value=nc; Swatch.BackgroundColor3=nc
                    SVB.BackgroundColor3=HSV(cpH,1,1); HexTB.Text=C3toHex(nc)
                    CP.Callback(nc)
                end

                -- SV drag (independent)
                local svD,svI=false,nil
                Conn(SVB.InputBegan,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                    or inp.UserInputType==Enum.UserInputType.Touch then
                        svD=true
                        Conn(inp.Changed,function()
                            if inp.UserInputState==Enum.UserInputState.End then
                                svD=false; svI=nil; Save(WC.ConfigName)
                            end
                        end)
                    end
                end)
                Conn(SVB.InputChanged,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseMovement
                    or inp.UserInputType==Enum.UserInputType.Touch then svI=inp end
                end)
                Conn(UIS.InputChanged,function(inp)
                    if not svD or inp~=svI then return end
                    cpS=Clamp((inp.Position.X-SVB.AbsolutePosition.X)/SVB.AbsoluteSize.X,0,1)
                    cpV=1-Clamp((inp.Position.Y-SVB.AbsolutePosition.Y)/SVB.AbsoluteSize.Y,0,1)
                    SVC.Position=UDim2.new(cpS,0,1-cpV,0); UpdateCP()
                end)

                -- Hue drag (independent)
                local hD,hI=false,nil
                Conn(HueB.InputBegan,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                    or inp.UserInputType==Enum.UserInputType.Touch then
                        hD=true
                        Conn(inp.Changed,function()
                            if inp.UserInputState==Enum.UserInputState.End then
                                hD=false; hI=nil; Save(WC.ConfigName)
                            end
                        end)
                    end
                end)
                Conn(HueB.InputChanged,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseMovement
                    or inp.UserInputType==Enum.UserInputType.Touch then hI=inp end
                end)
                Conn(UIS.InputChanged,function(inp)
                    if not hD or inp~=hI then return end
                    cpH=1-Clamp((inp.Position.Y-HueB.AbsolutePosition.Y)/HueB.AbsoluteSize.Y,0,1)
                    HC.Position=UDim2.new(0.5,0,1-cpH,0); UpdateCP()
                end)

                Conn(HexTB.FocusLost,function()
                    local c=HextoC3(HexTB.Text); if c then Cpk:Set(c) end
                end)

                local HBtn2=ClickBtn(Hdr,26)
                Conn(HBtn2.MouseButton1Up,function()
                    Cpk.Toggled=not Cpk.Toggled
                    Sep2.Visible=Cpk.Toggled; Body.Visible=Cpk.Toggled; HexBg.Visible=Cpk.Toggled
                    Tw(Arr,TI.Fast,{Rotation=Cpk.Toggled and 180 or 0})
                    Tw(Outer,TI.Mid,{Size=Cpk.Toggled and UDim2.new(1,0,0,200) or UDim2.new(1,0,0,36)})
                end)

                function Cpk:Set(c)
                    Cpk.Value=c; cpH,cpS,cpV=Color3.toHSV(c)
                    Swatch.BackgroundColor3=c; SVB.BackgroundColor3=HSV(cpH,1,1)
                    SVC.Position=UDim2.new(cpS,0,1-cpV,0); HC.Position=UDim2.new(0.5,0,1-cpH,0)
                    HexTB.Text=C3toHex(c); CP.Callback(c)
                end
                Cpk:Set(CP.Default)
                if CP.Flag then NL.Flags[CP.Flag]=Cpk end
                return Cpk
            end

            -- SECTION
            function EF:AddSection(SC2)
                SC2=SC2 or {}; SC2.Name=SC2.Name or "Section"
                local Wrap=New("Frame",{Parent=ItemParent,Size=UDim2.new(1,0,0,0),
                    AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,ZIndex=20})
                local Row=New("Frame",{Parent=Wrap,Size=UDim2.new(1,0,0,22),BackgroundTransparency=1,ZIndex=20})
                local AccBar2=New("Frame",{Parent=Row,Position=UDim2.new(0,0,0.5,-6),
                    Size=UDim2.new(0,3,0,12),BackgroundColor3=NL.Theme.Accent,BorderSizePixel=0,ZIndex=21},{Crn(1)})
                Bind(AccBar2,"BackgroundColor3","Accent")
                local SLbl=New("TextLabel",{Parent=Row,Position=UDim2.new(0,10,0,0),
                    Size=UDim2.new(1,-10,1,0),ZIndex=21,BackgroundTransparency=1,
                    Text=SC2.Name:upper(),Font=Enum.Font.GothamBlack,TextSize=11,
                    TextColor3=NL.Theme.TextDim,TextXAlignment=Enum.TextXAlignment.Left})
                Bind(SLbl,"TextColor3","TextDim")
                -- faint line after label
                New("Frame",{Parent=Row,Position=UDim2.new(0,14+#SC2.Name*7,0.5,0),
                    Size=UDim2.new(1,-(14+#SC2.Name*7+4),0,1),
                    BackgroundColor3=NL.Theme.Border,BorderSizePixel=0,ZIndex=21})
                local Holder=New("Frame",{Parent=Wrap,Position=UDim2.new(0,0,0,24),
                    Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
                    BackgroundTransparency=1,ZIndex=20},{List(6)})
                return BuildEF(Holder)
            end

            return EF
        end -- BuildEF

        -- expose tab-level elements
        local tabEF=BuildEF(TabSFr)
        return tabEF
    end -- MakeTab

    -- ══════════════════════════════════════════════════════════════════
    -- BUILT-IN SETTINGS TAB
    -- ══════════════════════════════════════════════════════════════════
    do
        local ST=TF:MakeTab({Name="⚙ Settings",Icon=""})

        -- APPEARANCE
        local App=ST:AddSection({Name="Appearance"})
        App:AddColorpicker({Name="Window Background",Default=NL.Theme.WinBg,Callback=function(c)
            NL:SetColor("WinBg",c); NL:SetColor("WinBgAlt",Lighten(c,0.04))
        end})
        App:AddColorpicker({Name="Topbar",Default=NL.Theme.TopbarBg,Callback=function(c)
            NL:SetColor("TopbarBg",c)
        end})
        App:AddColorpicker({Name="Sidebar",Default=NL.Theme.SidebarBg,Callback=function(c)
            NL:SetColor("SidebarBg",c)
        end})
        App:AddColorpicker({Name="Cards",Default=NL.Theme.CardBg,Callback=function(c)
            NL:SetColor("CardBg",c); NL:SetColor("CardHover",Lighten(c,0.06))
            NL:SetColor("CardActive",Lighten(c,0.03)); NL:SetColor("InputBg",Darken(c,0.04))
        end})
        App:AddColorpicker({Name="Borders",Default=NL.Theme.Border,Callback=function(c)
            NL:SetColor("Border",c); NL:SetColor("BorderBright",Lighten(c,0.15))
        end})

        -- ACCENT
        local Acc=ST:AddSection({Name="Accent"})
        Acc:AddColorpicker({Name="Accent Color",Default=NL.Theme.Accent,Callback=function(c)
            NL:SetColor("Accent",c); NL:SetColor("AccentBright",Lighten(c,0.15))
            NL:SetColor("AccentDim",Darken(c,0.25)); NL:SetColor("AccentAlpha",Darken(c,0.68))
            NL:SetColor("TrackOn",Darken(c,0.12)); NL:SetColor("ScrollBar",c)
        end})

        -- TEXT
        local Txt=ST:AddSection({Name="Text"})
        Txt:AddColorpicker({Name="Primary Text",Default=NL.Theme.TextH1,Callback=function(c) NL:SetColor("TextH1",c) end})
        Txt:AddColorpicker({Name="Secondary Text",Default=NL.Theme.TextH2,Callback=function(c) NL:SetColor("TextH2",c) end})
        Txt:AddColorpicker({Name="Body Text",Default=NL.Theme.Text,Callback=function(c) NL:SetColor("Text",c) end})
        Txt:AddColorpicker({Name="Dim Text",Default=NL.Theme.TextDim,Callback=function(c) NL:SetColor("TextDim",c) end})

        -- BACKGROUND IMAGE
        local BgSec=ST:AddSection({Name="Background Image"})
        BgSec:AddTextbox({Name="Image URL / Asset ID",Default=NL.Theme.BgImageUrl,
            Placeholder="rbxassetid://... or https://...",Callback=function(url)
                url=url:gsub("%s+",""); NL:SetColor("BgImageUrl",url)
                if url~="" then
                    if not table.find(NL._BgLib,url) then table.insert(NL._BgLib,url) end
                    Save(WC.ConfigName)
                end
            end})
        BgSec:AddSlider({Name="Image Opacity",Min=0,Max=100,Increment=1,
            Default=math.floor((1-NL.Theme.BgImageTrans)*100),Suffix="%",
            Callback=function(v) NL:SetColor("BgImageTrans",1-(v/100)) end})
        BgSec:AddDropdown({Name="Saved Backgrounds",
            Options=#NL._BgLib>0 and NL._BgLib or {"(none saved)"},
            Default=#NL._BgLib>0 and NL._BgLib[1] or "(none saved)",
            Callback=function(url) if url~="(none saved)" then NL:SetColor("BgImageUrl",url) end end})
        BgSec:AddButton({Name="Clear Background",Callback=function()
            NL:SetColor("BgImageUrl","")
            NL:Notify({Title="Cleared",Message="Background removed.",Type="info",Duration=3})
        end})
        BgSec:AddButton({Name="Remove from Library",Desc="Deletes current URL from saved list",
            Callback=function()
                local url=NL.Theme.BgImageUrl
                for i,v in ipairs(NL._BgLib) do
                    if v==url then table.remove(NL._BgLib,i); Save(WC.ConfigName)
                        NL:Notify({Title="Removed",Message="URL removed from library.",Type="warning",Duration=3}); return
                    end
                end
                NL:Notify({Title="Not Found",Message="URL not in library.",Type="error",Duration=3})
            end})

        -- PRESETS
        local Pre=ST:AddSection({Name="Theme Presets"})
        local Presets={
            {Name="Neon Teal",D={WinBg=C3(10,10,15),TopbarBg=C3(8,8,13),SidebarBg=C3(9,9,14),CardBg=C3(18,18,28),Border=C3(35,37,58),Accent=C3(0,210,175),TextH1=C3(240,242,255),Text=C3(170,173,200)}},
            {Name="Crimson",D={WinBg=C3(12,6,6),TopbarBg=C3(9,4,4),SidebarBg=C3(10,5,5),CardBg=C3(22,10,10),Border=C3(60,22,22),Accent=C3(220,55,55),TextH1=C3(255,235,235),Text=C3(185,155,155)}},
            {Name="Electric Blue",D={WinBg=C3(6,8,18),TopbarBg=C3(4,6,14),SidebarBg=C3(5,7,16),CardBg=C3(10,14,30),Border=C3(28,38,80),Accent=C3(70,140,255),TextH1=C3(230,235,255),Text=C3(155,165,215)}},
            {Name="Golden Hour",D={WinBg=C3(16,11,5),TopbarBg=C3(11,7,3),SidebarBg=C3(12,8,4),CardBg=C3(26,18,8),Border=C3(65,45,16),Accent=C3(255,190,40),TextH1=C3(255,248,225),Text=C3(195,170,130)}},
            {Name="Void Purple",D={WinBg=C3(9,6,16),TopbarBg=C3(7,4,12),SidebarBg=C3(8,5,14),CardBg=C3(16,10,28),Border=C3(45,28,75),Accent=C3(165,90,255),TextH1=C3(240,232,255),Text=C3(170,150,215)}},
            {Name="Forest",D={WinBg=C3(6,12,8),TopbarBg=C3(4,9,5),SidebarBg=C3(5,10,6),CardBg=C3(10,20,12),Border=C3(24,50,28),Accent=C3(60,200,100),TextH1=C3(220,255,228),Text=C3(140,185,150)}},
            {Name="Cyber Pink",D={WinBg=C3(14,6,12),TopbarBg=C3(10,4,9),SidebarBg=C3(12,5,10),CardBg=C3(22,10,20),Border=C3(60,22,55),Accent=C3(255,60,200),TextH1=C3(255,228,250),Text=C3(195,148,190)}},
            {Name="Arctic",D={WinBg=C3(238,240,250),TopbarBg=C3(220,224,240),SidebarBg=C3(228,232,245),CardBg=C3(248,250,255),Border=C3(195,200,225),Accent=C3(50,120,255),TextH1=C3(30,32,52),Text=C3(90,95,135),TrackOff=C3(180,185,215)}},
        }
        for _,preset in ipairs(Presets) do
            Pre:AddButton({Name=preset.Name,Callback=function()
                NL:SetTheme(preset.D)
                local a=preset.D.Accent or NL.Theme.Accent
                NL:SetColor("AccentBright",Lighten(a,0.15)); NL:SetColor("AccentDim",Darken(a,0.25))
                NL:SetColor("AccentAlpha",Darken(a,0.68)); NL:SetColor("TrackOn",Darken(a,0.12))
                NL:SetColor("ScrollBar",a)
                local bg=preset.D.CardBg or NL.Theme.CardBg
                NL:SetColor("CardHover",Lighten(bg,0.06)); NL:SetColor("CardActive",Lighten(bg,0.03))
                NL:SetColor("InputBg",Darken(bg,0.04))
                local w=preset.D.WinBg or NL.Theme.WinBg
                NL:SetColor("WinBgAlt",Lighten(w,0.04))
                NL:Notify({Title="Preset: "..preset.Name,Message="Theme applied.",Type="success",Duration=3})
            end})
        end

        -- CONFIG
        local Cfg=ST:AddSection({Name="Config"})
        Cfg:AddButton({Name="💾  Save Config",Desc="Saves all flags and theme to disk",Callback=function()
            _sLast=0; DoSave(WC.ConfigName)
            NL:Notify({Title="Saved",Message=NL.SaveFolder.."/"..WC.ConfigName..".json",Type="success",Duration=4})
        end})
        Cfg:AddButton({Name="🔄  Reset Theme",Desc="Restore all default colors",Callback=function()
            for k,v in pairs(DT) do NL.Theme[k]=v end; ApplyTheme()
            NL:Notify({Title="Reset",Message="Default theme restored.",Type="info",Duration=3})
        end})
        Cfg:AddButton({Name="🗑  Delete Config File",Callback=function()
            local path=NL.SaveFolder.."/"..WC.ConfigName..".json"
            if delfile and isfile and isfile(path) then
                pcall(delfile,path)
                NL:Notify({Title="Deleted",Message="Config file removed.",Type="warning",Duration=3})
            else
                NL:Notify({Title="Not Found",Message="No config file found.",Type="error",Duration=3})
            end
        end})
    end -- settings tab

    -- Load saved config after all tabs are ready
    if WC.SaveConfig then
        task.defer(function() task.wait(0.35); Load(WC.ConfigName) end)
    end

    return TF
end -- MakeWindow

-- ── INIT ─────────────────────────────────────────────────────────────
function NL:Init() end -- forward compat

return NL
