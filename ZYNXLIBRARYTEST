-- ── HELPERS ──────────────────────────────────────────────────
local function N(cls, props, children)
	local o = Instance.new(cls)
	for k,v in pairs(props or {}) do o[k]=v end
	for _,c in pairs(children or {}) do c.Parent=o end
	return o
end
local function Rnd(n,f) if not f or f==0 then return n end; return math.clamp(math.floor(n/f+.5)*f,f,1e9) end
local function CPk(c) return{R=math.round(c.R*255),G=math.round(c.G*255),B=math.round(c.B*255)} end
local function CUp(t) return type(t)=="table" and Color3.fromRGB(math.clamp(t.R,0,255),math.clamp(t.G,0,255),math.clamp(t.B,0,255)) or Color3.fromRGB(200,200,200) end
local function Snd(id,v) local s=N("Sound",{SoundId=id,Volume=v or .2,Parent=SS}); s:Play(); game.Debris:AddItem(s,4) end

