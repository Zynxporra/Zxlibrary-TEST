				ThemeBind(outer,"BackgroundColor3","BgCard")
				ThemeBind(outer:FindFirstChildOfClass("UIStroke"),"Color","Border")

				local header = New("Frame",{Parent=outer,Size=UDim2.new(1,0,0,38),BackgroundTransparency=1})
				New("TextLabel",{
					Parent=header,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-80,1,0),
					BackgroundTransparency=1,Text=dCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local selLbl = New("TextLabel",{
					Parent=header,Position=UDim2.new(1,-100,0,0),Size=UDim2.new(0,70,1,0),
					BackgroundTransparency=1,Text="Selected",
					Font=Enum.Font.Gotham,TextSize=13,
					TextColor3=T_.TextSecondary,TextXAlignment=Enum.TextXAlignment.Right,
				})
				ThemeBind(selLbl,"TextColor3","TextSecondary")
				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-22,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=T_.TextMuted,
				})

				local sep = New("Frame",{Parent=outer,Position=UDim2.new(0,0,0,38),Size=UDim2.new(1,0,0,1),BackgroundColor3=T_.Border,BorderSizePixel=0,Visible=false})
				ThemeBind(sep,"BackgroundColor3","Border")

				local optScroll = MakeScrollFrame(outer)
				optScroll.Position = UDim2.new(0,0,0,39)
				optScroll.Size = UDim2.new(1,0,1,-39)
				New("UIListLayout",{Parent=optScroll,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
				New("UIPadding",{Parent=optScroll,PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4)})
				Connect(optScroll.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
					optScroll.CanvasSize=UDim2.new(0,0,0,optScroll.UIListLayout.AbsoluteContentSize.Y+8)
				end)

				local function RemoveOption(playerName)
					local btn = DD.Buttons[playerName]
					if not btn then return end
					local isSelected = table.find(SelectedValues, playerName) ~= nil
					if isSelected then
						local stateIco = btn:FindFirstChild("DisconnectIcon")
						TPlay(btn, TW.Mid, {BackgroundColor3 = GetDisconnectedBg()})
						if stateIco then stateIco.Visible = true end
						for _, lbl in ipairs(btn:GetChildren()) do
							if lbl:IsA("TextLabel") then
								TPlay(lbl, TW.Mid, {TextColor3 = Color3.fromRGB(180, 80, 80)})
							end
						end
						btn:SetAttribute("Disconnected", true)
					else
						btn:Destroy()
						DD.Buttons[playerName] = nil
						Options = Options - 1
					end
				end

				local function AddOption(p)
					local playerName    = p.Name
					local playerDisplay = p.DisplayName
					local userId        = p.UserId

					if DD.Buttons[playerName] then
						local btn = DD.Buttons[playerName]
						if btn:GetAttribute("Disconnected") then
							btn:SetAttribute("Disconnected", false)
							local isSelected = table.find(SelectedValues, playerName) ~= nil
							local stateIco = btn:FindFirstChild("DisconnectIcon")
							if stateIco then stateIco.Visible = false end
							TPlay(btn, TW.Mid, {BackgroundColor3 = isSelected and GetSelectedBg() or NexusLib.Theme.BgPanel})
						end
						return
					end

					local isSelected = table.find(SelectedValues, playerName) ~= nil

					local ob = New("TextButton",{
						Parent=optScroll, Size=UDim2.new(1,0,0,45),
						BackgroundColor3=isSelected and GetSelectedBg() or NexusLib.Theme.BgPanel,
						BorderSizePixel=0, Text="", AutoButtonColor=false,
					},{
						New("UICorner",{CornerRadius=UDim.new(0,6)}),
						New("UIStroke",{Color=NexusLib.Theme.Border,Thickness=1}),
					})
					ThemeBind(ob:FindFirstChildOfClass("UIStroke"),"Color","Border")

					local selBar = New("Frame",{
						Parent=ob, Position=UDim2.new(0,0,0.1,0), Size=UDim2.new(0,3,0.8,0),
						BackgroundColor3=NexusLib.Theme.Accent,
						BackgroundTransparency=isSelected and 0 or 1, BorderSizePixel=0,
					},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
					selBar.Name = "SelBar"
					ThemeBind(selBar,"BackgroundColor3","Accent")

					New("ImageLabel",{
						Parent=ob, Position=UDim2.new(0,5,0.5,-18), Size=UDim2.new(0,36,0,36),
						BackgroundTransparency=1,
						Image="https://www.roblox.com/headshot-thumbnail/image?userId="..userId.."&width=420&height=420&format=png",
					},{New("UICorner",{CornerRadius=UDim.new(1,0)}),New("UIStroke",{Color=NexusLib.Theme.Border,Thickness=1})})

					local disconnectIcon = New("ImageLabel",{
						Parent=ob, Position=UDim2.new(1,-22,0.5,-11), Size=UDim2.new(0,22,0,22),
						BackgroundTransparency=1, Image="rbxassetid://7072725342",
						ImageColor3=Color3.fromRGB(255,80,80), Visible=false, Name="DisconnectIcon",
					})

					local dname = New("TextLabel",{
						Parent=ob, Position=UDim2.new(0,48,0,5), Size=UDim2.new(1,-72,0,18),
						BackgroundTransparency=1, Text=playerDisplay,
						Font=Enum.Font.GothamBold, TextSize=14,
						TextColor3=isSelected and NexusLib.Theme.Accent or NexusLib.Theme.TextPrimary,
						TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd,
					})
					ThemeBind(dname,"TextColor3","TextPrimary")

					local uname = New("TextLabel",{
						Parent=ob, Position=UDim2.new(0,48,0,22), Size=UDim2.new(1,-72,0,18),
						BackgroundTransparency=1, Text="@"..playerName,
						Font=Enum.Font.GothamMedium, TextSize=12,
						TextColor3=NexusLib.Theme.TextSecondary,
						TextXAlignment=Enum.TextXAlignment.Left, TextTruncate=Enum.TextTruncate.AtEnd,
					})
					ThemeBind(uname,"TextColor3","TextSecondary")

					Connect(ob.MouseButton1Up,function()
						if ob:GetAttribute("Disconnected") then return end
						DD:Set(playerName)
						SaveConfig(cfg.ConfigName)
					end)
					Connect(ob.MouseEnter,function()
						if ob:GetAttribute("Disconnected") then return end
						if table.find(SelectedValues, playerName) then return end
						TPlay(ob,TW.Fast,{BackgroundColor3=NexusLib.Theme.BgHover})
					end)
					Connect(ob.MouseLeave,function()
						if ob:GetAttribute("Disconnected") then return end
						local sel = table.find(SelectedValues, playerName) ~= nil
						TPlay(ob,TW.Fast,{BackgroundColor3=sel and GetSelectedBg() or NexusLib.Theme.BgPanel})
					end)

					DD.Buttons[playerName] = ob
					Options = Options + 1
				end

				for _, p in pairs(Players:GetPlayers()) do AddOption(p) end
				Connect(Players.PlayerAdded,   function(p) AddOption(p) end)
				Connect(Players.PlayerRemoving, function(p) task.delay(0.1, function() RemoveOption(p.Name) end) end)

				local function CleanDisconnected()
					for name, btn in pairs(DD.Buttons) do
						if btn and btn:GetAttribute("Disconnected") then
							local n = table.find(SelectedValues, name)
							if n then table.remove(SelectedValues, n) end
							btn:Destroy()
							DD.Buttons[name] = nil
							Options = Options - 1
						end
					end
				end

				function DD:Refresh() end

				function DD:Set(val, once)
					local btn = DD.Buttons[val]
					if not btn then
						for _ = 0, 10 do
							task.wait(0.15)
							if DD.Buttons[val] then btn = DD.Buttons[val] break end
						end
					end
					if not btn then return end
					if btn:GetAttribute("Disconnected") then return end

					local n = table.find(SelectedValues, val)
					local text = ""

					local function ApplySelectedStyle(b, selected)
						local sbar = b:FindFirstChild("SelBar")
						local T__ = NexusLib.Theme
						if selected then
							TPlay(b, TW.Mid, {BackgroundColor3 = GetSelectedBg()})
							if sbar then TPlay(sbar, TW.Fast, {BackgroundTransparency = 0}) end
							for _, lbl in ipairs(b:GetChildren()) do
								if lbl:IsA("TextLabel") and lbl.Font == Enum.Font.GothamBold then
									TPlay(lbl, TW.Fast, {TextColor3 = T__.Accent})
								end
							end
						else
							TPlay(b, TW.Mid, {BackgroundColor3 = T__.BgPanel})
							if sbar then TPlay(sbar, TW.Fast, {BackgroundTransparency = 1}) end
							for _, lbl in ipairs(b:GetChildren()) do
								if lbl:IsA("TextLabel") and lbl.Font == Enum.Font.GothamBold then
									TPlay(lbl, TW.Fast, {TextColor3 = T__.TextPrimary})
								end
							end
						end
					end

					if DD.MultipleSelection then
						if not n then
							table.insert(SelectedValues, val)
							ApplySelectedStyle(btn, true)
						elseif not once then
							table.remove(SelectedValues, n)
							ApplySelectedStyle(btn, false)
						end
						for i, v in pairs(SelectedValues) do
							if i <= 3 then
								text = text .. (#SelectedValues > 3 and i == 3 and v.."..." or v)
								if i < math.min(#SelectedValues, 3) then text = text .. ", " end
							end
						end
						DD.Value = val
						selLbl.Text = #SelectedValues > 0 and text or "Selected"
						return dCfg.Callback(SelectedValues)
					else
						table.clear(SelectedValues)
						CleanDisconnected()
						for pName, b in pairs(DD.Buttons) do
							if not b:GetAttribute("Disconnected") then
								ApplySelectedStyle(b, false)
							end
						end
						if DD.Buttons[val] and not DD.Buttons[val]:GetAttribute("Disconnected") then
							table.insert(SelectedValues, val)
							ApplySelectedStyle(DD.Buttons[val], true)
							DD.Value = val
							selLbl.Text = val
						else
							DD.Value = nil
							selLbl.Text = "Selected"
						end
						return dCfg.Callback(DD.Value)
					end
				end

				local Hbtn = New("TextButton",{
					Parent=header,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})
				Connect(Hbtn.MouseButton1Up,function()
					DD.Toggled = not DD.Toggled
					sep.Visible = DD.Toggled
					TPlay(arrow,TW.Fast,{Rotation=DD.Toggled and 180 or 0})
					if Options > MaxElements then
						TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,38+(MaxElements*47)) or UDim2.new(1,0,0,38)})
					else
						TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,38+(Options*47)) or UDim2.new(1,0,0,38)})
					end
				end)

				if dCfg.Flag then NexusLib.Flags[dCfg.Flag] = DD end
				return DD
			end

			-- PLAYER DROPDOWN (seleção única)
			function E:AddPlayerDropdown(pdCfg)
