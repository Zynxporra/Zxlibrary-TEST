-- UTILITY
-- ═══════════════════════════════════════════════════════════════
local function New(class, props, children)
	local o = Instance.new(class)
	for k,v in pairs(props or {}) do o[k] = v end
	for _,c in pairs(children or {}) do c.Parent = o end
	return o
end

local function Lerp(a, b, t) return a + (b - a) * t end

local function ColorPack(c)
	return { R = math.round(c.R*255), G = math.round(c.G*255), B = math.round(c.B*255) }
end
local function ColorUnpack(t)
	if type(t) == "table" then
		return Color3.fromRGB(math.clamp(t.R,0,255), math.clamp(t.G,0,255), math.clamp(t.B,0,255))
	end
	return Color3.fromRGB(200,200,200)
end

local function Round(n, f) 
	local r = math.floor(n/f + math.sign(n)*0.5)*f
	if r < 0 then r = r + f end
	return r
end

local function PlaySound(id, vol)
	local s = New("Sound", {SoundId = id, Volume = vol or 0.5, Parent = SoundService})
	s:Play()
	game.Debris:AddItem(s, 4)
end

