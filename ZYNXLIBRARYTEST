						TPlay(DD.Buttons[val],TW.Fast,{BackgroundTransparency=1})
						local lbl = DD.Buttons[val]:FindFirstChildOfClass("TextLabel")
						if lbl then TPlay(lbl,TW.Fast,{TextTransparency=0.4}) end
