local _NPos,_NH="BottomRight",nil
local function BuildNH(pos)
	if _NH then _NH:Destroy() end
	local isR=pos=="TopRight" or pos=="BottomRight"; local isB=pos=="BottomLeft" or pos=="BottomRight"
	local P,W=16,310
	local px=isR and UDim2.new(1,-(W+P),isB and 1 or 0,isB and -P or P) or UDim2.new(0,P,isB and 1 or 0,isB and -P or P)
	_NH=N("Frame",{Parent=Root,Size=UDim2.new(0,W,1,-(P*2)),Position=px,AnchorPoint=Vector2.new(0,isB and 1 or 0),BackgroundTransparency=1},{
		N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,VerticalAlignment=isB and Enum.VerticalAlignment.Bottom or Enum.VerticalAlignment.Top,HorizontalAlignment=Enum.HorizontalAlignment.Center,Padding=UDim.new(0,6)}),
	})
	return _NH
end
BuildNH(_NPos)
function ZNX:SetNotifyPosition(pos) _NPos=pos; BuildNH(pos) end

function ZNX:Notify(cfg)
	cfg=cfg or{}; cfg.Title=cfg.Title or"Aviso"; cfg.Message=cfg.Message or""; cfg.Duration=cfg.Duration or 5; cfg.Icon=cfg.Icon or"rbxassetid://16913919445"
	Snd("rbxassetid://9118776541",.25)
	task.spawn(function()
		local T=ZNX.Theme; local NH=_NH or BuildNH(_NPos)
		local isR=_NPos=="TopRight" or _NPos=="BottomRight"
		local offX=isR and UDim2.new(1,20,0,0) or UDim2.new(-1,-20,0,0)
		local wrap=N("Frame",{Parent=NH,Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,ClipsDescendants=true})
		-- Card principal da notificação
		local card=N("Frame",{Parent=wrap,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundColor3=T.Surface,BorderSizePixel=0,Position=offX},{
			N("UICorner",{CornerRadius=UDim.new(0,10)}),
			N("UIStroke",{Color=T.Accent,Thickness=1,Transparency=0.5}),
			N("UIPadding",{PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14),PaddingTop=UDim.new(0,11),PaddingBottom=UDim.new(0,11)}),
		})
		-- Barra lateral ciano
		N("Frame",{Parent=card,Size=UDim2.new(0,3,1,-16),Position=UDim2.new(0,-14,0,8),BackgroundColor3=T.Accent,BorderSizePixel=0},{N("UICorner",{CornerRadius=UDim.new(1,0)})})
		-- Conteúdo em UIListLayout
		N("UIListLayout",{Parent=card,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3)})
		-- Linha do título
		local titleRow=N("Frame",{Parent=card,Size=UDim2.new(1,0,0,18),BackgroundTransparency=1})
		N("ImageLabel",{Parent=titleRow,Size=UDim2.new(0,16,0,16),Position=UDim2.new(0,0,0.5,-8),BackgroundTransparency=1,Image=cfg.Icon,ImageColor3=T.Accent})
		N("TextLabel",{Parent=titleRow,Position=UDim2.new(0,22,0,0),Size=UDim2.new(1,-22,1,0),BackgroundTransparency=1,Text=cfg.Title,Font=Enum.Font.GothamBlack,TextSize=13,TextColor3=T.TxtA,TextXAlignment=Enum.TextXAlignment.Left})
		-- Mensagem
		local msg=N("TextLabel",{Parent=card,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Text=cfg.Message,Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=T.TxtB,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true})
		-- Progress bar
		local pb=N("Frame",{Parent=card,Size=UDim2.new(1,0,0,2),BackgroundColor3=T.AccentLo,BorderSizePixel=0},{N("UICorner",{CornerRadius=UDim.new(1,0)})})
		Tw(card,TweenInfo.new(.3,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)})
		Tw(pb,TweenInfo.new(cfg.Duration,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,0,2)})
		task.wait(cfg.Duration-.4)
		Tw(card,TI.Mid,{BackgroundTransparency=1})
		for _,ch in ipairs(card:GetDescendants()) do
			if ch:IsA("TextLabel") then Tw(ch,TI.Mid,{TextTransparency=1}) end
			if ch:IsA("ImageLabel") then Tw(ch,TI.Mid,{ImageTransparency=1}) end
		end
		task.wait(.22)
		Tw(card,TweenInfo.new(.24,Enum.EasingStyle.Quint,Enum.EasingDirection.In),{Position=offX})
		task.wait(.28); wrap:Destroy()
	end)
end

