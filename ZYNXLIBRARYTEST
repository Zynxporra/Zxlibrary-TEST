-- PACKET DETECTOR (mantido do original)
-- ══════════════════════════════════════════════════════
local PacketDetector = {
    Active = false, Connection = nil,
    KB_THRESHOLD = 5, BYTE_THRESHOLD = 5*1024,
    COOLDOWN = 30, lastNotify = 0,
}
function PacketDetector:shortenString(str)
    if #str<=100 then return str end
    return str:sub(1,100).."... (+"..( #str-100).." chars)"
end
function PacketDetector:summarizeTable(tbl,depth)
    depth=depth or 0
    if depth>2 then return "table[...]" end
    local preview={}; local count=0
    for k,v in pairs(tbl) do
        count+=1
        if count<=4 then
            local key=type(k)=="string" and k or tostring(k)
            local val=type(v)=="table" and self:summarizeTable(v,depth+1) or tostring(v)
            table.insert(preview,key.."="..val)
        end
    end
    if count>4 then table.insert(preview,"...") end
    return "{"..table.concat(preview,", ").."}"
end
function PacketDetector:resolveSender(args)
    for _,v in ipairs(args) do
        if typeof(v)=="Instance" and v:IsA("Player") then return v end
        if typeof(v)=="Instance" and v:IsA("Model") then
            local plr=Players:GetPlayerFromCharacter(v)
            if plr then return plr end
        end
        if typeof(v)=="Instance" and v:IsA("BasePart") then
            local model=v:FindFirstAncestorOfClass("Model")
            if model then local plr=Players:GetPlayerFromCharacter(model); if plr then return plr end end
        end
    end
    return LP
end
function PacketDetector:compressArgs(args)
    local summary={}; local stringSizes={}
    for _,v in ipairs(args) do
        local key
        if typeof(v)=="string" then
            key="txt "..self:shortenString(v)
            stringSizes[key]=(stringSizes[key] or 0)+#v
        elseif typeof(v)=="Instance" then key="inst "..v.ClassName.."("..v.Name..")"
        elseif typeof(v)=="table" then key="tbl "..self:summarizeTable(v)
        elseif typeof(v)=="number" then key="num "..string.format("%.2f",v)
        else key="val "..typeof(v)..":"..tostring(v):sub(1,50) end
        table.insert(summary,key)
    end
    for k,size in pairs(stringSizes) do
        if size>500 then table.insert(summary,"big "..k.." ("..string.format("%.2f",size/1024).." KB)") end
    end
    return summary
end
function PacketDetector:showNotification(sender,mbSize,args,remoteName)
    local msgLines={
        "De: "..sender.DisplayName.." (@"..sender.Name..")",
        "Tamanho: "..string.format("%.3f MB",mbSize),
        "Remote: "..remoteName,
    }
    ZNX:Notify({Title="PACOTE SUSPEITO DETECTADO",Message=table.concat(msgLines,"\n"),Duration=8,Type="danger"})
    if mbSize>1 then
        task.spawn(function()
            local flash=N("Frame",{Parent=Root,Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(200,30,30),BackgroundTransparency=0.82,BorderSizePixel=0})
            Tw(flash,TweenInfo.new(0.2),{BackgroundTransparency=1}); task.wait(0.2); flash:Destroy()
        end)
    end
end
function PacketDetector:start()
    if self.Connection then return end
    local grabEvents=game:GetService("ReplicatedStorage"):FindFirstChild("GrabEvents")
    if not grabEvents then ZNX:Notify({Title="Detector",Message="GrabEvents não encontrado",Duration=3,Type="warn"}); return end
    local extendGrabLine=grabEvents:FindFirstChild("ExtendGrabLine")
    if not extendGrabLine then ZNX:Notify({Title="Detector",Message="ExtendGrabLine não encontrado",Duration=3,Type="warn"}); return end
    self.Connection=extendGrabLine.OnClientEvent:Connect(function(...)
        if not self.Active then return end
        local args={...}; local totalBytes=0
        for _,v in ipairs(args) do
            if typeof(v)=="string" then totalBytes+=# v
            elseif typeof(v)=="table" then totalBytes+=#HTTP:JSONEncode(v) end
        end
        if totalBytes<self.BYTE_THRESHOLD then return end
        if tick()-self.lastNotify<self.COOLDOWN then return end
        self.lastNotify=tick()
        local sender=self:resolveSender(args)
        local mbSize=totalBytes/(1024*1024)
        self:showNotification(sender,mbSize,args,extendGrabLine.Name)
    end)
    self.Active=true
    ZNX:Notify({Title="Packet Detector",Message="Monitorando pacotes",Duration=3,Type="ok"})
end
function PacketDetector:stop()
    if self.Connection then self.Connection:Disconnect(); self.Connection=nil end
    self.Active=false
    ZNX:Notify({Title="Packet Detector",Message="Desativado",Duration=2,Type="info"})
end

