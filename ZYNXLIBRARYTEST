				},{New("UICorner",{CornerRadius=UDim.new(1,0)}),New("UIStroke",{Color=NexusLib.Theme.Border,Thickness=1})})
				local dname = New("TextLabel",{
					Parent=card,Size=UDim2.new(1,-70,0,20),Position=UDim2.new(0,70,0,10),
					BackgroundTransparency=1,Text=displayName,Font=Enum.Font.GothamBold,TextSize=15,
