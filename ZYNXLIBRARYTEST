-- SAVE / LOAD
-- ═══════════════════════════════════════════════════════════════
local sDb,sPend=0,false
local function BuildData(name)
	local d={Version="5.3",ConfigName=name,SavedAt=os.time(),Flags={},Theme={},NPos=ZNX.NPos,BgMode=ZNX.BgMode,BgAnimEnabled=ZNX.BgAnimEnabled}
	for k,f in pairs(ZNX.Flags) do
		if f.Save and f.Type~="PlayersDropdown" and f.Type~="PlayerDropdown" then
			if     f.Type=="Colorpicker" then d.Flags[k]={Type="CP",Value=CPk(f.Value)}
			elseif f.Type=="Toggle"      then d.Flags[k]={Type="Toggle",Value=f.Value}
			elseif f.Type=="Slider"      then d.Flags[k]={Type="Slider",Value=f.Value}
			elseif f.Type=="Dropdown"    then d.Flags[k]={Type="Dropdown",Value=f.Value}
			elseif f.Type=="Bind"        then d.Flags[k]={Type="Bind",Value=f.Value}
			end
		end
	end
	for k,v in pairs(ZNX.Theme) do if typeof(v)=="Color3" then d.Theme[k]=CPk(v) end end
	return d
end
local function SaveCfg(name,silent)
	if not ZNX.SaveEn then return false end
	local now=tick()
	if now-sDb<1.5 then
		if not sPend then sPend=true; task.delay(1.5,function() sPend=false; SaveCfg(name,true) end) end
		return false
	end
	sDb=now
	local ok=SS2:Write(name,BuildData(name))
	if not silent then
		ZNX:Notify({Title=ok and "Config salva" or "Erro ao salvar",Message=ok and ZNX.SaveDir.."/"..name..".json" or "Verifique permissoes do executor",Duration=3,Type=ok and "ok" or "err"})
	end
	return ok
end
local function LoadCfg(name,silent)
	local data=SS2:Read(name)
	if not data then return false end
	if data.NPos then ZNX.NPos=data.NPos end
	if data.BgMode then ZNX.BgMode=data.BgMode end
	if data.BgAnimEnabled~=nil then ZNX.BgAnimEnabled=data.BgAnimEnabled end
	if data.Theme then
		for k,v in pairs(data.Theme) do if ZNX.Theme[k]~=nil then ZNX.Theme[k]=CUp(v) end end
		ApplyTheme()
	end
	task.defer(function()
		task.wait(0.2)
		for k,fd in pairs(data.Flags or {}) do
			local flag=ZNX.Flags[k]
			if flag and flag.Type~="PlayersDropdown" and flag.Type~="PlayerDropdown" then
				pcall(function()
					if fd.Type=="CP" then flag:Set(CUp(fd.Value))
					elseif fd.Value~=nil then flag:Set(fd.Value) end
				end)
			end
		end
		if not silent then ZNX:Notify({Title="Config carregada",Message=name,Duration=3,Type="ok"}) end
	end)
	return true
end

