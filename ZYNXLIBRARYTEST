-- ═══════════════════════════════════════════════════════════════
-- CONNECTION MANAGER
-- ═══════════════════════════════════════════════════════════════
local function IsAlive()
	return Root and Root.Parent ~= nil
end

local function Connect(signal, fn)
	if not IsAlive() then return end
	local c = signal:Connect(fn)
	table.insert(NexusLib.Connections, c)
	return c
end

task.spawn(function()
	while IsAlive() do task.wait(0.5) end
	for _, c in pairs(NexusLib.Connections) do pcall(function() c:Disconnect() end) end
end)

-- ═══════════════════════════════════════════════════════════════
-- THEME LIVE UPDATE
-- ═══════════════════════════════════════════════════════════════
local function ApplyTheme()
	for _, fn in pairs(NexusLib._ThemeWatchers) do
		pcall(fn)
	end
end

function NexusLib:SetThemeColor(key, color)
	if NexusLib.Theme[key] ~= nil then
		NexusLib.Theme[key] = color
		ApplyTheme()
	end
end

-- Watch a GUI object's property to a theme key
local function ThemeBind(obj, prop, key, transform)
	table.insert(NexusLib._ThemeWatchers, function()
		local val = NexusLib.Theme[key]
		obj[prop] = transform and transform(val) or val
	end)
	-- Apply immediately
	local val = NexusLib.Theme[key]
	obj[prop] = transform and transform(val) or val
	return obj
end

-- ═══════════════════════════════════════════════════════════════
-- DRAG SYSTEM
-- ═══════════════════════════════════════════════════════════════
local function MakeDraggable(handle, target)
	pcall(function()
		local dragging, dragStart, startPos = false
		Connect(handle.InputBegan, function(inp)
			if inp.UserInputType == Enum.UserInputType.MouseButton1
			or inp.UserInputType == Enum.UserInputType.Touch then
				dragging  = true
				dragStart = inp.Position
				startPos  = target.Position
				inp.Changed:Connect(function()
					if inp.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)
		Connect(UserInputService.InputChanged, function(inp)
			if dragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
			or inp.UserInputType == Enum.UserInputType.Touch) then
				local d = inp.Position - dragStart
				target.Position = UDim2.new(
					startPos.X.Scale, startPos.X.Offset + d.X,
					startPos.Y.Scale, startPos.Y.Offset + d.Y
				)
			end
		end)
	end)
end

-- ═══════════════════════════════════════════════════════════════
-- CONFIG SAVE/LOAD
-- ═══════════════════════════════════════════════════════════════
local saveDebounce = 0
local savePending  = false

local function SaveConfig(name)
	if not NexusLib.SaveEnabled or not writefile then return end
	local now = tick()
	if now - saveDebounce < 1.5 then
		if not savePending then
			savePending = true
			task.delay(1.5, function()
				savePending = false
				SaveConfig(name)
			end)
		end
		return
	end
	saveDebounce = now
	task.spawn(function()
		if not isfolder then return end
		if not isfolder(NexusLib.SaveFolder) then makefolder(NexusLib.SaveFolder) end
		local data = { Flags = {}, Theme = {} }
		for k, flag in pairs(NexusLib.Flags) do
			if flag.Save then
				if flag.Type == "Colorpicker" then
					data.Flags[k] = { Type = "Colorpicker", Value = ColorPack(flag.Value) }
				else
					data.Flags[k] = { Type = flag.Type or "?", Value = flag.Value }
				end
			end
		end
		-- save theme colors
		for k, v in pairs(NexusLib.Theme) do
			if typeof(v) == "Color3" then
				data.Theme[k] = ColorPack(v)
			end
		end
		pcall(writefile, NexusLib.SaveFolder.."/"..name..".json", HttpService:JSONEncode(data))
	end)
end

local function LoadConfig(name)
	if not readfile or not isfile then return end
	local path = NexusLib.SaveFolder.."/"..name..".json"
	if not isfile(path) then return end
	local ok, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok then return end
	-- Load theme
	if data.Theme then
		for k, v in pairs(data.Theme) do
			if NexusLib.Theme[k] ~= nil then
				NexusLib.Theme[k] = ColorUnpack(v)
			end
		end
		ApplyTheme()
	end
	-- Load flags (deferred so all flags are registered)
	task.defer(function()
		for k, fd in pairs(data.Flags or {}) do
			if NexusLib.Flags[k] then
				task.spawn(function()
					if fd.Type == "Colorpicker" then
						NexusLib.Flags[k]:Set(ColorUnpack(fd.Value))
					elseif fd.Value ~= nil then
						NexusLib.Flags[k]:Set(fd.Value)
					end
				end)
			end
		end
	end)
end

