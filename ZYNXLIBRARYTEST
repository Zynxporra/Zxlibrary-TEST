                }

                local h, s, v = Color3.toHSV(colorConfig.Default)

                -- Main frame
                local main = New("Frame", {
                    Parent = container,
                    Size = UDim2.new(1, 0, 0, 40),
                    BackgroundColor3 = theme.BgCard,
                    BorderSizePixel = 0,
