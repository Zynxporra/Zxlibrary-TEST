            -- BIND (KEYBIND)
            function Elements:AddBind(bindConfig)
                bindConfig = bindConfig or {}
                bindConfig.Name = bindConfig.Name or "Keybind"
                bindConfig.Default = bindConfig.Default or Enum.KeyCode.Unknown
                bindConfig.Hold = bindConfig.Hold or false
                bindConfig.Callback = bindConfig.Callback or function() end
                bindConfig.Flag = bindConfig.Flag or nil
                bindConfig.Save = bindConfig.Save or false

                local blacklisted = {
                    Enum.KeyCode.Unknown, Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
                    Enum.KeyCode.Slash, Enum.KeyCode.Tab, Enum.KeyCode.Backspace, Enum.KeyCode.Escape,
                    Enum.KeyCode.Up, Enum.KeyCode.Down, Enum.KeyCode.Left, Enum.KeyCode.Right,
                }

                local function IsBlacklisted(key)
                    for _, v in pairs(blacklisted) do
                        if v == key then return true end
                    end
                    return false
                end

                local bind = {
                    Value = bindConfig.Default.Name or tostring(bindConfig.Default),
                    Binding = false,
                    Holding = false,
                    Type = "Bind",
                    Save = bindConfig.Save,
                }

                local card = CreateCard(container)
                card.Size = UDim2.new(1, 0, 0, 40)

                New("UIPadding", {
                    Parent = card,
                    PaddingLeft = UDim.new(0, 14),
                    PaddingRight = UDim.new(0, 14),
                    PaddingTop = UDim.new(0, 0),
                    PaddingBottom = UDim.new(0, 0),
                })

                New("TextLabel", {
                    Parent = card,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, -90, 1, 0),
                    BackgroundTransparency = 1,
                    Text = bindConfig.Name,
                    Font = Enum.Font.GothamBold,
                    TextSize = 15,
                    TextColor3 = theme.TextPrimary,
                    TextXAlignment = Enum.TextXAlignment.Left,
                })
                BindTheme(card:FindFirstChildOfClass("TextLabel"), "TextColor3", "TextPrimary")

                local keyContainer = New("Frame", {
                    Parent = card,
                    Position = UDim2.new(1, -80, 0.5, -13),
                    Size = UDim2.new(0, 70, 0, 26),
                    BackgroundColor3 = theme.BgDeep,
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    New("UIStroke", { Color = theme.Border, Thickness = 1 }),
                })
                BindTheme(keyContainer, "BackgroundColor3", "BgDeep")
                BindTheme(keyContainer:FindFirstChildOfClass("UIStroke"), "Color", "Border")

                local keyLabel = New("TextLabel", {
                    Parent = keyContainer,
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = bind.Value,
                    Font = Enum.Font.GothamBold,
                    TextSize = 12,
                    TextColor3 = theme.Accent,
                    TextXAlignment = Enum.TextXAlignment.Center,
                })
                BindTheme(keyLabel, "TextColor3", "Accent")

                local button = New("TextButton", {
                    Parent = card,
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    AutoButtonColor = false,
                })

                Connect(button.InputEnded, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and not bind.Binding then
                        bind.Binding = true
                        keyLabel.Text = "..."
                        TweenPlay(keyContainer:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = theme.Accent })
                    end
                end)

                Connect(UserInputService.InputBegan, function(input, gameProcessed)
                    if gameProcessed then return end

                    if bind.Binding then
                        local key
                        pcall(function()
                            if not IsBlacklisted(input.KeyCode) then
                                key = input.KeyCode
                            end
                        end)
                        pcall(function()
                            if input.UserInputType == Enum.UserInputType.MouseButton1 or
                               input.UserInputType == Enum.UserInputType.MouseButton2 or
                               input.UserInputType == Enum.UserInputType.MouseButton3 then
                                key = input.UserInputType
                            end
                        end)

                        key = key or bind.Value
                        bind:Set(key)
                        TweenPlay(keyContainer:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = theme.Border })
                        SaveConfig(config.ConfigName)
                    elseif (input.KeyCode.Name == bind.Value or input.UserInputType.Name == bind.Value) then
                        if bindConfig.Hold then
                            bind.Holding = true
                            bindConfig.Callback(true)
                        else
                            bindConfig.Callback()
                        end
                    end
                end)

                Connect(UserInputService.InputEnded, function(input)
                    if (input.KeyCode.Name == bind.Value or input.UserInputType.Name == bind.Value) and
                       bindConfig.Hold and bind.Holding then
                        bind.Holding = false
                        bindConfig.Callback(false)
                    end
                end)

                function bind:Set(key)
                    bind.Binding = false
                    bind.Value = (type(key) == "string") and key or (key.Name or tostring(key))
                    keyLabel.Text = bind.Value
                end

                bind:Set(bindConfig.Default)

                if bindConfig.Flag then
                    NexusLib.Flags[bindConfig.Flag] = bind
                end

                return bind
            end

            -- COLORPICKER
            function Elements:AddColorpicker(colorConfig)
