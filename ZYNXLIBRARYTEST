			function E:AddSlider(sCfg)
				sCfg           = sCfg or {}
				sCfg.Name      = sCfg.Name      or "Slider"
				sCfg.Min       = sCfg.Min       or 0
				sCfg.Max       = sCfg.Max       or 100
				sCfg.Increment = sCfg.Increment or 1
				sCfg.Default   = sCfg.Default   or sCfg.Min
				sCfg.Suffix    = sCfg.Suffix    or ""
				sCfg.Callback  = sCfg.Callback  or function() end
				sCfg.Flag      = sCfg.Flag      or nil
				sCfg.Save      = sCfg.Save      or false

				local T_   = NexusLib.Theme
				local Sl   = {Value = sCfg.Default, Type = "Slider", Save = sCfg.Save}
				local isDragging = false

				local card = MakeCard(parent)
				card.Size  = UDim2.new(1, 0, 0, 56)

				local NameRow = New("Frame",{
					Parent=card,Position=UDim2.new(0,12,0,8),
					Size=UDim2.new(1,-24,0,18),
					BackgroundTransparency=1,
				})
				New("TextLabel",{
					Parent=NameRow,Size=UDim2.new(0.7,0,1,0),
					BackgroundTransparency=1,Text=sCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(NameRow:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local ValLbl = New("TextLabel",{
					Parent=NameRow,Position=UDim2.new(0.7,0,0,0),Size=UDim2.new(0.3,0,1,0),
					BackgroundTransparency=1,
					Text=tostring(sCfg.Default).." "..sCfg.Suffix,
					Font=Enum.Font.GothamBold,TextSize=13,
					TextColor3=T_.Accent,TextXAlignment=Enum.TextXAlignment.Right,
				})
				ThemeBind(ValLbl,"TextColor3","Accent")

				local TrackBg = New("Frame",{
					Parent=card,Position=UDim2.new(0,12,0,34),
					Size=UDim2.new(1,-24,0,8),
					BackgroundColor3=T_.Border,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
				ThemeBind(TrackBg,"BackgroundColor3","Border")

				local TrackFill = New("Frame",{
					Parent=TrackBg,Size=UDim2.new(0,0,1,0),
					BackgroundColor3=T_.Accent,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
				ThemeBind(TrackFill,"BackgroundColor3","Accent")

				local ThumbDot = New("Frame",{
					Parent=TrackBg,Position=UDim2.new(0,-6,0.5,-6),
					Size=UDim2.new(0,12,0,12),
					BackgroundColor3=T_.AccentGlow,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
				ThemeBind(ThumbDot,"BackgroundColor3","AccentGlow")

				-- Botão transparente sobre o card inteiro para detectar hover
				local HoverBtn = New("TextButton",{
					Parent=card,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})

				function Sl:Set(v)
					Sl.Value = math.clamp(Round(v, sCfg.Increment), sCfg.Min, sCfg.Max)
					local pct = (Sl.Value - sCfg.Min) / math.max(sCfg.Max - sCfg.Min, 0.001)
					TPlay(TrackFill, TW.Fast, {Size = UDim2.new(pct, 0, 1, 0)})
					ThumbDot.Position = UDim2.new(pct, -6, 0.5, -6)
					ValLbl.Text = tostring(Sl.Value).." "..sCfg.Suffix
					sCfg.Callback(Sl.Value)
				end

				-- FIX: Drag no TrackBg (a barra em si)
				Connect(TrackBg.InputBegan, function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1
					or inp.UserInputType == Enum.UserInputType.Touch then
						isDragging = true
						-- Calcular posição imediata ao clicar
						local pct = math.clamp((inp.Position.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X, 0, 1)
						Sl:Set(sCfg.Min + (sCfg.Max - sCfg.Min) * pct)
					end
				end)

				-- FIX: InputEnded global para parar o drag
				Connect(UserInputService.InputEnded, function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1
					or inp.UserInputType == Enum.UserInputType.Touch then
						if isDragging then
							isDragging = false
							SaveConfig(cfg.ConfigName)
						end
					end
				end)

				-- FIX: InputChanged global para arrastar
				Connect(UserInputService.InputChanged, function(inp)
					if isDragging and (inp.UserInputType == Enum.UserInputType.MouseMovement
					or inp.UserInputType == Enum.UserInputType.Touch) then
						local pct = math.clamp(
							(inp.Position.X - TrackBg.AbsolutePosition.X) / math.max(TrackBg.AbsoluteSize.X, 1),
							0, 1
						)
						Sl:Set(sCfg.Min + (sCfg.Max - sCfg.Min) * pct)
					end
				end)

				Connect(HoverBtn.MouseEnter, function() TPlay(card,TW.Fast,{BackgroundColor3=NexusLib.Theme.BgHover}) end)
				Connect(HoverBtn.MouseLeave, function() TPlay(card,TW.Fast,{BackgroundColor3=NexusLib.Theme.BgCard}) end)

				Sl:Set(Sl.Value)
				if sCfg.Flag then NexusLib.Flags[sCfg.Flag] = Sl end
				return Sl
			end

