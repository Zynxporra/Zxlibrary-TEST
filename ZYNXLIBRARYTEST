		Position=UDim2.new(0.5,-wCfg.Size.X/2,0.5,-wCfg.Size.Y/2),
		BackgroundColor3=T.Bg,
		BorderSizePixel=0, Active=true, ClipsDescendants=true,
	},{
		N("UICorner",{CornerRadius=UDim.new(0,6)}),
		N("UIStroke",{Color=T.Line,Thickness=1}),
	})
	B(Win,"BackgroundColor3","Bg")
	B(Win:FindFirstChildOfClass("UIStroke"),"Color","Line")

	-- Imagem de fundo (ZIndex=1, atrás de tudo)
	local BgImg=N("ImageLabel",{Parent=Win,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Image=wCfg.BgImage~="" and "rbxassetid://"..wCfg.BgImage or "",ImageTransparency=wCfg.BgImageAlpha,ScaleType=Enum.ScaleType.Crop,ZIndex=1})
	local BgDim=N("Frame",{Parent=Win,Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=wCfg.BgImage~="" and 0.35 or 1,BorderSizePixel=0,ZIndex=1})

	-- ── BARRA DE TÍTULO (linha fina no topo) ─────────────────
	-- Design: linha horizontal com título à esquerda, stats + botões à direita
	local TitleBar=N("Frame",{Parent=Win,Size=UDim2.new(1,0,0,T.TopH),BackgroundColor3=T.Panel,BorderSizePixel=0,ZIndex=10})
	B(TitleBar,"BackgroundColor3","Panel")
	-- Linha accent laranja no fundo do título bar
	N("Frame",{Parent=TitleBar,Position=UDim2.new(0,0,1,-1),Size=UDim2.new(1,0,0,1),BackgroundColor3=T.Acc,BorderSizePixel=0})

	-- Logo: prefixo [ ] + título
	local logoX=10
	N("TextLabel",{Parent=TitleBar,Position=UDim2.new(0,logoX,0,0),Size=UDim2.new(0,12,1,0),BackgroundTransparency=1,Text="[",Font=Enum.Font.Code,TextSize=13,TextColor3=T.AccDim,TextXAlignment=Enum.TextXAlignment.Left})
	local TitleL=N("TextLabel",{Parent=TitleBar,Position=UDim2.new(0,logoX+10,0,0),Size=UDim2.new(0,180,1,0),BackgroundTransparency=1,Text=wCfg.Title,Font=Enum.Font.Code,TextSize=13,TextColor3=T.Acc,TextXAlignment=Enum.TextXAlignment.Left})
	B(TitleL,"TextColor3","Acc")
	N("TextLabel",{Parent=TitleBar,Position=UDim2.new(0,logoX+10+#wCfg.Title*8,0,0),Size=UDim2.new(0,12,1,0),BackgroundTransparency=1,Text="]",Font=Enum.Font.Code,TextSize=13,TextColor3=T.AccDim,TextXAlignment=Enum.TextXAlignment.Left})

	-- Stats compactos
	local StL=N("TextLabel",{Parent=TitleBar,Position=UDim2.new(1,-290,0,0),Size=UDim2.new(0,180,1,0),BackgroundTransparency=1,Text="-- fps  --ms  --:--",Font=Enum.Font.Code,TextSize=11,TextColor3=T.TxtC,TextXAlignment=Enum.TextXAlignment.Right})
