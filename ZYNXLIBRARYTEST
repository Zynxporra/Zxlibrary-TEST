-- CONNECTION MANAGER
-- ═══════════════════════════════════════════════════════════════════════════
local function IsValid()
    return NexusGUI and NexusGUI.Parent ~= nil
end

local function Connect(signal, callback)
    if not IsValid() then return end
    local connection = signal:Connect(callback)
    table.insert(NexusLib.Connections, connection)
    return connection
end

-- Auto cleanup
task.spawn(function()
    while IsValid() do
        task.wait(1)
    end
    for _, conn in pairs(NexusLib.Connections) do
        pcall(function() conn:Disconnect() end)
    end
end)

-- ═══════════════════════════════════════════════════════════════════════════
-- THEME SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════
local function ApplyTheme()
    for _, callback in pairs(NexusLib.ThemeWatchers) do
        pcall(callback)
    end
end

function NexusLib:SetTheme(key, color)
    if NexusLib.Theme[key] then
        NexusLib.Theme[key] = color
        ApplyTheme()
    end
end

local function BindTheme(obj, prop, key, transform)
    table.insert(NexusLib.ThemeWatchers, function()
        local val = NexusLib.Theme[key]
        obj[prop] = transform and transform(val) or val
    end)
    local val = NexusLib.Theme[key]
    obj[prop] = transform and transform(val) or val
    return obj
end

-- ═══════════════════════════════════════════════════════════════════════════
-- DRAG SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════
local function MakeDraggable(handle, target)
    local dragging = false
    local dragStart, startPos

    Connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = target.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    Connect(UserInputService.InputChanged, function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
                        input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

-- ═══════════════════════════════════════════════════════════════════════════
-- CONFIG SYSTEM (Estilo OrionLib)
-- ═══════════════════════════════════════════════════════════════════════════
local saveDebounce = 0
local savePending = false

local function SaveConfig(name)
    if not NexusLib.SaveEnabled or not writefile then return end

    local now = tick()
    if now - saveDebounce < 1.5 then
        if not savePending then
            savePending = true
            task.delay(1.5, function()
                savePending = false
                SaveConfig(name)
            end)
        end
        return
    end
    saveDebounce = now

    task.spawn(function()
        if not isfolder then return end
        if not isfolder(NexusLib.SaveFolder) then
            makefolder(NexusLib.SaveFolder)
        end

        local data = {
            Flags = {},
            Theme = {},
            Settings = {
                ToggleKey = NexusLib.ToggleKey,
            }
        }

        for flagName, flag in pairs(NexusLib.Flags) do
            if flag.Save then
                if flag.Type == "Colorpicker" then
                    data.Flags[flagName] = {
                        Type = "ColorPicker",
                        Value = ColorPack(flag.Value),
                    }
                else
                    data.Flags[flagName] = {
                        Type = flag.Type,
                        Value = flag.Value,
                    }
                end
            end
        end

        for key, val in pairs(NexusLib.Theme) do
            if typeof(val) == "Color3" then
                data.Theme[key] = ColorPack(val)
            end
        end

        pcall(writefile, NexusLib.SaveFolder .. "/" .. name .. ".json", HttpService:JSONEncode(data))
    end)
end

local function LoadConfig(name)
    if not readfile or not isfile then return end

    local path = NexusLib.SaveFolder .. "/" .. name .. ".json"
    if not isfile(path) then return end

    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not success then return end

    if data.Theme then
        for key, val in pairs(data.Theme) do
            if NexusLib.Theme[key] then
                NexusLib.Theme[key] = ColorUnpack(val)
            end
        end
        ApplyTheme()
    end

    if data.Settings and data.Settings.ToggleKey then
        NexusLib.ToggleKey = data.Settings.ToggleKey
    end

    task.defer(function()
        for flagName, flagData in pairs(data.Flags or {}) do
            if NexusLib.Flags[flagName] then
                task.spawn(function()
                    if flagData.Type == "ColorPicker" and flagData.Value then
                        NexusLib.Flags[flagName]:Set(ColorUnpack(flagData.Value))
                    elseif flagData.Value ~= nil then
                        NexusLib.Flags[flagName]:Set(flagData.Value)
                    end
                end)
            end
        end
    end)
end

