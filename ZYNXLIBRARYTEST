	wCfg.Title        = wCfg.Title        or "ZNXHUB"
	wCfg.SubTitle     = wCfg.SubTitle     or ""
	wCfg.ConfigName   = wCfg.ConfigName   or wCfg.Title
	wCfg.SaveConfig   = wCfg.SaveConfig   ~=false
