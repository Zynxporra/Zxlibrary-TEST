					local f=N("Frame",{Parent=inRow,Position=UDim2.new(x,0,0.5,-12),Size=UDim2.new(w,-4,0,24),BackgroundColor3=ZNX.Theme.Input,BorderSizePixel=0},{N("UIStroke",{Color=ZNX.Theme.Line,Thickness=.5})}); B(f,"BackgroundColor3","Input"); B(f:FindFirstChildOfClass("UIStroke"),"Color","Line")
					local tb3=N("TextBox",{Parent=f,Position=UDim2.new(0,6,0,0),Size=UDim2.new(1,-12,1,0),BackgroundTransparency=1,Text="",PlaceholderText=ph,PlaceholderColor3=ZNX.Theme.TxtC,Font=Enum.Font.Code,TextSize=11,TextColor3=ZNX.Theme.TxtA,ClearTextOnFocus=false}); B(tb3,"TextColor3","TxtA")
					C(tb3.Focused,function() Tw(f:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Acc}) end); C(tb3.FocusLost,function() Tw(f:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Line}) end)
					return tb3
