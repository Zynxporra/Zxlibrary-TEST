                })
                BindTheme(header:FindFirstChildOfClass("TextLabel"), "TextColor3", "TextPrimary")

                -- Preview
                local preview = New("Frame", {
                    Parent = header,
                    Position = UDim2.new(1, -50, 0.5, -12),
                    Size = UDim2.new(0, 24, 0, 24),
                    BackgroundColor3 = colorConfig.Default,
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    New("UIStroke", { Color = theme.Border, Thickness = 1.5 }),
                })

                local arrow = New("ImageLabel", {
                    Parent = header,
                    Position = UDim2.new(1, -24, 0.5, -10),
                    Size = UDim2.new(0, 20, 0, 20),
                    BackgroundTransparency = 1,
                    Image = "rbxassetid://7072706796",
                    ImageColor3 = theme.TextMuted,
                })

                -- Separator
                local separator = New("Frame", {
                    Parent = main,
                    Position = UDim2.new(0, 0, 0, 40),
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundColor3 = theme.Border,
                    BorderSizePixel = 0,
                    Visible = false,
                })
                BindTheme(separator, "BackgroundColor3", "Border")

                -- Picker container
                local pickerContainer = New("Frame", {
                    Parent = main,
                    Position = UDim2.new(0, 10, 0, 44),
                    Size = UDim2.new(1, -20, 0, 120),
                    BackgroundTransparency = 1,
                    Visible = false,
                })

                -- SV Box
                local svBox = New("ImageLabel", {
                    Parent = pickerContainer,
                    Position = UDim2.new(0, 0, 0, 0),
                    Size = UDim2.new(1, -30, 1, 0),
                    Image = "rbxassetid://4155801252",
                    BackgroundColor3 = Color3.fromHSV(h, 1, 1),
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(0, 6) }),
                })

                local svPin = New("Frame", {
                    Parent = svBox,
                    Position = UDim2.new(s, 0, 1 - v, 0),
                    Size = UDim2.new(0, 14, 0, 14),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    AnchorPoint = Vector2.new(0.5, 0.5),
                }, {
                    New("UICorner", { CornerRadius = UDim.new(1, 0) }),
                    New("UIStroke", { Color = Color3.fromRGB(40, 40, 40), Thickness = 2 }),
                })

                -- Hue bar
                local hueBar = New("Frame", {
                    Parent = pickerContainer,
                    Position = UDim2.new(1, -22, 0, 0),
                    Size = UDim2.new(0, 16, 1, 0),
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(0, 6) }),
                    New("UIGradient", {
                        Rotation = 270,
                        Color = ColorSequence.new({
                            ColorSequenceKeypoint.new(0.00, Color3.fromRGB(255, 0, 4)),
                            ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                            ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                            ColorSequenceKeypoint.new(0.50, Color3.fromRGB(0, 255, 255)),
                            ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                            ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                            ColorSequenceKeypoint.new(1.00, Color3.fromRGB(255, 0, 4)),
                        }),
                    }),
                })

                local huePin = New("Frame", {
                    Parent = hueBar,
                    Position = UDim2.new(0.5, 0, 1 - h, 0),
                    Size = UDim2.new(1, 4, 0, 4),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    AnchorPoint = Vector2.new(0.5, 0.5),
                }, {
                    New("UICorner", { CornerRadius = UDim.new(0, 2) }),
                    New("UIStroke", { Color = Color3.fromRGB(40, 40, 40), Thickness = 1.5 }),
                })

                local function UpdateColor()
                    local color = Color3.fromHSV(h, s, v)
                    colorpicker.Value = color
                    preview.BackgroundColor3 = color
                    svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    colorConfig.Callback(color)
                    SaveConfig(config.ConfigName)
                end

                -- SV drag
                local svDragging = false
                Connect(svBox.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        svDragging = true

                        local pos = input.Position
                        s = math.clamp((pos.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                        v = 1 - math.clamp((pos.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                        svPin.Position = UDim2.new(s, 0, 1 - v, 0)
                        UpdateColor()

                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then
                                svDragging = false
                            end
                        end)
                    end
                end)

                Connect(UserInputService.InputChanged, function(input)
                    if svDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        s = math.clamp((input.Position.X - svBox.AbsolutePosition.X) / svBox.AbsoluteSize.X, 0, 1)
                        v = 1 - math.clamp((input.Position.Y - svBox.AbsolutePosition.Y) / svBox.AbsoluteSize.Y, 0, 1)
                        svPin.Position = UDim2.new(s, 0, 1 - v, 0)
                        UpdateColor()
                    end
                end)

                -- Hue drag
                local hueDragging = false
                Connect(hueBar.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        hueDragging = true

                        local pos = input.Position
                        h = 1 - math.clamp((pos.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                        huePin.Position = UDim2.new(0.5, 0, 1 - h, 0)
                        UpdateColor()

                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then
                                hueDragging = false
                            end
                        end)
                    end
                end)

                Connect(UserInputService.InputChanged, function(input)
                    if hueDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        h = 1 - math.clamp((input.Position.Y - hueBar.AbsolutePosition.Y) / hueBar.AbsoluteSize.Y, 0, 1)
                        huePin.Position = UDim2.new(0.5, 0, 1 - h, 0)
                        UpdateColor()
                    end
                end)

                local headerButton = New("TextButton", {
                    Parent = header,
                    Size = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text = "",
                    AutoButtonColor = false,
                })

                Connect(headerButton.MouseButton1Up, function()
                    colorpicker.Toggled = not colorpicker.Toggled
                    separator.Visible = colorpicker.Toggled
                    pickerContainer.Visible = colorpicker.Toggled
                    TweenPlay(arrow, TweenCache.Fast, { Rotation = colorpicker.Toggled and 180 or 0 })
                    TweenPlay(main, TweenCache.Medium, {
                        Size = colorpicker.Toggled and UDim2.new(1, 0, 0, 170) or UDim2.new(1, 0, 0, 40)
                    })
                end)

                function colorpicker:Set(color)
                    colorpicker.Value = color
                    h, s, v = Color3.toHSV(color)
                    preview.BackgroundColor3 = color
                    svBox.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    svPin.Position = UDim2.new(s, 0, 1 - v, 0)
                    huePin.Position = UDim2.new(0.5, 0, 1 - h, 0)
                    colorConfig.Callback(color)
                end

                if colorConfig.Flag then
                    NexusLib.Flags[colorConfig.Flag] = colorpicker
                end

                return colorpicker
            end

            -- SECTION
            function Elements:AddSection(sectionConfig)
