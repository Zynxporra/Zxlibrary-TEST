				local nameIn=MkIn(0,.38,"nome"); local idIn=MkIn(.39,.39,"id")
				local addBtn=N("TextButton",{Parent=inRow,Position=UDim2.new(.79,4,0.5,-12),Size=UDim2.new(.21,-8,0,24),BackgroundColor3=ZNX.Theme.Acc,BorderSizePixel=0,Text="ADD",Font=Enum.Font.Code,TextSize=11,TextColor3=Color3.fromRGB(0,0,0),AutoButtonColor=false}); B(addBtn,"BackgroundColor3","Acc")
