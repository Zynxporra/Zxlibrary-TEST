				N("TextLabel",{Parent=head,Position=UDim2.new(0,8,0,0),Size=UDim2.new(0,12,1,0),BackgroundTransparency=1,Text="[",Font=Enum.Font.Code,TextSize=11,TextColor3=ZNX.Theme.AccDim,TextXAlignment=Enum.TextXAlignment.Left})
