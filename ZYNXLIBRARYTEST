	-- ABA DE CONFIGURAÇÕES INTERNA
	-- ════════════════════════════════════════════════════════════
	local function CreateSettingsTab()
		local ST = TabFunction:MakeTab({ Name = "⚙ Settings", Icon = "" })

		local Appearance = ST:AddSection({ Name = "APARÊNCIA" })

		Appearance:AddColorpicker({
			Name="Cor de Fundo", Default=NexusLib.Theme.BgBase,
			Callback=function(c)
				NexusLib:SetThemeColor("BgBase",c)
				NexusLib:SetThemeColor("BgDeep",Color3.fromRGB(math.max(0,c.R*255-6),math.max(0,c.G*255-6),math.max(0,c.B*255-6)))
			end,
		})
		Appearance:AddColorpicker({
			Name="Cor dos Cards", Default=NexusLib.Theme.BgCard,
			Callback=function(c)
				NexusLib:SetThemeColor("BgCard",c)
				NexusLib:SetThemeColor("BgPanel",Color3.fromRGB(math.max(0,c.R*255-4),math.max(0,c.G*255-4),math.max(0,c.B*255-4)))
				NexusLib:SetThemeColor("BgHover",Color3.fromRGB(math.min(255,c.R*255+8),math.min(255,c.G*255+8),math.min(255,c.B*255+8)))
			end,
		})
		Appearance:AddColorpicker({
			Name="Cor da Sidebar", Default=NexusLib.Theme.SidebarBg,
			Callback=function(c) NexusLib:SetThemeColor("SidebarBg",c) end,
		})
		Appearance:AddColorpicker({
			Name="Cor da Topbar", Default=NexusLib.Theme.TopbarBg,
			Callback=function(c) NexusLib:SetThemeColor("TopbarBg",c) end,
		})

		Appearance:AddSlider({
			Name="Opacidade da Imagem de Fundo", Min=0, Max=100,
			Default=math.floor((1-cfg.BackgroundImageTransparency)*100),
			Increment=5, Suffix="%",
			Callback=function(v)
				local t = 1-(v/100)
				BgImage.ImageTransparency = t
				BgDim.BackgroundTransparency = 0.3+(t*0.4)
			end,
		})

		local AccentSec = ST:AddSection({ Name = "DESTAQUE" })

		AccentSec:AddColorpicker({
			Name="Cor de Destaque", Default=NexusLib.Theme.Accent,
			Callback=function(c)
				NexusLib:SetThemeColor("Accent",c)
				NexusLib:SetThemeColor("AccentGlow",Color3.fromRGB(math.min(255,c.R*255+35),math.min(255,c.G*255+35),math.min(255,c.B*255+35)))
				NexusLib:SetThemeColor("AccentDim",Color3.fromRGB(math.floor(c.R*255*0.65),math.floor(c.G*255*0.65),math.floor(c.B*255*0.65)))
				NexusLib:SetThemeColor("TabActive",c)
				NexusLib:SetThemeColor("ScrollBar",c)
				NexusLib:SetThemeColor("BorderLit",c)
			end,
		})

		local BorderSec = ST:AddSection({ Name = "BORDAS" })
		BorderSec:AddColorpicker({
			Name="Cor das Bordas", Default=NexusLib.Theme.Border,
			Callback=function(c) NexusLib:SetThemeColor("Border",c) end,
		})

		local TextSec = ST:AddSection({ Name = "TEXTO" })
		TextSec:AddColorpicker({Name="Texto Primário",Default=NexusLib.Theme.TextPrimary,Callback=function(c) NexusLib:SetThemeColor("TextPrimary",c) end})
		TextSec:AddColorpicker({Name="Texto Secundário",Default=NexusLib.Theme.TextSecondary,Callback=function(c) NexusLib:SetThemeColor("TextSecondary",c) end})
		TextSec:AddColorpicker({Name="Texto Silenciado",Default=NexusLib.Theme.TextMuted,Callback=function(c) NexusLib:SetThemeColor("TextMuted",c) end})

		local PresetSec = ST:AddSection({ Name = "PRESETS" })
		local Presets = {
			["Neon Cyan"]    = {BgBase=Color3.fromRGB(14,14,20),BgCard=Color3.fromRGB(22,22,32),Accent=Color3.fromRGB(0,220,180),Border=Color3.fromRGB(40,42,60),SidebarBg=Color3.fromRGB(14,14,20)},
			["Blood Red"]    = {BgBase=Color3.fromRGB(14,8,8),BgCard=Color3.fromRGB(28,12,12),Accent=Color3.fromRGB(220,50,50),Border=Color3.fromRGB(60,20,20),SidebarBg=Color3.fromRGB(14,8,8)},
			["Electric Blue"]= {BgBase=Color3.fromRGB(8,10,20),BgCard=Color3.fromRGB(14,18,36),Accent=Color3.fromRGB(80,140,255),Border=Color3.fromRGB(30,40,80),SidebarBg=Color3.fromRGB(8,10,20)},
			["Golden Hour"]  = {BgBase=Color3.fromRGB(18,14,8),BgCard=Color3.fromRGB(30,22,10),Accent=Color3.fromRGB(255,195,50),Border=Color3.fromRGB(60,45,18),SidebarBg=Color3.fromRGB(18,14,8)},
			["Void Purple"]  = {BgBase=Color3.fromRGB(10,8,18),BgCard=Color3.fromRGB(18,14,32),Accent=Color3.fromRGB(160,80,255),Border=Color3.fromRGB(40,30,70),SidebarBg=Color3.fromRGB(10,8,18)},
			["Arctic White"] = {BgBase=Color3.fromRGB(235,237,245),BgCard=Color3.fromRGB(220,222,234),Accent=Color3.fromRGB(60,120,255),Border=Color3.fromRGB(190,195,215),SidebarBg=Color3.fromRGB(220,222,234),TextPrimary=Color3.fromRGB(30,32,50),TextSecondary=Color3.fromRGB(80,85,115),TextMuted=Color3.fromRGB(140,145,170)},
		}
		for pName, pData in pairs(Presets) do
			PresetSec:AddButton({Name=pName,Callback=function()
				for k, v in pairs(pData) do NexusLib:SetThemeColor(k,v) end
				local a = pData.Accent or NexusLib.Theme.Accent
				NexusLib:SetThemeColor("AccentGlow",Color3.fromRGB(math.min(255,a.R*255+35),math.min(255,a.G*255+35),math.min(255,a.B*255+35)))
				NexusLib:SetThemeColor("AccentDim",Color3.fromRGB(math.floor(a.R*255*.65),math.floor(a.G*255*.65),math.floor(a.B*255*.65)))
				NexusLib:SetThemeColor("TabActive",a); NexusLib:SetThemeColor("ScrollBar",a)
				local bg = pData.BgCard or NexusLib.Theme.BgCard
				NexusLib:SetThemeColor("BgHover",Color3.fromRGB(math.min(255,bg.R*255+8),math.min(255,bg.G*255+8),math.min(255,bg.B*255+8)))
				NexusLib:SetThemeColor("BgPanel",Color3.fromRGB(math.max(0,bg.R*255-4),math.max(0,bg.G*255-4),math.max(0,bg.B*255-4)))
				NexusLib:SetThemeColor("BgDeep",Color3.fromRGB(math.max(0,bg.R*255-12),math.max(0,bg.G*255-12),math.max(0,bg.B*255-12)))
				NexusLib:SetThemeColor("TopbarBg",pData.SidebarBg or NexusLib.Theme.SidebarBg)
				NexusLib:Notify({Title="Preset Carregado",Message=pName,Duration=3})
			end})
		end

		local CfgSec = ST:AddSection({ Name = "CONFIG" })
		CfgSec:AddButton({Name="Salvar Config",Callback=function()
			saveDebounce=0; SaveConfig(cfg.ConfigName)
			NexusLib:Notify({Title="Config Salva",Message=NexusLib.SaveFolder.."/"..cfg.ConfigName..".json",Duration=4})
		end})
		CfgSec:AddButton({Name="Resetar Tema",Callback=function()
			for k,v in pairs(DefaultTheme) do NexusLib.Theme[k]=v end
			ApplyTheme()
			NexusLib:Notify({Title="Tema Resetado",Message="Tema padrão restaurado.",Duration=3})
		end})
		CfgSec:AddBind({
			Name="Tecla Toggle", Default=Enum.KeyCode[cfg.ToggleKey] or Enum.KeyCode.RightShift,
			Callback=function(key)
				cfg.ToggleKey = key
				NexusLib:Notify({Title="Tecla Alterada",Message="Nova tecla: "..key,Duration=3})
			end,
			Flag="ToggleKey", Save=true,
		})
		CfgSec:AddTextbox({
			Name="ID da Imagem de Fundo", Default=cfg.BackgroundImage,
			Placeholder="ex: 123456789",
			Callback=function(id)
				cfg.BackgroundImage = id
				BgImage.Image = id ~= "" and "rbxassetid://"..id or ""
				BgDim.BackgroundTransparency = id ~= "" and 0.55 or 1
				NexusLib:Notify({Title="Fundo Atualizado",Message=id ~= "" and "Imagem definida" or "Imagem removida",Duration=3})
			end,
		})
	end

	CreateSettingsTab()

	if cfg.SaveConfig then
		task.defer(function() LoadConfig(cfg.ConfigName) end)
	end

	return TabFunction
end

