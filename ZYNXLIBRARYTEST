local SS2 = {}
function SS2:EnsureDir()
	if isfolder and not isfolder(ZNX.SaveDir) then pcall(makefolder,ZNX.SaveDir) end
end
function SS2:Write(name,data)
	if not writefile then return false end
	self:EnsureDir()
	local ok=pcall(writefile,ZNX.SaveDir.."/"..name..".json",HTTP:JSONEncode(data))
	return ok
end
function SS2:Read(name)
	if not readfile or not isfile then return nil end
	local p=ZNX.SaveDir.."/"..name..".json"
	if not isfile(p) then return nil end
	local ok,d=pcall(function() return HTTP:JSONDecode(readfile(p)) end)
	return ok and d or nil
end
function SS2:Delete(name)
	if not delfile then return false end
	return pcall(delfile,ZNX.SaveDir.."/"..name..".json")
end
function SS2:List()
	if not listfiles or not isfolder then return {} end
	local r={}
	if not isfolder(ZNX.SaveDir) then return r end
	for _,f in ipairs(listfiles(ZNX.SaveDir)) do
		local n=f:match("([^/\\]+)%.json$"); if n then table.insert(r,n) end
	end
	return r
end

