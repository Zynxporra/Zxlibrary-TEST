-- ORBES DE FUNDO (bolinhas roxas flutuantes)
-- ═══════════════════════════════════════════════════════════════
local OrbContainer = nil
local OrbList = {}

local function ClearOrbs()
	for _,o in pairs(OrbList) do pcall(function() o.frame:Destroy() end) end
	OrbList = {}
end

local function SpawnOrbs(container, count)
	ClearOrbs()
	if not container then return end
	count = count or 8
	for i=1,count do
		local sz = math.random(60,200)
		local ox = math.random(-20,120) / 100
		local oy = math.random(-10,110) / 100
		local phase = math.random(0,628) / 100
		local speed = 0.08 + math.random(0,8)/100
		local orb = N("Frame",{
			Parent=container,
			Size=UDim2.new(0,sz,0,sz),
			Position=UDim2.new(ox,-sz/2,oy,-sz/2),
			BackgroundColor3=ZNX.Theme.A,
			BackgroundTransparency=0.78,
			BorderSizePixel=0,
			ZIndex=2,
		},{
			N("UICorner",{CornerRadius=UDim.new(1,0)}),
			N("UIGradient",{
				Color=ColorSequence.new{
					ColorSequenceKeypoint.new(0,ZNX.Theme.ABr),
					ColorSequenceKeypoint.new(1,ZNX.Theme.A2),
				},
				Transparency=NumberSequence.new{
					NumberSequenceKeypoint.new(0,0.55),
					NumberSequenceKeypoint.new(1,1),
				},
				Rotation=math.random(0,360),
			}),
		})
		table.insert(OrbList,{frame=orb,ox=ox,oy=oy,phase=phase,speed=speed,sz=sz})
		RegAurora(orb,"grad")
	end
end

-- Anima posição das orbes
task.spawn(function()
	local t=0
	while Alive() do
		t=t+task.wait(0.033)
		if not ZNX.BgAnimEnabled then continue end
		for _,o in ipairs(OrbList) do
			if o.frame and o.frame.Parent then
				local dx=math.sin(t*o.speed+o.phase)*0.06
				local dy=math.cos(t*o.speed*0.7+o.phase)*0.04
				o.frame.Position=UDim2.new(o.ox+dx,-o.sz/2, o.oy+dy,-o.sz/2)
			end
		end
	end
end)

