                SC=SC or {}; SC.Name=SC.Name or "Slider"
                SC.Min=SC.Min or 0; SC.Max=SC.Max or 100
                SC.Increment=SC.Increment or 1
                SC.Default=Clamp(SC.Default~=nil and SC.Default or SC.Min,SC.Min,SC.Max)
                SC.Suffix=SC.Suffix or ""; SC.Callback=SC.Callback or function() end
                SC.Flag=SC.Flag or nil; SC.Save=SC.Save or false

                local Sl={Value=SC.Default,Type="Slider",Save=SC.Save}
                local isDrag=false; local dragInp=nil

                local card=MkCard(58)
                -- name label
                local NmLbl=MkTitle(card,SC.Name,12,9,-90)
                -- value label
                local VLbl=New("TextLabel",{Parent=card,Position=UDim2.new(1,-86,0,9),
                    Size=UDim2.new(0,74,0,18),ZIndex=21,BackgroundTransparency=1,
                    Text=tostring(SC.Default)..(SC.Suffix~="" and " "..SC.Suffix or ""),
                    Font=Enum.Font.GothamBold,TextSize=13,TextColor3=NL.Theme.Accent,
                    TextXAlignment=Enum.TextXAlignment.Right})
                Bind(VLbl,"TextColor3","Accent")
                -- track bg
                local TrkBg=New("Frame",{Parent=card,Position=UDim2.new(0,12,0,36),
                    Size=UDim2.new(1,-24,0,6),BackgroundColor3=NL.Theme.Border,
                    BorderSizePixel=0,ZIndex=22},{Crn(3)})
                Bind(TrkBg,"BackgroundColor3","Border")
                -- track fill
                local TrkFl=New("Frame",{Parent=TrkBg,Size=UDim2.new(0,0,1,0),
                    BackgroundColor3=NL.Theme.Accent,BorderSizePixel=0,ZIndex=23},{Crn(3)})
                Bind(TrkFl,"BackgroundColor3","Accent")
                -- thumb button (wider hit area)
                local ThBtn=New("TextButton",{Parent=TrkBg,
                    Size=UDim2.new(0,20,0,20),Position=UDim2.new(0,-10,0.5,-10),
                    BackgroundColor3=NL.Theme.AccentBright,BorderSizePixel=0,
                    Text="",AutoButtonColor=false,ZIndex=26},{Crn(10)})
                Bind(ThBtn,"BackgroundColor3","AccentBright")
                New("Frame",{Parent=ThBtn,AnchorPoint=Vector2.new(0.5,0.5),
                    Position=UDim2.new(0.5,0,0.5,0),Size=UDim2.new(0,6,0,6),
                    BackgroundColor3=C3(255,255,255),BorderSizePixel=0,ZIndex=27},{Crn(3)})

                -- hit area covering full track zone
                local HitA=New("TextButton",{Parent=card,Text="",AutoButtonColor=false,
                    Position=UDim2.new(0,6,0,28),Size=UDim2.new(1,-12,0,22),
                    BackgroundTransparency=1,ZIndex=28})

                -- tooltip
                local TTip=New("Frame",{Parent=TrkBg,AnchorPoint=Vector2.new(0.5,1),
                    Position=UDim2.new(0,-10,0,-8),Size=UDim2.new(0,54,0,22),
                    BackgroundColor3=NL.Theme.CardBg,BorderSizePixel=0,ZIndex=30,Visible=false},
                    {Crn(5),Str(NL.Theme.Border,1)})
                local TTLbl=New("TextLabel",{Parent=TTip,Size=UDim2.new(1,0,1,0),
                    BackgroundTransparency=1,Font=Enum.Font.GothamBold,TextSize=12,
                    TextColor3=NL.Theme.Accent,TextXAlignment=Enum.TextXAlignment.Center,ZIndex=31})
                Bind(TTLbl,"TextColor3","Accent")

                local function GetPct(inputX)
                    local abs=TrkBg.AbsolutePosition.X; local sz=TrkBg.AbsoluteSize.X
                    if sz==0 then return 0 end; return Clamp((inputX-abs)/sz,0,1)
                end

                function Sl:Set(v)
                    Sl.Value=Clamp(Round(v,SC.Increment),SC.Min,SC.Max)
                    local pct=(Sl.Value-SC.Min)/math.max(0.0001,SC.Max-SC.Min)
                    TrkFl.Size=UDim2.new(pct,0,1,0)
                    ThBtn.Position=UDim2.new(pct,-10,0.5,-10)
                    TTip.Position=UDim2.new(pct,-27,0,-8)
                    local txt=tostring(Sl.Value)..(SC.Suffix~="" and " "..SC.Suffix or "")
                    VLbl.Text=txt; TTLbl.Text=txt
                    SC.Callback(Sl.Value)
                end

                -- drag via HitArea
                Conn(HitA.InputBegan,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1
                    or inp.UserInputType==Enum.UserInputType.Touch then
                        isDrag=true; TTip.Visible=true
                        Tw(ThBtn,TI.Fast,{Size=UDim2.new(0,24,0,24),Position=UDim2.new(ThBtn.Position.X.Scale,-12,0.5,-12)})
                        Sl:Set(SC.Min+GetPct(inp.Position.X)*(SC.Max-SC.Min))
                        Conn(inp.Changed,function()
                            if inp.UserInputState==Enum.UserInputState.End then
                                isDrag=false; dragInp=nil; TTip.Visible=false
                                Tw(ThBtn,TI.Fast,{Size=UDim2.new(0,20,0,20)})
                                local p=(Sl.Value-SC.Min)/math.max(0.0001,SC.Max-SC.Min)
                                ThBtn.Position=UDim2.new(p,-10,0.5,-10)
                                Save(WC.ConfigName)
                            end
                        end)
                    end
                end)
                Conn(HitA.InputChanged,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseMovement
                    or inp.UserInputType==Enum.UserInputType.Touch then dragInp=inp end
                end)
                Conn(UIS.InputChanged,function(inp)
                    if not isDrag then return end
                    if inp.UserInputType~=Enum.UserInputType.MouseMovement
                    and inp.UserInputType~=Enum.UserInputType.Touch then return end
                    Sl:Set(SC.Min+GetPct(inp.Position.X)*(SC.Max-SC.Min))
                end)

                Sl:Set(Sl.Value)
                if SC.Flag then NL.Flags[SC.Flag]=Sl end
                return Sl
            end

            -- DROPDOWN
            function EF:AddDropdown(DC)
                DC=DC or {}; DC.Name=DC.Name or "Dropdown"
