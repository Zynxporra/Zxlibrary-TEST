			-- Slider: row, barra de progresso ocupa metade direita
			function E:AddSlider(sCfg)
				sCfg=sCfg or{}; sCfg.Name=sCfg.Name or "Slider"; sCfg.Min=sCfg.Min or 0; sCfg.Max=sCfg.Max or 100; sCfg.Increment=sCfg.Increment or 1; sCfg.Default=math.clamp(sCfg.Default or sCfg.Min,sCfg.Min,sCfg.Max); sCfg.Suffix=sCfg.Suffix or ""; sCfg.Callback=sCfg.Callback or function()end; sCfg.Flag=sCfg.Flag or nil; sCfg.Save=sCfg.Save or false
				local Sl={Value=sCfg.Default,Type="Slider",Save=sCfg.Save}
				local drag=false
				local row=MkRow(par,38)
				MkLabel(row,sCfg.Name)
				-- Valor numérico
				local valL=N("TextLabel",{Parent=row,Position=UDim2.new(0.5,0,0,0),Size=UDim2.new(0,52,1,0),BackgroundTransparency=1,Text=tostring(sCfg.Default).." "..sCfg.Suffix,Font=Enum.Font.Code,TextSize=11,TextColor3=ZNX.Theme.Acc,TextXAlignment=Enum.TextXAlignment.Right}); B(valL,"TextColor3","Acc")
				-- Track fina (3px) na metade direita
				local trkBg=N("Frame",{Parent=row,Position=UDim2.new(0.5,56,0.5,-1),Size=UDim2.new(0.5,-68,0,3),BackgroundColor3=ZNX.Theme.Line,BorderSizePixel=0,ZIndex=10}); B(trkBg,"BackgroundColor3","Line")
				local trkFill=N("Frame",{Parent=trkBg,Size=UDim2.new(0,0,1,0),BackgroundColor3=ZNX.Theme.Acc,BorderSizePixel=0,ZIndex=11}); B(trkFill,"BackgroundColor3","Acc")
				-- Thumb quadrado (4x4)
				local thumb=N("Frame",{Parent=trkBg,Position=UDim2.new(0,-2,0.5,-4),Size=UDim2.new(0,4,0,8),BackgroundColor3=ZNX.Theme.AccGlow,BorderSizePixel=0,ZIndex=12}); B(thumb,"BackgroundColor3","AccGlow")
				-- hBtn atrás (ZIndex=1)
				local hBtn=N("TextButton",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=1})
				C(hBtn.MouseEnter,function() Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.RowHov}) end)
				C(hBtn.MouseLeave,function() if not drag then Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.Row}) end end)
				function Sl:Set(v)
					Sl.Value=math.clamp(Rnd(v,sCfg.Increment),sCfg.Min,sCfg.Max)
					local pct=(Sl.Value-sCfg.Min)/math.max(sCfg.Max-sCfg.Min,.001)
					trkFill.Size=UDim2.new(pct,0,1,0); thumb.Position=UDim2.new(pct,-2,0.5,-4)
					valL.Text=tostring(Sl.Value).." "..sCfg.Suffix; sCfg.Callback(Sl.Value)
				end
				C(trkBg.InputBegan,function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						drag=true; Sl:Set(sCfg.Min+(sCfg.Max-sCfg.Min)*math.clamp((inp.Position.X-trkBg.AbsolutePosition.X)/math.max(trkBg.AbsoluteSize.X,1),0,1))
					end
				end)
				C(UIS.InputChanged,function(inp)
					if drag and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
						Sl:Set(sCfg.Min+(sCfg.Max-sCfg.Min)*math.clamp((inp.Position.X-trkBg.AbsolutePosition.X)/math.max(trkBg.AbsoluteSize.X,1),0,1))
					end
				end)
				C(UIS.InputEnded,function(inp)
					if drag and (inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch) then drag=false; Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.Row}); SaveCfg(wCfg.ConfigName) end
				end)
				Sl:Set(Sl.Value); MkSep(par); reg(row,sCfg.Name)
				if sCfg.Flag then ZNX.Flags[sCfg.Flag]=Sl end
				return Sl
			end

