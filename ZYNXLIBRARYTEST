			-- Toggle: row, lado direito tem [ ON ] / [ OFF ] em Code
			function E:AddToggle(tCfg2)
				tCfg2=tCfg2 or{}; tCfg2.Name=tCfg2.Name or "Toggle"; tCfg2.Default=tCfg2.Default or false; tCfg2.Callback=tCfg2.Callback or function()end; tCfg2.Flag=tCfg2.Flag or nil; tCfg2.Save=tCfg2.Save or false
				local Tog={Value=tCfg2.Default,Type="Toggle",Save=tCfg2.Save}
				local row=MkRow(par,38)
				MkLabel(row,tCfg2.Name)
				-- Display [ ON ]/[ OFF ]
				local disp=N("TextLabel",{Parent=row,Position=UDim2.new(0.5,0,0,0),Size=UDim2.new(0.5,-12,1,0),BackgroundTransparency=1,Text="[ OFF ]",Font=Enum.Font.Code,TextSize=12,TextColor3=ZNX.Theme.TxtC,TextXAlignment=Enum.TextXAlignment.Right})
				local btn=N("TextButton",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				function Tog:Set(v)
					Tog.Value=v
					if v then disp.Text="[ ON  ]"; Tw(disp,TI.Fast,{TextColor3=ZNX.Theme.Acc}); Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.RowSel})
					else disp.Text="[ OFF ]"; Tw(disp,TI.Fast,{TextColor3=ZNX.Theme.TxtC}); Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.Row}) end
					tCfg2.Callback(Tog.Value)
				end
				C(btn.MouseButton1Up,function() Snd("rbxassetid://6698737249",.15); Tog:Set(not Tog.Value); SaveCfg(wCfg.ConfigName) end)
				C(btn.MouseEnter,function() if not Tog.Value then Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.RowHov}) end end)
				C(btn.MouseLeave,function() if not Tog.Value then Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.Row}) end end)
				task.spawn(function() Tog:Set(Tog.Value) end)
