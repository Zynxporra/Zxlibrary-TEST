                    BackgroundTransparency = 1,
                    Text = tostring(sliderConfig.Default) .. " " .. sliderConfig.Suffix,
                    Font = Enum.Font.GothamBold,
                    TextSize = 14,
                    TextColor3 = theme.Accent,
                    TextXAlignment = Enum.TextXAlignment.Right,
                })
                BindTheme(valueLabel, "TextColor3", "Accent")

                -- Track
                local track = New("Frame", {
                    Parent = card,
                    Position = UDim2.new(0, 0, 0, 28),
                    Size = UDim2.new(1, 0, 0, 6),
                    BackgroundColor3 = theme.Border,
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(1, 0) }),
                })
                BindTheme(track, "BackgroundColor3", "Border")

                -- Fill
                local fill = New("Frame", {
                    Parent = track,
                    Size = UDim2.new(0, 0, 1, 0),
                    BackgroundColor3 = theme.Accent,
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(1, 0) }),
                })
                BindTheme(fill, "BackgroundColor3", "Accent")

                -- Thumb
                local thumb = New("Frame", {
                    Parent = track,
                    Position = UDim2.new(0, -8, 0.5, -8),
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundColor3 = theme.AccentGlow,
                    BorderSizePixel = 0,
                }, {
                    New("UICorner", { CornerRadius = UDim.new(1, 0) }),
                    New("UIStroke", { Color = Color3.fromRGB(255, 255, 255), Thickness = 2 }),
                })
                BindTheme(thumb, "BackgroundColor3", "AccentGlow")

                function slider:Set(val)
                    slider.Value = math.clamp(Round(val, sliderConfig.Increment), sliderConfig.Min, sliderConfig.Max)
                    local percent = (slider.Value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min)
                    TweenPlay(fill, TweenCache.Fast, { Size = UDim2.new(percent, 0, 1, 0) })
                    thumb.Position = UDim2.new(percent, -8, 0.5, -8)
                    valueLabel.Text = tostring(slider.Value) .. " " .. sliderConfig.Suffix
                    sliderConfig.Callback(slider.Value)
                end

                -- Drag logic
                Connect(track.InputBegan, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true

                        -- Update on click
                        local percent = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        slider:Set(sliderConfig.Min + (sliderConfig.Max - sliderConfig.Min) * percent)
                        SaveConfig(config.ConfigName)

                        if dragConnection then
                            dragConnection:Disconnect()
                        end

                        dragConnection = Connect(UserInputService.InputChanged, function(input)
                            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                                local percent = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                                slider:Set(sliderConfig.Min + (sliderConfig.Max - sliderConfig.Min) * percent)
                                SaveConfig(config.ConfigName)
                            end
                        end)

                        input.Changed:Connect(function()
                            if input.UserInputState == Enum.UserInputState.End then
                                dragging = false
                                if dragConnection then
                                    dragConnection:Disconnect()
                                    dragConnection = nil
                                end
                            end
                        end)
                    end
                end)

                Connect(track.InputEnded, function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                        if dragConnection then
                            dragConnection:Disconnect()
                            dragConnection = nil
                        end
                    end
                end)

                slider:Set(slider.Value)

                if sliderConfig.Flag then
                    NexusLib.Flags[sliderConfig.Flag] = slider
                end

                return slider
            end

