				ThemeBind(outer:FindFirstChildOfClass("UIStroke"),"Color","Border")

				local header = New("Frame",{Parent=outer,Size=UDim2.new(1,0,0,36),BackgroundTransparency=1})
				New("TextLabel",{
					Parent=header,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-80,1,0),
					BackgroundTransparency=1,Text=dCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local selLbl = New("TextLabel",{
					Parent=header,Position=UDim2.new(1,-100,0,0),Size=UDim2.new(0,70,1,0),
					BackgroundTransparency=1,Text=tostring(DD.Value),
					Font=Enum.Font.GothamMedium,TextSize=13,
					TextColor3=T_.Accent,TextXAlignment=Enum.TextXAlignment.Right,
					TextTruncate=Enum.TextTruncate.AtEnd,
				})
				ThemeBind(selLbl,"TextColor3","Accent")
				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-22,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=T_.TextMuted,
				})

				local sep = New("Frame",{
					Parent=outer,Position=UDim2.new(0,0,0,36),
					Size=UDim2.new(1,0,0,1),
					BackgroundColor3=T_.Border,BorderSizePixel=0,
					Visible=false,Name="Sep",
				})
				ThemeBind(sep,"BackgroundColor3","Border")

				local optScroll = MakeScrollFrame(outer)
				optScroll.Position = UDim2.new(0,0,0,37)
				optScroll.Size     = UDim2.new(1,0,1,-37)
				New("UIListLayout",{Parent=optScroll,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
				New("UIPadding",{Parent=optScroll,PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4)})
				Connect(optScroll.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function()
					optScroll.CanvasSize=UDim2.new(0,0,0,optScroll.UIListLayout.AbsoluteContentSize.Y+8)
				end)

				local function RefreshOpts()
					for _,b in pairs(DD.Buttons) do b:Destroy() end
					DD.Buttons = {}
					for _, opt in ipairs(DD.Options) do
						local isSelected = opt == DD.Value
						local ob = New("TextButton",{
							Parent=optScroll,Size=UDim2.new(1,0,0,28),
							BackgroundColor3=isSelected and T_.BgHover or T_.BgPanel,
							BorderSizePixel=0,
							Text="",AutoButtonColor=false,
						},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
						New("TextLabel",{
							Parent=ob,Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-14,1,0),
							BackgroundTransparency=1,Text=tostring(opt),
							Font=Enum.Font.GothamMedium,TextSize=13,
							TextColor3=isSelected and T_.Accent or T_.TextSecondary,
							TextXAlignment=Enum.TextXAlignment.Left,
						})
						Connect(ob.MouseButton1Up,function()
							DD:Set(opt)
							SaveConfig(cfg.ConfigName)
						end)
						Connect(ob.MouseEnter,function() TPlay(ob,TW.Fast,{BackgroundColor3=T_.BgHover}) end)
						Connect(ob.MouseLeave,function()
							TPlay(ob,TW.Fast,{BackgroundColor3=opt==DD.Value and T_.BgHover or T_.BgPanel})
						end)
						DD.Buttons[opt] = ob
					end
				end

				function DD:Set(val)
					if table.find(DD.Options, val) then
						DD.Value = val
					else
						DD.Value = DD.Options[1] or "..."
					end
					selLbl.Text = tostring(DD.Value)
					for opt, ob in pairs(DD.Buttons) do
						local lbl = ob:FindFirstChildOfClass("TextLabel")
						local isSelected = opt == DD.Value
						if lbl then
							TPlay(lbl, TW.Fast, {TextColor3 = isSelected and NexusLib.Theme.Accent or NexusLib.Theme.TextSecondary})
						end
						TPlay(ob, TW.Fast, {BackgroundColor3 = isSelected and NexusLib.Theme.BgHover or NexusLib.Theme.BgPanel})
					end
					dCfg.Callback(DD.Value)
				end

				function DD:Refresh(opts, clear)
					if clear then DD.Options = {} end
					for _,o in ipairs(opts) do table.insert(DD.Options,o) end
					RefreshOpts()
				end

				local Hbtn = New("TextButton",{
					Parent=header,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})
				Connect(Hbtn.MouseButton1Up,function()
					DD.Toggled = not DD.Toggled
					sep.Visible = DD.Toggled
					TPlay(arrow,TW.Fast,{Rotation=DD.Toggled and 180 or 0})
					local oh = math.min(#DD.Options*30+8, MaxH*30+8)
					TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,36+oh) or UDim2.new(1,0,0,36)})
				end)

				RefreshOpts()
				DD:Set(DD.Value)
				if dCfg.Flag then NexusLib.Flags[dCfg.Flag] = DD end
				return DD
			end

			-- MULTIPLE DROPDOWN
			function E:AddMultipleDropdown(dCfg)
				dCfg = dCfg or {}
				dCfg.Name = dCfg.Name or "Dropdown"
				dCfg.Options = dCfg.Options or {}
				dCfg.Default = dCfg.Default or ""
				dCfg.Callback = dCfg.Callback or function() end
				dCfg.Flag = dCfg.Flag or nil
				dCfg.Save = dCfg.Save or false

				local T_ = NexusLib.Theme
				local DD = {Value = dCfg.Default, Options = dCfg.Options, Buttons = {}, Toggled = false, Type = "Dropdown", Save = dCfg.Save}
				local MaxElements = 5
				local SelectedValues = {}

				if not table.find(DD.Options, DD.Value) then DD.Value = "..." end

				local outer = New("Frame",{
					Parent=parent,Size=UDim2.new(1,0,0,38),
					BackgroundColor3=T_.BgCard,BorderSizePixel=0,ClipsDescendants=true,
				},{New("UICorner",{CornerRadius=UDim.new(0,6)}),New("UIStroke",{Color=T_.Border,Thickness=1})})
				ThemeBind(outer,"BackgroundColor3","BgCard")
				ThemeBind(outer:FindFirstChildOfClass("UIStroke"),"Color","Border")

				local header = New("Frame",{Parent=outer,Size=UDim2.new(1,0,0,38),BackgroundTransparency=1})
				New("TextLabel",{
					Parent=header,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-80,1,0),
					BackgroundTransparency=1,Text=dCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=T_.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local selLbl = New("TextLabel",{
					Parent=header,Position=UDim2.new(1,-100,0,0),Size=UDim2.new(0,70,1,0),
					BackgroundTransparency=1,Text="Selected",
					Font=Enum.Font.Gotham,TextSize=13,
					TextColor3=T_.TextSecondary,TextXAlignment=Enum.TextXAlignment.Right,
				})
				ThemeBind(selLbl,"TextColor3","TextSecondary")
				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-22,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=T_.TextMuted,
				})

				local sep = New("Frame",{Parent=outer,Position=UDim2.new(0,0,0,38),Size=UDim2.new(1,0,0,1),BackgroundColor3=T_.Border,BorderSizePixel=0,Visible=false})
				ThemeBind(sep,"BackgroundColor3","Border")

				local optScroll = MakeScrollFrame(outer)
				optScroll.Position = UDim2.new(0,0,0,39)
				optScroll.Size = UDim2.new(1,0,1,-39)
				local optList = New("UIListLayout",{Parent=optScroll,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
				New("UIPadding",{Parent=optScroll,PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6),PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4)})
				Connect(optList:GetPropertyChangedSignal("AbsoluteContentSize"),function()
					optScroll.CanvasSize = UDim2.new(0,0,0,optList.AbsoluteContentSize.Y + 8)
				end)

				local function AddOptions(opts)
					for _, opt in pairs(opts) do
						local isSelected = table.find(SelectedValues, opt) ~= nil
						local ob = New("TextButton",{
							Parent=optScroll,Size=UDim2.new(1,0,0,28),
							BackgroundColor3=isSelected and T_.BgHover or T_.BgPanel,
							BorderSizePixel=0,
							Text="",AutoButtonColor=false,
						},{New("UICorner",{CornerRadius=UDim.new(0,5)})})

						New("TextLabel",{
							Parent=ob,Position=UDim2.new(0,8,0,0),Size=UDim2.new(1,-8,1,0),
							BackgroundTransparency=1,Text=tostring(opt),
							Font=Enum.Font.GothamMedium,TextSize=13,
							TextColor3=isSelected and T_.Accent or T_.TextSecondary,
							TextXAlignment=Enum.TextXAlignment.Left,
						})

						Connect(ob.MouseButton1Up,function()
							DD:Set(opt)
							SaveConfig(cfg.ConfigName)
						end)
						Connect(ob.MouseEnter,function() TPlay(ob,TW.Fast,{BackgroundColor3=T_.BgHover}) end)
						Connect(ob.MouseLeave,function()
							local sel = table.find(SelectedValues, opt) ~= nil
							TPlay(ob,TW.Fast,{BackgroundColor3=sel and T_.BgHover or T_.BgPanel})
						end)

						DD.Buttons[opt] = ob
					end
				end

				function DD:Refresh(opts, del)
					if del then
						for _,b in pairs(DD.Buttons) do b:Destroy() end
						table.clear(DD.Options)
						table.clear(DD.Buttons)
					end
					DD.Options = opts
					AddOptions(DD.Options)
				end

				function DD:Set(val)
					local n = table.find(SelectedValues, val)
					local text = ""
					local btn = DD.Buttons[val]
					local lbl = btn and btn:FindFirstChildOfClass("TextLabel")

					if not n then
						table.insert(SelectedValues, val)
						if btn then TPlay(btn, TW.Fast, {BackgroundColor3 = NexusLib.Theme.BgHover}) end
						if lbl then TPlay(lbl, TW.Fast, {TextColor3 = NexusLib.Theme.Accent}) end
					else
						table.remove(SelectedValues, n)
						if btn then TPlay(btn, TW.Fast, {BackgroundColor3 = NexusLib.Theme.BgPanel}) end
						if lbl then TPlay(lbl, TW.Fast, {TextColor3 = NexusLib.Theme.TextSecondary}) end
					end

					for i, v in pairs(SelectedValues) do
						if #SelectedValues == i then
							text = text .. v
						else
							text = text .. v .. ", "
						end
					end

					DD.Value = val
					selLbl.Text = #SelectedValues > 0 and text or "Selected"

					return dCfg.Callback(SelectedValues)
				end

				local Hbtn = New("TextButton",{
					Parent=header,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})
				Connect(Hbtn.MouseButton1Up,function()
					DD.Toggled = not DD.Toggled
					sep.Visible = DD.Toggled
					TPlay(arrow,TW.Fast,{Rotation=DD.Toggled and 180 or 0})
					if #DD.Options > MaxElements then
						TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,38 + (MaxElements * 28)) or UDim2.new(1,0,0,38)})
					else
						TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,optList.AbsoluteContentSize.Y + 38) or UDim2.new(1,0,0,38)})
					end
				end)

				DD:Refresh(DD.Options, false)
				if dCfg.Flag then NexusLib.Flags[dCfg.Flag] = DD end
				return DD
			end

