-- ═══════════════════════════════════════════════════════════════
-- AURORA ENGINE — anima gradientes, strokes e orbes de fundo
-- ═══════════════════════════════════════════════════════════════
local AuroraReg = {}
local function RegAurora(f,t) table.insert(AuroraReg,{f=f,t=t or "grad"}) end

local _aT = 0
task.spawn(function()
	while Alive() do
		local dt = task.wait(0.033)
		if not ZNX.BgAnimEnabled then continue end
		_aT = _aT + dt * 0.35

		local A  = ZNX.Theme.A  or Color3.fromRGB(160,80,255)
		local A2 = ZNX.Theme.A2 or Color3.fromRGB(220,80,255)
		local ABr= ZNX.Theme.ABr or Color3.fromRGB(200,140,255)

		local s1=(math.sin(_aT*1.0)+1)/2
		local s2=(math.sin(_aT*0.65+1.3)+1)/2
		local s3=(math.sin(_aT*0.45+2.5)+1)/2

		local cMid=LC(A,A2,s1)
		local cA  =LC(A,ABr,s2)
		local cB  =LC(A2,A,s3)

		for i=#AuroraReg,1,-1 do
			local e=AuroraReg[i]
			if not e.f or not e.f.Parent then
				table.remove(AuroraReg,i)
			else
				pcall(function()
					if e.t=="grad" then
						local g=e.f:FindFirstChildOfClass("UIGradient")
						if g then g.Color=ColorSequence.new{
							ColorSequenceKeypoint.new(0,cA),
							ColorSequenceKeypoint.new(0.5,cMid),
							ColorSequenceKeypoint.new(1,cB),
						} end
					elseif e.t=="stroke" then
						local s=e.f:FindFirstChildOfClass("UIStroke")
						if s then s.Color=LC(A,A2,s1) end
					elseif e.t=="bg" then
						e.f.BackgroundColor3=LC(A,A2,s1)
					elseif e.t=="text" then
						e.f.TextColor3=LC(A,A2,s1)
					elseif e.t=="imgcol" then
						e.f.ImageColor3=LC(A,A2,s1)
					end
				end)
			end
		end
	end
end)

