-- ── COLOR / MATH UTILS ───────────────────────────────────────
local function Clamp(v,a,b)  return math.clamp(v,a,b) end
local function Round(n,step) if step==0 then return n end return math.floor(n/step+0.5)*step end
local function C3(r,g,b)     return Color3.fromRGB(r,g,b) end
local function HSV(h,s,v)    return Color3.fromHSV(h,s,v) end
local function Lrp(a,b,t)    return a+(b-a)*t end

local function Lighten(c,a) local h,s,v=Color3.toHSV(c); return HSV(h,math.max(0,s-a*.3),math.min(1,v+a)) end
local function Darken(c,a)  local h,s,v=Color3.toHSV(c); return HSV(h,s,math.max(0,v-a)) end
local function Tint(c,t,s)  return Color3.new(Lrp(c.R,t.R,s),Lrp(c.G,t.G,s),Lrp(c.B,t.B,s)) end

local function ColorPack(c)   return {R=math.round(c.R*255),G=math.round(c.G*255),B=math.round(c.B*255)} end
local function ColorUnpack(t)
    if type(t)=="table" and t.R then return C3(Clamp(t.R,0,255),Clamp(t.G,0,255),Clamp(t.B,0,255)) end
    return C3(200,200,200)
end
local function C3Hex(c)   return ("%02X%02X%02X"):format(math.round(c.R*255),math.round(c.G*255),math.round(c.B*255)) end
local function HexC3(h)
    h=h:gsub("#","")
    if #h~=6 then return nil end
    local r,g,b=tonumber(h:sub(1,2),16),tonumber(h:sub(3,4),16),tonumber(h:sub(5,6),16)
    return (r and g and b) and C3(r,g,b) or nil
end

