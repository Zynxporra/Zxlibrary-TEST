-- ── THEME ENGINE ─────────────────────────────────────────────
local function ApplyTheme() for _,fn in pairs(ZNX.Watch) do pcall(fn) end end
function ZNX:SetColor(k,col) if ZNX.Theme[k]~=nil then ZNX.Theme[k]=col; ApplyTheme() end end
local function B(obj,prop,key)
	table.insert(ZNX.Watch,function() if obj and obj.Parent then obj[prop]=ZNX.Theme[key] end end)
	if ZNX.Theme[key]~=nil then obj[prop]=ZNX.Theme[key] end
end

-- ── DRAG ─────────────────────────────────────────────────────
local function MkDrag(handle,target)
	pcall(function()
		local drag,ds,sp=false
		C(handle.InputBegan,function(i)
			if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
				drag=true; ds=i.Position; sp=target.Position
				i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
			end
		end)
		C(UIS.InputChanged,function(i)
			if drag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
				local d=i.Position-ds; target.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
			end
		end)
	end)
end

-- ── SAVE/LOAD ────────────────────────────────────────────────
local sDb,sPend=0,false
local function SaveCfg(name)
	if not ZNX.SaveEn or not writefile then return end
	local now=tick(); if now-sDb<1.5 then if not sPend then sPend=true; task.delay(1.5,function() sPend=false; SaveCfg(name) end) end return end
	sDb=now; task.spawn(function()
		if not isfolder then return end; if not isfolder(ZNX.SaveDir) then makefolder(ZNX.SaveDir) end
		local d={Flags={},Theme={}}
		for k,f in pairs(ZNX.Flags) do if f.Save then d.Flags[k]=f.Type=="Colorpicker" and{Type="CP",Value=CPk(f.Value)} or{Type=f.Type,Value=f.Value} end end
		for k,v in pairs(ZNX.Theme) do if typeof(v)=="Color3" then d.Theme[k]=CPk(v) end end
		pcall(writefile,ZNX.SaveDir.."/"..name..".json",HTTP:JSONEncode(d))
	end)
end
local function LoadCfg(name)
	if not readfile or not isfile then return end
	local p=ZNX.SaveDir.."/"..name..".json"; if not isfile(p) then return end
	local ok,d=pcall(function() return HTTP:JSONDecode(readfile(p)) end); if not ok then return end
	if d.Theme then for k,v in pairs(d.Theme) do if ZNX.Theme[k]~=nil then ZNX.Theme[k]=CUp(v) end end; ApplyTheme() end
	task.defer(function()
		for k,fd in pairs(d.Flags or {}) do if ZNX.Flags[k] then task.spawn(function()
			if fd.Type=="CP" then ZNX.Flags[k]:Set(CUp(fd.Value)) elseif fd.Value~=nil then ZNX.Flags[k]:Set(fd.Value) end
		end) end end
	end)
end

-- ── NOTIFICATIONS ────────────────────────────────────────────
-- Aparecem no canto inferior direito, estilo terminal log
local _NPos,_NH="BottomRight",nil
local function BuildNH(pos)
	if _NH then _NH:Destroy() end
	local isR=pos=="TopRight" or pos=="BottomRight"; local isB=pos=="BottomLeft" or pos=="BottomRight"
	local P,W=12,290
	local px=isR and UDim2.new(1,-(W+P),isB and 1 or 0,isB and -P or P) or UDim2.new(0,P,isB and 1 or 0,isB and -P or P)
	_NH=N("Frame",{Parent=Root,Size=UDim2.new(0,W,1,-(P*2)),Position=px,AnchorPoint=Vector2.new(0,isB and 1 or 0),BackgroundTransparency=1},{
		N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,VerticalAlignment=isB and Enum.VerticalAlignment.Bottom or Enum.VerticalAlignment.Top,HorizontalAlignment=Enum.HorizontalAlignment.Center,Padding=UDim.new(0,4)}),
	})
	return _NH
end
BuildNH(_NPos)
function ZNX:SetNotifyPosition(pos) _NPos=pos; BuildNH(pos) end

function ZNX:Notify(cfg)
	cfg=cfg or{}; cfg.Title=cfg.Title or"AVISO"; cfg.Message=cfg.Message or""; cfg.Duration=cfg.Duration or 5
	task.spawn(function()
		local T=ZNX.Theme; local NH=_NH or BuildNH(_NPos)
		local isR=_NPos=="TopRight" or _NPos=="BottomRight"
		local offX=isR and UDim2.new(1,16,0,0) or UDim2.new(-1,-16,0,0)
		local wrap=N("Frame",{Parent=NH,Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,ClipsDescendants=true})
		local card=N("Frame",{Parent=wrap,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundColor3=T.Panel,BorderSizePixel=0,Position=offX},{
			N("UICorner",{CornerRadius=UDim.new(0,4)}),
			N("UIStroke",{Color=T.Acc,Thickness=1}),
			N("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12),PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10)}),
		})
		-- Linha laranja esquerda
		N("Frame",{Parent=card,Size=UDim2.new(0,2,1,-16),Position=UDim2.new(0,-12,0,8),BackgroundColor3=T.Acc,BorderSizePixel=0})
		N("UIListLayout",{Parent=card,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,2)})
		-- Prefixo estilo terminal
		local titleRow=N("Frame",{Parent=card,Size=UDim2.new(1,0,0,16),BackgroundTransparency=1})
		N("TextLabel",{Parent=titleRow,Size=UDim2.new(0,18,1,0),BackgroundTransparency=1,Text=">",Font=Enum.Font.Code,TextSize=12,TextColor3=T.Acc,TextXAlignment=Enum.TextXAlignment.Left})
		N("TextLabel",{Parent=titleRow,Position=UDim2.new(0,18,0,0),Size=UDim2.new(1,-18,1,0),BackgroundTransparency=1,Text=cfg.Title:upper(),Font=Enum.Font.Code,TextSize=12,TextColor3=T.AccGlow,TextXAlignment=Enum.TextXAlignment.Left})
		if cfg.Message~="" then
			N("TextLabel",{Parent=card,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1,Text=cfg.Message,Font=Enum.Font.Code,TextSize=11,TextColor3=T.TxtB,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true})
		end
		local pb=N("Frame",{Parent=card,Size=UDim2.new(1,0,0,1),BackgroundColor3=T.AccDim,BorderSizePixel=0})
		Tw(card,TweenInfo.new(.2,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{Position=UDim2.new(0,0,0,0)})
		Tw(pb,TweenInfo.new(cfg.Duration,Enum.EasingStyle.Linear),{Size=UDim2.new(0,0,0,1)})
		task.wait(cfg.Duration-.3)
		Tw(card,TI.Mid,{BackgroundTransparency=1})
		for _,ch in ipairs(card:GetDescendants()) do
			if ch:IsA("TextLabel") then Tw(ch,TI.Mid,{TextTransparency=1}) end
		end
		task.wait(.22); Tw(card,TweenInfo.new(.18,Enum.EasingStyle.Quint,Enum.EasingDirection.In),{Position=offX}); task.wait(.22); wrap:Destroy()
	end)
end

