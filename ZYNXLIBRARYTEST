				local function DeleteAllDisconnectedPlayers()
					for i, v in pairs(DD.Buttons) do
						if v and v:FindFirstChild("State") and v.State.Visible then
							DD.Buttons[i]:Destroy()
							DD.Buttons[i] = nil
							Options = Options - 1
						end
					end
				end

				function DD:Refresh() end

				function DD:Set(val, once)
					local n = table.find(SelectedValues, val)
					local text = ""
					local btn = DD.Buttons[val]

					if not btn then
						for i = 0, 10 do
							if DD.Buttons[val] then btn = DD.Buttons[val] break end
							task.wait(0.15)
						end
					end

					if btn then
						if DD.MultipleSelection then
							if not n then
								table.insert(SelectedValues, val)
								selLbl.Text = dCfg.Name
								TPlay(DD.Buttons[val],TW.Fast,{BackgroundTransparency=0.5})
								TPlay(DD.Buttons[val]:FindFirstChildOfClass("TextLabel"),TW.Fast,{TextTransparency=0})
							elseif n and not once then
								table.remove(SelectedValues, n)
								if DD.Buttons[val].State.Visible then
									DD.Buttons[val]:Destroy()
									DD.Buttons[val] = nil
									Options = Options - 1
								else
									TPlay(DD.Buttons[val],TW.Fast,{BackgroundTransparency=1})
									TPlay(DD.Buttons[val]:FindFirstChildOfClass("TextLabel"),TW.Fast,{TextTransparency=0.4})
								end
							end

							for i, v in pairs(SelectedValues) do
								if #SelectedValues == 1 then
									text = text .. v
								elseif i > 3 then
									text = text .. "..."
									break
								else
									text = text .. v .. ", "
								end
							end

							DD.Value = val
							selLbl.Text = text
							return dCfg.Callback(SelectedValues)
						else
							table.clear(SelectedValues)
							table.insert(SelectedValues, val)

							DeleteAllDisconnectedPlayers()

							for _, v in pairs(DD.Buttons) do
								TPlay(v,TW.Fast,{BackgroundTransparency=1})
								local lbl = v:FindFirstChildOfClass("TextLabel")
								if lbl then TPlay(lbl,TW.Fast,{TextTransparency=0.4}) end
							end

							if DD.Buttons[val] then
								TPlay(DD.Buttons[val],TW.Fast,{BackgroundTransparency=0.5})
								local lbl = DD.Buttons[val]:FindFirstChildOfClass("TextLabel")
								if lbl then TPlay(lbl,TW.Fast,{TextTransparency=0}) end

								DD.Value = val
								selLbl.Text = DD.Value
							else
								DD.Value = nil
								selLbl.Text = ""
							end

							return dCfg.Callback(DD.Value)
						end
					end
				end

				local Hbtn = New("TextButton",{
					Parent=header,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,
				})
