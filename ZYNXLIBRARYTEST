			-- Image Dropdown — UIListLayout correto
			function E:AddImageDropdown(imgCfg)
				imgCfg=imgCfg or{}; imgCfg.Name=imgCfg.Name or "Imagens"; imgCfg.OnApply=imgCfg.OnApply or function(_)end; imgCfg.SaveKey=imgCfg.SaveKey or "__ZNXBgImg"
				local saved={}
