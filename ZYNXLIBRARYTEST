			-- Button: row full-width, clique acende linha laranja inferior
			function E:AddButton(bCfg)
				bCfg=bCfg or{}; bCfg.Name=bCfg.Name or "Button"; bCfg.Callback=bCfg.Callback or function()end
				local row=MkRow(par,38)
				local acc=N("Frame",{Parent=row,Position=UDim2.new(0,0,1,-1),Size=UDim2.new(0,0,0,1),BackgroundColor3=ZNX.Theme.Acc,BorderSizePixel=0}); B(acc,"BackgroundColor3","Acc")
				N("TextLabel",{Parent=row,Position=UDim2.new(0,12,0,0),Size=UDim2.new(0,16,1,0),BackgroundTransparency=1,Text=">",Font=Enum.Font.Code,TextSize=12,TextColor3=ZNX.Theme.AccDim,TextXAlignment=Enum.TextXAlignment.Left})
				local lbl=N("TextLabel",{Parent=row,Position=UDim2.new(0,26,0,0),Size=UDim2.new(1,-46,1,0),BackgroundTransparency=1,Text=bCfg.Name,Font=Enum.Font.Code,TextSize=12,TextColor3=ZNX.Theme.TxtA,TextXAlignment=Enum.TextXAlignment.Left}); B(lbl,"TextColor3","TxtA")
				local btn=N("TextButton",{Parent=row,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				C(btn.MouseEnter,function() Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.RowHov}); Tw(acc,TI.Fast,{Size=UDim2.new(1,0,0,1)}) end)
				C(btn.MouseLeave,function() Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.Row}); Tw(acc,TI.Fast,{Size=UDim2.new(0,0,0,1)}) end)
				C(btn.MouseButton1Down,function() Tw(row,TI.Snap,{BackgroundColor3=ZNX.Theme.RowSel}) end)
				C(btn.MouseButton1Up,function() Tw(row,TI.Fast,{BackgroundColor3=ZNX.Theme.RowHov}); task.spawn(bCfg.Callback) end)
				MkSep(par); reg(row,bCfg.Name)
				return{Set=function(_,t) lbl.Text=t end}
