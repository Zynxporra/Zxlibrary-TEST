                colorConfig.Callback = colorConfig.Callback or function() end
                colorConfig.Flag = colorConfig.Flag or nil
                colorConfig.Save = colorConfig.Save or false

                local colorpicker = {
                    Value = colorConfig.Default,
                    Toggled = false,
