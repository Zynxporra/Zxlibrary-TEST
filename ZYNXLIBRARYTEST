-- ── SAVE / LOAD CONFIG ────────────────────────────────────────
local _sl,_sp=0,false
local function EDir()
    if not isfolder then return false end
    if not isfolder(Nexus.SaveDir) then makefolder(Nexus.SaveDir) end; return true
end
local function DoSave(name)
    if not Nexus.SaveOn or not writefile or not EDir() then return end
    local d={Ver=Nexus.Version,At=os.date("%Y-%m-%d %H:%M:%S"),Flags={},Theme={},BgLib=Nexus._BgLib}
    for fn,fo in pairs(Nexus.Flags) do
        if fo.Save then
            d.Flags[fn]=fo.Type=="Colorpicker"
                and {Type="Colorpicker",Value=ColorPack(fo.Value)}
                or  {Type=fo.Type or "?",Value=fo.Value}
        end
    end
    for k,v in pairs(Nexus.Theme) do
        if typeof(v)=="Color3" then d.Theme[k]=ColorPack(v)
        elseif type(v)=="number" or type(v)=="string" or type(v)=="boolean" then d.Theme[k]=v end
    end
    pcall(function() writefile(Nexus.SaveDir.."/"..name..".json",HttpService:JSONEncode(d)) end)
end
local function SaveCfg(name)
    local now=tick()
    if now-_sl<1.2 then
        if not _sp then _sp=true; task.delay(1.4,function() _sp=false; DoSave(name or Nexus._CfgName) end) end; return
    end; _sl=now; task.spawn(DoSave,name or Nexus._CfgName)
end
local function LoadCfg(name)
    if not readfile or not isfile then return end
    local path=Nexus.SaveDir.."/"..name..".json"
    if not isfile(path) then return end
    local ok,d=pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not ok or not d then return end
    if d.Theme then
        for k,v in pairs(d.Theme) do
            if type(v)=="table" and v.R then
                if Nexus.Theme[k]~=nil then Nexus.Theme[k]=ColorUnpack(v) end
            elseif type(v)~="nil" and Nexus.Theme[k]~=nil then Nexus.Theme[k]=v end
        end; ApplyTheme()
    end
    if d.BgLib then Nexus._BgLib=d.BgLib end
    task.defer(function()
        task.wait(0.3)
        for fn,fd in pairs(d.Flags or {}) do
            if Nexus.Flags[fn] then pcall(function()
                if fd.Type=="Colorpicker" then Nexus.Flags[fn]:Set(ColorUnpack(fd.Value))
                elseif fd.Value~=nil then Nexus.Flags[fn]:Set(fd.Value) end
            end) end
        end
    end)
end

-- ── DRAG ──────────────────────────────────────────────────────
local function MakeDrag(handle,target)
    pcall(function()
        local drag,dS,wS=false
        Conn(handle.InputBegan,function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1
            or i.UserInputType==Enum.UserInputType.Touch then
                drag=true; dS=Vector2.new(i.Position.X,i.Position.Y)
                wS=Vector2.new(target.Position.X.Offset,target.Position.Y.Offset)
                Conn(i.Changed,function()
                    if i.UserInputState==Enum.UserInputState.End then drag=false end
                end)
            end
        end)
        Conn(UIS.InputChanged,function(i)
            if not drag then return end
            if i.UserInputType~=Enum.UserInputType.MouseMovement
            and i.UserInputType~=Enum.UserInputType.Touch then return end
            local d=Vector2.new(i.Position.X,i.Position.Y)-dS
            target.Position=UDim2.new(target.Position.X.Scale,wS.X+d.X,target.Position.Y.Scale,wS.Y+d.Y)
        end)
    end)
end

