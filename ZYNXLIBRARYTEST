					Toggled = false, Type = "Dropdown", Save = dCfg.Save,
					MultipleSelection = dCfg.MultipleSelection
				}
				local MaxElements = 3
				local SelectedValues = {}
				local Options = 0

				local function GetSelectedBg()
					local a = NexusLib.Theme.Accent
					return Color3.fromRGB(
						math.clamp(math.floor(a.R * 255 * 0.18), 0, 255),
						math.clamp(math.floor(a.G * 255 * 0.18), 0, 255),
						math.clamp(math.floor(a.B * 255 * 0.18), 0, 255)
					)
