						N("TextLabel",{Parent=row2,Position=UDim2.new(0,36,0,18),Size=UDim2.new(1,-140,0,14),BackgroundTransparency=1,Text=tostring(img.id),Font=Enum.Font.Code,TextSize=10,TextColor3=ZNX.Theme.TxtC,TextXAlignment=Enum.TextXAlignment.Left})
