					Parent=header,Position=UDim2.new(0,12,0,0),Size=UDim2.new(1,-80,1,0),
					BackgroundTransparency=1,Text=pdCfg.Name,
					Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=NexusLib.Theme.TextPrimary,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				local selLbl = New("TextLabel",{
					Parent=header,Position=UDim2.new(1,-100,0,0),Size=UDim2.new(0,70,1,0),
