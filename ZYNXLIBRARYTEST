                local function InBL(k) for _,v in pairs(BLst) do if v==k then return true end end end
                local Bnd={Value="",Binding=false,Holding=false,Type="Bind",Save=BC2.Save}
                Bnd.Value=type(BC2.Default)=="userdata" and BC2.Default.Name or tostring(BC2.Default)
                local card=MkCard(36); local click=CBtn(card); HovCard(card,click)
                MkTitle(card,BC2.Name,12,0,-90)
