-- PACKET DETECTOR
-- ═══════════════════════════════════════════════════════════════
local PKD = {
	Active=false,Connection=nil,
	KB_THRESHOLD=5,BYTE_THRESHOLD=5*1024,
	COOLDOWN=30,lastNotify=0,
}
function PKD:start()
	if self.Connection then return end
	local gr=game:GetService("ReplicatedStorage"):FindFirstChild("GrabEvents")
	if not gr then ZNX:Notify({Title="Detector",Message="GrabEvents nao encontrado",Duration=3,Type="warn"}); return end
	local ev=gr:FindFirstChild("ExtendGrabLine")
	if not ev then ZNX:Notify({Title="Detector",Message="ExtendGrabLine nao encontrado",Duration=3,Type="warn"}); return end
	self.Connection=ev.OnClientEvent:Connect(function(...)
		if not self.Active then return end
		local args={...}; local totalBytes=0
		for _,v in ipairs(args) do
			if typeof(v)=="string" then totalBytes+=# v
			elseif typeof(v)=="table" then totalBytes+=#HTTP:JSONEncode(v) end
		end
		if totalBytes<self.BYTE_THRESHOLD then return end
		if tick()-self.lastNotify<self.COOLDOWN then return end
		self.lastNotify=tick()
		local sender=LP
		for _,v in ipairs(args) do
			if typeof(v)=="Instance" and v:IsA("Player") then sender=v; break end
		end
		local mb=totalBytes/(1024*1024)
		ZNX:Notify({
			Title="Pacote suspeito detectado",
			Message=string.format("De: %s (@%s)\nTamanho: %.3f MB\nRemote: %s",sender.DisplayName,sender.Name,mb,ev.Name),
			Duration=8,Type="danger"
		})
		if mb>1 then
			task.spawn(function()
				local f=N("Frame",{Parent=Root,Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(200,30,30),BackgroundTransparency=0.84,BorderSizePixel=0})
				Tw(f,TweenInfo.new(.25),{BackgroundTransparency=1}); task.wait(.25); f:Destroy()
			end)
		end
	end)
	self.Active=true
	ZNX:Notify({Title="Packet Detector",Message="Monitorando pacotes",Duration=3,Type="ok"})
end
function PKD:stop()
	if self.Connection then self.Connection:Disconnect(); self.Connection=nil end
	self.Active=false
	ZNX:Notify({Title="Packet Detector",Message="Desativado",Duration=2,Type="info"})
end

