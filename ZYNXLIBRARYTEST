		Cfg:AddTextbox({Name="bg image id",Default=wCfg.BgImage,Placeholder="id numerico",Callback=function(id) wCfg.BgImage=id; BgImg.Image=id~="" and "rbxassetid://"..id or""; BgDim.BackgroundTransparency=id~="" and 0.35 or 1; ZNX:Notify({Title="BG",Message=id~="" and "imagem aplicada" or "removida",Duration=3}) end})
		local ImgS=ST:AddSection({Name="imagens salvas"})
