                DC.Callback=DC.Callback or function() end
                DC.Flag=DC.Flag or nil; DC.Save=DC.Save or false
                DC.MaxShown=DC.MaxShown or 5

                local DD={Value=DC.Default,Options=DC.Options,Buttons={},Toggled=false,Type="Dropdown",Save=DC.Save}
                if not table.find(DD.Options,DD.Value) then DD.Value=DD.Options[1] or "None" end

                local Outer=New("Frame",{Parent=ItemParent,Size=UDim2.new(1,0,0,36),
                    BackgroundColor3=NL.Theme.CardBg,BorderSizePixel=0,ClipsDescendants=true,ZIndex=20},
                    {Crn(7),Str(NL.Theme.Border,1)})
