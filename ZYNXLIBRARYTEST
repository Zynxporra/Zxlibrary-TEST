                Bind(KBg,"BackgroundColor3","InputBg")
                local KSt=KBg:FindFirstChildOfClass("UIStroke"); Bind(KSt,"Color","Border")
                local KLbl=New("TextLabel",{Parent=KBg,Size=UDim2.new(1,0,1,0),ZIndex=23,
                    BackgroundTransparency=1,Text=Bnd.Value,Font=Enum.Font.GothamBold,TextSize=12,
                    TextColor3=Nexus.Theme.Accent,TextXAlignment=Enum.TextXAlignment.Center})
                Bind(KLbl,"TextColor3","Accent")
                Conn(click.InputEnded,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 and not Bnd.Binding then
                        Bnd.Binding=true; KLbl.Text="..."
                        Tw(KSt,TI.Fast,{Color=Nexus.Theme.Accent})
                    end
                end)
                Conn(UIS.InputBegan,function(inp,gp)
                    if gp then return end
                    if Bnd.Binding then
                        local Key=nil
                        pcall(function() if not InBL(inp.KeyCode) then Key=inp.KeyCode end end)
                        Key=Key or Enum.KeyCode.Unknown; Bnd:Set(Key)
                        Tw(KSt,TI.Fast,{Color=Nexus.Theme.Border}); SaveCfg(WC.ConfigName)
                    elseif inp.KeyCode.Name==Bnd.Value or inp.UserInputType.Name==Bnd.Value then
                        if BC2.Hold then Bnd.Holding=true; BC2.Callback(true) else BC2.Callback() end
                    end
                end)
                Conn(UIS.InputEnded,function(inp)
                    if (inp.KeyCode.Name==Bnd.Value or inp.UserInputType.Name==Bnd.Value)
                    and BC2.Hold and Bnd.Holding then Bnd.Holding=false; BC2.Callback(false) end
                end)
                function Bnd:Set(k)
                    Bnd.Binding=false
                    Bnd.Value=type(k)=="string" and k or (k and k.Name or "Unknown")
                    KLbl.Text=Bnd.Value
                end
                Bnd:Set(BC2.Default)
                if BC2.Flag then Nexus.Flags[BC2.Flag]=Bnd end
                return Bnd
            end

