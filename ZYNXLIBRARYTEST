            end
            local function HovCard(card,btn)
                Conn(btn.MouseEnter,function() Tw(card,TI.Fast,{BackgroundColor3=Nexus.Theme.CardHov}) end)
                Conn(btn.MouseLeave,function() Tw(card,TI.Fast,{BackgroundColor3=Nexus.Theme.CardBg}) end)
                Conn(btn.MouseButton1Down,function() Tw(card,TI.Fast,{BackgroundColor3=Nexus.Theme.CardAct}) end)
                Conn(btn.MouseButton1Up,function() Tw(card,TI.Fast,{BackgroundColor3=Nexus.Theme.CardHov}) end)
            end
            local function MkTitle(card,text,xO,yO,wO)
                local l=New("TextLabel",{Parent=card,ZIndex=21,
                    Position=UDim2.new(0,xO or 12,0,yO or 0),Size=UDim2.new(1,wO or -24,1,0),
                    BackgroundTransparency=1,Text=text,Font=Enum.Font.GothamBold,TextSize=14,
                    TextColor3=Nexus.Theme.TextH2,TextXAlignment=Enum.TextXAlignment.Left})
                Bind(l,"TextColor3","TextH2"); return l
            end
            local function CBtn(p,z)
                return New("TextButton",{Parent=p,Size=UDim2.new(1,0,1,0),
                    BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=z or 25})
            end

            -- LABEL
            function EF:AddLabel(text)
                local card=MkCard(28); local lbl=MkTitle(card,text or "Label")
                local L={}; function L:Set(t) lbl.Text=t end; return L
            end

            -- PARAGRAPH
            function EF:AddParagraph(title,content)
                local card=MkCard(nil,true); Pad(10,12,10,12).Parent=card
                local tl=New("TextLabel",{Parent=card,Size=UDim2.new(1,0,0,18),ZIndex=21,
                    BackgroundTransparency=1,Text=title or "Title",Font=Enum.Font.GothamBold,
                    TextSize=14,TextColor3=Nexus.Theme.TextH1,TextXAlignment=Enum.TextXAlignment.Left})
                Bind(tl,"TextColor3","TextH1")
                local cl=New("TextLabel",{Parent=card,Position=UDim2.new(0,0,0,22),
                    Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,ZIndex=21,
                    BackgroundTransparency=1,Text=content or "",Font=Enum.Font.GothamMedium,
                    TextSize=13,TextColor3=Nexus.Theme.Text,TextWrapped=true,
                    TextXAlignment=Enum.TextXAlignment.Left})
                Bind(cl,"TextColor3","Text")
                local P={}; function P:Set(t) cl.Text=t end; function P:SetTitle(t) tl.Text=t end; return P
            end

            -- BUTTON
            function EF:AddButton(BC)
                BC=BC or {}; BC.Name=BC.Name or "Button"; BC.Callback=BC.Callback or function() end
                BC.Desc=BC.Desc or ""; BC.Icon=BC.Icon or ""
                local h=BC.Desc~="" and 52 or 36
                local card=MkCard(h); local click=CBtn(card); HovCard(card,click)
                MkTitle(card,BC.Name,12,0,-40)
                if BC.Desc~="" then
