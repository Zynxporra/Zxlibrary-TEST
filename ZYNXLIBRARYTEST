-- DRAG
local function MkDrag(handle,target)
	pcall(function()
		local drag,ds,sp=false
		C(handle.InputBegan,function(i)
			if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
				drag=true; ds=i.Position; sp=target.Position
				i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
			end
		end)
		C(UIS.InputChanged,function(i)
			if drag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
				local d=i.Position-ds; target.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
			end
		end)
	end)
end

-- SAVE/LOAD (integrado com SaveSystem)
local sDb, sPend = 0, false

local function BuildSaveData(configName)
	local d = {
		Version = "5.2",
		ConfigName = configName,
		SavedAt = os.time(),
		Flags = {},
		Theme = {},
		NPos = ZNX.NPos,
	}
	for k,f in pairs(ZNX.Flags) do
		if f.Save and f.Type ~= "PlayersDropdown" and f.Type ~= "PlayerDropdown" then
			if f.Type == "Colorpicker" then
				d.Flags[k] = {Type="CP", Value=CPk(f.Value)}
			elseif f.Type == "Toggle" then
				d.Flags[k] = {Type="Toggle", Value=f.Value}
			elseif f.Type == "Slider" then
				d.Flags[k] = {Type="Slider", Value=f.Value}
			elseif f.Type == "Dropdown" then
				d.Flags[k] = {Type="Dropdown", Value=f.Value}
			elseif f.Type == "Bind" then
				d.Flags[k] = {Type="Bind", Value=f.Value}
			end
		end
	end
	for k,v in pairs(ZNX.Theme) do
		if typeof(v) == "Color3" then
			d.Theme[k] = CPk(v)
		end
	end
	return d
end

local function SaveCfg(name, silent)
	if not ZNX.SaveEn then return false end
	local now = tick()
	if now - sDb < 1.5 then
		if not sPend then
			sPend = true
			task.delay(1.5, function()
				sPend = false
				SaveCfg(name, true)
			end)
		end
		return false
	end
	sDb = now
	local data = BuildSaveData(name)
	local ok = SaveSystem:Write(name, data)
	if not silent then
		if ok then
			ZNX:Notify({Title="💾 Config Salva", Message=ZNX.SaveDir.."/"..name..".json", Duration=3, Type="ok"})
		else
			ZNX:Notify({Title="❌ Erro ao Salvar", Message="Verifique permissões do executor", Duration=4, Type="err"})
		end
	end
	return ok
end

local function LoadCfg(name, silent)
	local data = SaveSystem:Read(name)
	if not data then return false end

	if data.NPos then ZNX.NPos = data.NPos end

	-- Aplica tema primeiro
	if data.Theme then
		for k,v in pairs(data.Theme) do
			if ZNX.Theme[k] ~= nil then
				ZNX.Theme[k] = CUp(v)
			end
		end
		ApplyTheme()
	end

	-- Aplica flags com delay para garantir que os elementos existam
	task.defer(function()
		task.wait(0.2)
		for k, fd in pairs(data.Flags or {}) do
			local flag = ZNX.Flags[k]
			if flag and flag.Type ~= "PlayersDropdown" and flag.Type ~= "PlayerDropdown" then
				pcall(function()
					if fd.Type == "CP" then
						flag:Set(CUp(fd.Value))
					elseif fd.Value ~= nil then
						flag:Set(fd.Value)
					end
				end)
			end
		end
		if not silent then
			ZNX:Notify({Title="📂 Config Carregada", Message=name, Duration=3, Type="ok"})
		end
	end)
	return true
end

