		-- FIX: Ativar tab com highlight correto
		local function ActivateTab()
			for _, td in pairs(AllTabs) do
				-- Desativar outros
				TPlay(td.Btn, TW.Fast, {BackgroundColor3 = T_.BgPanel})
				local bar = td.Btn:FindFirstChildOfClass("Frame")
				if bar then TPlay(bar, TW.Fast, {BackgroundTransparency = 1}) end
				local ico = td.Btn:FindFirstChildOfClass("ImageLabel")
				local lbl = td.Btn:FindFirstChildOfClass("TextLabel")
				if ico then TPlay(ico, TW.Fast, {ImageColor3 = T_.TextMuted}) end
				if lbl then TPlay(lbl, TW.Fast, {TextColor3 = T_.TextMuted}) end
				td.Content.Visible = false
			end
			-- Ativar tab atual
			TPlay(TabBtn,  TW.Fast, {BackgroundColor3 = T_.BgHover})
			TPlay(IndBar,  TW.Fast, {BackgroundTransparency = 0})
			TPlay(TabIco,  TW.Fast, {ImageColor3 = T_.Accent})
			TPlay(TabLbl,  TW.Fast, {TextColor3  = T_.TextPrimary})
			ContentScroll.Visible = true
			ActiveTab = tabCfg.Name
		end

		Connect(TabBtn.MouseButton1Up, ActivateTab)
		Connect(TabBtn.MouseEnter, function()
			if ActiveTab ~= tabCfg.Name then
				TPlay(TabBtn, TW.Fast, {BackgroundColor3 = T_.BgCard})
			end
		end)
		Connect(TabBtn.MouseLeave, function()
			if ActiveTab ~= tabCfg.Name then
				TPlay(TabBtn, TW.Fast, {BackgroundColor3 = T_.BgPanel})
			end
		end)

		if firstTab then
			firstTab = false
			ActivateTab()
		end

