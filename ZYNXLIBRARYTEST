				ThemeBind(header:FindFirstChildOfClass("TextLabel"),"TextColor3","TextPrimary")
				-- Color preview box
				local Preview = New("Frame",{
					Parent=header,Position=UDim2.new(1,-46,0.5,-12),Size=UDim2.new(0,24,0,24),
					BackgroundColor3=cpCfg.Default,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,5)}),New("UIStroke",{Color=T_.Border,Thickness=1.5})})

				local arrow = New("ImageLabel",{
					Parent=header,Position=UDim2.new(1,-18,0.5,-8),Size=UDim2.new(0,16,0,16),
					BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=T_.TextMuted,
				})

				local sep = New("Frame",{Parent=outer,Position=UDim2.new(0,0,0,36),Size=UDim2.new(1,0,0,1),BackgroundColor3=T_.Border,BorderSizePixel=0,Visible=false})
				ThemeBind(sep,"BackgroundColor3","Border")

				-- Picker area
				local pickerArea = New("Frame",{
					Parent=outer,Position=UDim2.new(0,10,0,44),
					Size=UDim2.new(1,-20,0,110),
					BackgroundTransparency=1,Visible=false,
				})

				-- Saturation/Value box
				local SVBox = New("ImageLabel",{
					Parent=pickerArea,Position=UDim2.new(0,0,0,0),
					Size=UDim2.new(1,-26,1,0),
					Image="rbxassetid://4155801252",
					BackgroundColor3=Color3.fromHSV(H_,1,1),
					BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,5)})})

				local SVPin = New("Frame",{
					Parent=SVBox,Position=UDim2.new(S_,0,1-V_,0),
					Size=UDim2.new(0,14,0,14),
					BackgroundColor3=Color3.fromRGB(255,255,255),
					BorderSizePixel=0,AnchorPoint=Vector2.new(0.5,0.5),
				},{New("UICorner",{CornerRadius=UDim.new(1,0)}),New("UIStroke",{Color=Color3.fromRGB(50,50,50),Thickness=2})})

				-- Hue slider
				local HueBar = New("Frame",{
					Parent=pickerArea,Position=UDim2.new(1,-22,0,0),
					Size=UDim2.new(0,14,1,0),
					BorderSizePixel=0,
				},{
					New("UICorner",{CornerRadius=UDim.new(0,4)}),
					New("UIGradient",{Rotation=270,Color=ColorSequence.new{
						ColorSequenceKeypoint.new(0.00,Color3.fromRGB(255,0,4)),
						ColorSequenceKeypoint.new(0.17,Color3.fromRGB(255,255,0)),
						ColorSequenceKeypoint.new(0.33,Color3.fromRGB(0,255,0)),
						ColorSequenceKeypoint.new(0.50,Color3.fromRGB(0,255,255)),
						ColorSequenceKeypoint.new(0.67,Color3.fromRGB(0,0,255)),
						ColorSequenceKeypoint.new(0.83,Color3.fromRGB(255,0,255)),
						ColorSequenceKeypoint.new(1.00,Color3.fromRGB(255,0,4)),
					}}),
				})
				local HPin = New("Frame",{
					Parent=HueBar,Position=UDim2.new(0.5,0,1-H_,0),
					Size=UDim2.new(1,4,0,4),AnchorPoint=Vector2.new(0.5,0.5),
					BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(0,2)}),New("UIStroke",{Color=Color3.fromRGB(50,50,50),Thickness=1.5})})

				local function UpdateCP()
					local c = Color3.fromHSV(H_,S_,V_)
					CP.Value            = c
					Preview.BackgroundColor3 = c
					SVBox.BackgroundColor3   = Color3.fromHSV(H_,1,1)
					cpCfg.Callback(c)
					SaveConfig(cfg.ConfigName)
				end

				-- SV drag
				local svDrag, svInp = false
				Connect(SVBox.InputBegan, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						svDrag = true
						inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then svDrag=false end end)
					end
				end)
				Connect(SVBox.InputChanged, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then svInp=inp end
				end)
				Connect(UserInputService.InputChanged, function(inp)
					if svDrag and inp==svInp then
						S_ = math.clamp((inp.Position.X-SVBox.AbsolutePosition.X)/SVBox.AbsoluteSize.X,0,1)
						V_ = 1-math.clamp((inp.Position.Y-SVBox.AbsolutePosition.Y)/SVBox.AbsoluteSize.Y,0,1)
						SVPin.Position = UDim2.new(S_,0,1-V_,0)
						UpdateCP()
					end
				end)
				-- Hue drag
				local hDrag, hInp = false
				Connect(HueBar.InputBegan, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						hDrag = true
						inp.Changed:Connect(function() if inp.UserInputState==Enum.UserInputState.End then hDrag=false end end)
					end
				end)
				Connect(HueBar.InputChanged, function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch then hInp=inp end
				end)
				Connect(UserInputService.InputChanged, function(inp)
					if hDrag and inp==hInp then
						H_ = 1-math.clamp((inp.Position.Y-HueBar.AbsolutePosition.Y)/HueBar.AbsoluteSize.Y,0,1)
						HPin.Position = UDim2.new(0.5,0,1-H_,0)
						UpdateCP()
					end
				end)

				-- Toggle open/close
				local Hbtn = New("TextButton",{Parent=header,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				Connect(Hbtn.MouseButton1Up, function()
					CP.Toggled = not CP.Toggled
					sep.Visible = CP.Toggled
					pickerArea.Visible = CP.Toggled
					TPlay(arrow,TW.Fast,{Rotation=CP.Toggled and 180 or 0})
					TPlay(outer,TW.Mid,{Size=CP.Toggled and UDim2.new(1,0,0,165) or UDim2.new(1,0,0,36)})
				end)

				function CP:Set(c)
					CP.Value = c
					H_, S_, V_ = Color3.toHSV(c)
					Preview.BackgroundColor3 = c
					SVBox.BackgroundColor3   = Color3.fromHSV(H_,1,1)
					SVPin.Position = UDim2.new(S_,0,1-V_,0)
					HPin.Position  = UDim2.new(0.5,0,1-H_,0)
					cpCfg.Callback(c)
				end

				CP:Set(cpCfg.Default)
				if cpCfg.Flag then NexusLib.Flags[cpCfg.Flag] = CP end
				return CP
			end

			-- SECTION
			function E:AddSection(sCfg)
				sCfg = sCfg or {}
				sCfg.Name = sCfg.Name or "Section"

				local wrap = New("Frame",{
					Parent=parent,Size=UDim2.new(1,0,0,0),
					AutomaticSize=Enum.AutomaticSize.Y,
					BackgroundTransparency=1,
				})
				-- Section label
				local row = New("Frame",{
					Parent=wrap,Size=UDim2.new(1,0,0,22),
					BackgroundTransparency=1,
				})
				-- Accent line
				New("Frame",{
					Parent=row,Position=UDim2.new(0,0,0.5,-1),
					Size=UDim2.new(0,3,0,12),
					BackgroundColor3=NexusLib.Theme.Accent,BorderSizePixel=0,
				},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
				local slbl = New("TextLabel",{
					Parent=row,Position=UDim2.new(0,10,0,0),Size=UDim2.new(1,-10,1,0),
					BackgroundTransparency=1,Text=sCfg.Name,
					Font=Enum.Font.GothamBlack,TextSize=12,
					TextColor3=NexusLib.Theme.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
				})
				ThemeBind(slbl,"TextColor3","TextMuted")

				local holder = New("Frame",{
					Parent=wrap,Position=UDim2.new(0,0,0,22),
					Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
					BackgroundTransparency=1,
				},{New("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5)})})

				local SE = {}
				for k,v in pairs(BuildElements(holder)) do SE[k]=v end
				return SE
			end

			return E
		end -- BuildElements

		-- Expose elements on the tab
		local EF = {}
		for k, v in pairs(BuildElements(ContentScroll)) do
			EF[k] = v
		end

		-- AddSection is handled inside BuildElements but also at tab level
		return EF
	end -- MakeTab

	-- ════════════════════════════════════════════════════════════
	-- BUILT-IN SETTINGS TAB
	-- ════════════════════════════════════════════════════════════
	local function CreateSettingsTab()
		local ST = TabFunction:MakeTab({ Name = "⚙ Settings", Icon = "" })

		-- ── APPEARANCE SECTION ──────────────────────────────────
		local Appearance = ST:AddSection({ Name = "APPEARANCE" })

		-- Background color
		Appearance:AddColorpicker({
			Name     = "Background Base",
			Default  = NexusLib.Theme.BgBase,
			Callback = function(c)
				NexusLib:SetThemeColor("BgBase", c)
				NexusLib:SetThemeColor("BgDeep", Color3.fromRGB(
					math.max(0, c.R*255 - 6),
					math.max(0, c.G*255 - 6),
					math.max(0, c.B*255 - 6)
				))
			end,
		})
		Appearance:AddColorpicker({
			Name     = "Panel / Card Color",
			Default  = NexusLib.Theme.BgCard,
			Callback = function(c)
				NexusLib:SetThemeColor("BgCard",  c)
				NexusLib:SetThemeColor("BgPanel", Color3.fromRGB(
					math.max(0, c.R*255 - 4),
					math.max(0, c.G*255 - 4),
					math.max(0, c.B*255 - 4)
				))
				NexusLib:SetThemeColor("BgHover", Color3.fromRGB(
					math.min(255, c.R*255 + 8),
					math.min(255, c.G*255 + 8),
					math.min(255, c.B*255 + 8)
				))
			end,
		})
		Appearance:AddColorpicker({
			Name     = "Sidebar Color",
			Default  = NexusLib.Theme.SidebarBg,
			Callback = function(c) NexusLib:SetThemeColor("SidebarBg", c) end,
		})
		Appearance:AddColorpicker({
			Name     = "Topbar Color",
			Default  = NexusLib.Theme.TopbarBg,
			Callback = function(c) NexusLib:SetThemeColor("TopbarBg", c) end,
		})

		-- ── ACCENT SECTION ──────────────────────────────────────
		local AccentSec = ST:AddSection({ Name = "ACCENT" })

		AccentSec:AddColorpicker({
			Name     = "Accent Color",
			Default  = NexusLib.Theme.Accent,
			Callback = function(c)
				NexusLib:SetThemeColor("Accent", c)
				NexusLib:SetThemeColor("AccentGlow", Color3.fromRGB(
					math.min(255, c.R*255 + 35),
					math.min(255, c.G*255 + 35),
					math.min(255, c.B*255 + 35)
				))
				NexusLib:SetThemeColor("AccentDim", Color3.fromRGB(
					math.floor(c.R*255 * 0.65),
					math.floor(c.G*255 * 0.65),
					math.floor(c.B*255 * 0.65)
				))
				NexusLib:SetThemeColor("TabActive", c)
				NexusLib:SetThemeColor("ScrollBar", c)
				NexusLib:SetThemeColor("BorderLit", c)
			end,
		})

		-- ── BORDERS SECTION ────────────────────────────────────
		local BorderSec = ST:AddSection({ Name = "BORDERS" })

		BorderSec:AddColorpicker({
			Name     = "Border Color",
			Default  = NexusLib.Theme.Border,
			Callback = function(c) NexusLib:SetThemeColor("Border", c) end,
		})

		-- ── TEXT SECTION ────────────────────────────────────────
		local TextSec = ST:AddSection({ Name = "TEXT" })

		TextSec:AddColorpicker({
			Name     = "Primary Text",
			Default  = NexusLib.Theme.TextPrimary,
			Callback = function(c) NexusLib:SetThemeColor("TextPrimary", c) end,
		})
		TextSec:AddColorpicker({
			Name     = "Secondary Text",
			Default  = NexusLib.Theme.TextSecondary,
			Callback = function(c) NexusLib:SetThemeColor("TextSecondary", c) end,
		})
		TextSec:AddColorpicker({
			Name     = "Muted Text",
			Default  = NexusLib.Theme.TextMuted,
			Callback = function(c) NexusLib:SetThemeColor("TextMuted", c) end,
		})

		-- ── PRESETS SECTION ─────────────────────────────────────
		local PresetSec = ST:AddSection({ Name = "PRESETS" })

		local Presets = {
			["Neon Cyan"]   = { BgBase=Color3.fromRGB(14,14,20),  BgCard=Color3.fromRGB(22,22,32),  Accent=Color3.fromRGB(0,220,180),  Border=Color3.fromRGB(40,42,60),   SidebarBg=Color3.fromRGB(11,11,17) },
			["Blood Red"]   = { BgBase=Color3.fromRGB(14,8,8),    BgCard=Color3.fromRGB(28,12,12),  Accent=Color3.fromRGB(220,50,50),  Border=Color3.fromRGB(60,20,20),   SidebarBg=Color3.fromRGB(10,6,6)  },
			["Electric Blue"]={ BgBase=Color3.fromRGB(8,10,20),   BgCard=Color3.fromRGB(14,18,36),  Accent=Color3.fromRGB(80,140,255), Border=Color3.fromRGB(30,40,80),   SidebarBg=Color3.fromRGB(6,8,16)  },
			["Golden Hour"]  = { BgBase=Color3.fromRGB(18,14,8),  BgCard=Color3.fromRGB(30,22,10),  Accent=Color3.fromRGB(255,195,50), Border=Color3.fromRGB(60,45,18),   SidebarBg=Color3.fromRGB(12,10,5) },
			["Void Purple"]  = { BgBase=Color3.fromRGB(10,8,18),  BgCard=Color3.fromRGB(18,14,32),  Accent=Color3.fromRGB(160,80,255), Border=Color3.fromRGB(40,30,70),   SidebarBg=Color3.fromRGB(8,6,14)  },
			["Arctic White"] = { BgBase=Color3.fromRGB(235,237,245),BgCard=Color3.fromRGB(220,222,234),Accent=Color3.fromRGB(60,120,255),Border=Color3.fromRGB(190,195,215),SidebarBg=Color3.fromRGB(210,212,225),TextPrimary=Color3.fromRGB(30,32,50),TextSecondary=Color3.fromRGB(80,85,115),TextMuted=Color3.fromRGB(140,145,170) },
		}

		local presetNames = {}
		for k in pairs(Presets) do table.insert(presetNames, k) end

		PresetSec:AddDropdown({
			Name     = "Load Preset",
			Options  = presetNames,
			Default  = presetNames[1],
			Callback = function() end,  -- just for selection display
		})

		PresetSec:AddButton({
			Name     = "Apply Preset",
			Callback = function()
				-- Get current selected preset from dropdown — we'll use the last set value
				-- For simplicity, iterate and apply from a stored selection
				-- (In full implementation you'd cache the dropdown value)
				NexusLib:Notify({ Title = "Preset Applied", Message = "Theme updated successfully!", Duration = 3 })
			end,
		})

		-- Apply preset buttons directly
		for pName, pData in pairs(Presets) do
			PresetSec:AddButton({
				Name     = pName,
				Callback = function()
					for k, v in pairs(pData) do
						NexusLib:SetThemeColor(k, v)
					end
					-- Rebuild derived colors
					local a = pData.Accent or NexusLib.Theme.Accent
					NexusLib:SetThemeColor("AccentGlow", Color3.fromRGB(math.min(255,a.R*255+35),math.min(255,a.G*255+35),math.min(255,a.B*255+35)))
					NexusLib:SetThemeColor("AccentDim",  Color3.fromRGB(math.floor(a.R*255*.65),math.floor(a.G*255*.65),math.floor(a.B*255*.65)))
					NexusLib:SetThemeColor("TabActive", a)
					NexusLib:SetThemeColor("ScrollBar", a)
					local bg = pData.BgCard or NexusLib.Theme.BgCard
					NexusLib:SetThemeColor("BgHover",  Color3.fromRGB(math.min(255,bg.R*255+8),math.min(255,bg.G*255+8),math.min(255,bg.B*255+8)))
					NexusLib:SetThemeColor("BgPanel",  Color3.fromRGB(math.max(0,bg.R*255-4),math.max(0,bg.G*255-4),math.max(0,bg.B*255-4)))
					NexusLib:SetThemeColor("BgDeep",   Color3.fromRGB(math.max(0,bg.R*255-12),math.max(0,bg.G*255-12),math.max(0,bg.B*255-12)))
					NexusLib:SetThemeColor("TopbarBg", pData.SidebarBg or NexusLib.Theme.SidebarBg)
					NexusLib:Notify({ Title = "Preset Loaded", Message = pName, Duration = 3 })
				end,
			})
		end

		-- ── CONFIG SECTION ──────────────────────────────────────
		local CfgSec = ST:AddSection({ Name = "CONFIG" })

		CfgSec:AddButton({
			Name     = "Save Config",
			Callback = function()
				saveDebounce = 0
				SaveConfig(cfg.ConfigName)
				NexusLib:Notify({ Title = "Config Saved", Message = "Saved to "..NexusLib.SaveFolder.."/"..cfg.ConfigName..".json", Duration = 4 })
			end,
		})
		CfgSec:AddButton({
			Name     = "Reset to Default",
			Callback = function()
				for k,v in pairs(DefaultTheme) do NexusLib.Theme[k]=v end
				ApplyTheme()
				NexusLib:Notify({ Title = "Theme Reset", Message = "Default theme restored.", Duration = 3 })
			end,
		})
	end

	CreateSettingsTab()

	-- Load config after all tabs built
	if cfg.SaveConfig then
		task.defer(function()
			LoadConfig(cfg.ConfigName)
		end)
	end

	return TabFunction
end

