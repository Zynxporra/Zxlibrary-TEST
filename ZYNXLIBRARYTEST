            sliderConfig = sliderConfig or {}
            sliderConfig.Name = sliderConfig.Name or "Slider"
            sliderConfig.Min = sliderConfig.Min or 0
            sliderConfig.Max = sliderConfig.Max or 100
            sliderConfig.Default = sliderConfig.Default or sliderConfig.Min
            sliderConfig.Suffix = sliderConfig.Suffix or ""
            sliderConfig.Callback = sliderConfig.Callback or function() end
            
            local slider = { Value = sliderConfig.Default }
            local dragging = false
            
            local card = self:New("Frame", {
                Parent = ContentScroll,
                Size = UDim2.new(1, 0, 0, 56),
                BackgroundColor3 = theme.BgCard,
                BorderSizePixel = 0,
            }, {
                Instance.new("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Instance.new("UIStroke", { Color = theme.Border, Thickness = 1 }),
            })
            
            self:New("TextLabel", {
                Parent = card,
                Position = UDim2.new(0, 12, 0, 8),
                Size = UDim2.new(0.7, 0, 0, 18),
                BackgroundTransparency = 1,
                Text = sliderConfig.Name,
                Font = Enum.Font.GothamBold,
                TextSize = 14,
                TextColor3 = theme.TextPrimary,
                TextXAlignment = Enum.TextXAlignment.Left,
            })
            
            local valueLabel = self:New("TextLabel", {
                Parent = card,
                Position = UDim2.new(0.7, 0, 0, 8),
                Size = UDim2.new(0.3, 0, 0, 18),
                BackgroundTransparency = 1,
                Text = tostring(sliderConfig.Default).." "..sliderConfig.Suffix,
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = theme.Accent,
                TextXAlignment = Enum.TextXAlignment.Right,
            })
            
            local track = self:New("Frame", {
                Parent = card,
                Position = UDim2.new(0, 12, 0, 34),
                Size = UDim2.new(1, -24, 0, 6),
                BackgroundColor3 = theme.Border,
                BorderSizePixel = 0,
            }, {
                Instance.new("UICorner", { CornerRadius = UDim.new(1, 0) }),
            })
            
            local fill = self:New("Frame", {
                Parent = track,
                Size = UDim2.new((slider.Value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min), 0, 1, 0),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel = 0,
            }, {
                Instance.new("UICorner", { CornerRadius = UDim.new(1, 0) }),
            })
            
            local thumb = self:New("Frame", {
                Parent = track,
                Position = UDim2.new((slider.Value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min), -8, 0.5, -8),
                Size = UDim2.new(0, 16, 0, 16),
                BackgroundColor3 = theme.Accent,
                BorderSizePixel = 0,
            }, {
                Instance.new("UICorner", { CornerRadius = UDim.new(1, 0) }),
                Instance.new("UIStroke", { Color = Color3.new(1,1,1), Thickness = 2 }),
            })
            
            function slider:Set(val)
                slider.Value = math.clamp(val, sliderConfig.Min, sliderConfig.Max)
                local pct = (slider.Value - sliderConfig.Min) / (sliderConfig.Max - sliderConfig.Min)
                fill.Size = UDim2.new(pct, 0, 1, 0)
                thumb.Position = UDim2.new(pct, -8, 0.5, -8)
                valueLabel.Text = tostring(math.floor(slider.Value)).." "..sliderConfig.Suffix
                sliderConfig.Callback(slider.Value)
            end
            
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    slider:Set(sliderConfig.Min + (sliderConfig.Max - sliderConfig.Min) * pct)
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pct = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                    slider:Set(sliderConfig.Min + (sliderConfig.Max - sliderConfig.Min) * pct)
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            slider:Set(slider.Value)
            return slider
        end
        
        return Elements
    end
    
    return TabCreator
end

return NexusLib
