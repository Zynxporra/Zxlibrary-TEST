				-- Header
				local head=N("Frame",{Parent=outer,Size=UDim2.new(1,0,0,30),BackgroundColor3=ZNX.Theme.Panel,BorderSizePixel=0}); B(head,"BackgroundColor3","Panel")
				N("TextLabel",{Parent=head,Position=UDim2.new(0,8,0,0),Size=UDim2.new(0.5,0,1,0),BackgroundTransparency=1,Text=imgCfg.Name:upper(),Font=Enum.Font.Code,TextSize=11,TextColor3=ZNX.Theme.Acc,TextXAlignment=Enum.TextXAlignment.Left}); B(head:FindFirstChildOfClass("TextLabel"),"TextColor3","Acc")
