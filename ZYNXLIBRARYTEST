		for pn,cols in pairs(gradPresets) do
			GradSec:AddButton({Name="Aplicar: "..pn, Callback=function()
				BgGradObj.Color=ColorSequence.new{
					ColorSequenceKeypoint.new(0,cols[1]),
					ColorSequenceKeypoint.new(0.45,cols[2]),
					ColorSequenceKeypoint.new(1,cols[3]),
