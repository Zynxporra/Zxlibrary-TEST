                Callback = function()
                    for key, val in pairs(preset) do
                        NexusLib:SetTheme(key, val)
                    end
                    local a = preset.Accent
                    NexusLib:SetTheme("AccentGlow", Color3.fromRGB(
                        math.min(255, a.R * 255 + 35),
                        math.min(255, a.G * 255 + 35),
                        math.min(255, a.B * 255 + 35)
                    ))
                    NexusLib:SetTheme("AccentDim", Color3.fromRGB(
                        math.floor(a.R * 255 * 0.65),
                        math.floor(a.G * 255 * 0.65),
                        math.floor(a.B * 255 * 0.65)
                    ))
                    NexusLib:Notify({
                        Title = "Preset Loaded",
                        Message = name,
                        Duration = 3,
                    })
                end,
            })
        end

        local configSection = settingsTab:AddSection({ Name = "CONFIG" })

        configSection:AddButton({
            Name = "Save Config",
            Callback = function()
                SaveConfig(config.ConfigName)
                NexusLib:Notify({
                    Title = "Config Saved",
                    Message = "Saved to " .. NexusLib.SaveFolder .. "/" .. config.ConfigName .. ".json",
                    Duration = 4,
                })
            end,
        })

        configSection:AddButton({
            Name = "Reset to Default",
            Callback = function()
                for k, v in pairs(DefaultTheme) do
                    NexusLib.Theme[k] = v
                end
                ApplyTheme()
                NexusLib:Notify({
                    Title = "Theme Reset",
                    Message = "Default theme restored.",
                    Duration = 3,
                })
            end,
        })

        configSection:AddBind({
            Name = "Toggle Key",
            Default = Enum.KeyCode[NexusLib.ToggleKey] or Enum.KeyCode.RightShift,
            Callback = function(key)
                NexusLib.ToggleKey = key
                NexusLib:Notify({
                    Title = "Toggle Key Changed",
                    Message = "New key: " .. key,
                    Duration = 3,
                })
            end,
            Flag = "ToggleKey",
            Save = true,
        })

        configSection:AddTextbox({
            Name = "Background ID",
            Default = config.BackgroundImage,
            Placeholder = "Image ID",
            Callback = function(id)
                config.BackgroundImage = id
                BackgroundImage.Image = id ~= "" and "rbxassetid://" .. id or ""
                BackgroundDim.BackgroundTransparency = id ~= "" and 0.6 or 1
                NexusLib:Notify({
                    Title = "Background Updated",
                    Message = id ~= "" and "Image set" or "Image removed",
                    Duration = 3,
                })
            end,
        })
    end

    CreateSettingsTab()

    if config.SaveConfig then
        task.defer(function()
            LoadConfig(config.ConfigName)
        end)
    end

    return TabCreator
end

-- ═══════════════════════════════════════════════════════════════════════════
-- INIT
-- ═══════════════════════════════════════════════════════════════════════════
function NexusLib:Init()
    -- Auto-load config if exists
    if self.SaveEnabled then
        pcall(function()
            LoadConfig(self.SaveFolder)
        end)
    end
end

return NexusLib
