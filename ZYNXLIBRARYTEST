		AccSec:AddColorpicker({Name="Accent principal", Default=ZNX.Theme.A, ThemeKey="A", Callback=function(c)
			ZNX:SetColor("A",c)
			ZNX:SetColor("ADim",Color3.fromRGB(math.floor(c.R*255*.35),math.floor(c.G*255*.35),math.floor(c.B*255*.35)))
			ZNX:SetColor("ABr",Color3.fromRGB(Cl(c.R*255+60,0,255),Cl(c.G*255+60,0,255),Cl(c.B*255+60,0,255)))
			ZNX:SetColor("ASel",Color3.fromRGB(math.floor(c.R*255*.14),math.floor(c.G*255*.14),math.floor(c.B*255*.14)))
			ZNX:SetColor("Scr",c)
		end})
		AccSec:AddColorpicker({Name="Accent secundario", Default=ZNX.Theme.A2, ThemeKey="A2", Callback=function(c)
			ZNX:SetColor("A2",c)
			ZNX:SetColor("A2Dim",Color3.fromRGB(math.floor(c.R*255*.35),math.floor(c.G*255*.35),math.floor(c.B*255*.35)))
		end})

		-- TEXTO
		local TxSec=ST:AddSection({Name="Texto"})
		TxSec:AddColorpicker({Name="Texto principal", Default=ZNX.Theme.TxA, ThemeKey="TxA", Callback=function(c) ZNX:SetColor("TxA",c) end})
		TxSec:AddColorpicker({Name="Texto secundario", Default=ZNX.Theme.TxB, ThemeKey="TxB", Callback=function(c) ZNX:SetColor("TxB",c) end})
		TxSec:AddColorpicker({Name="Bordas / linhas", Default=ZNX.Theme.Line, ThemeKey="Line", Callback=function(c) ZNX:SetColor("Line",c) end})

		-- PRESETS
		local PSec=ST:AddSection({Name="Presets de tema"})
		local Presets={
			["Neon Void (padrao)"]  = {A=Color3.fromRGB(160,80,255), A2=Color3.fromRGB(220,80,255), Bg0=Color3.fromRGB(7,4,15), Bg1=Color3.fromRGB(12,8,24), Bg2=Color3.fromRGB(17,12,32), Line=Color3.fromRGB(40,28,72), TxA=Color3.fromRGB(242,236,255), TxB=Color3.fromRGB(180,162,220)},
			["Electric Cyan"]       = {A=Color3.fromRGB(0,220,255), A2=Color3.fromRGB(0,160,255), Bg0=Color3.fromRGB(3,6,14), Bg1=Color3.fromRGB(5,10,22), Bg2=Color3.fromRGB(8,14,30), Line=Color3.fromRGB(18,32,66), TxA=Color3.fromRGB(230,244,255), TxB=Color3.fromRGB(140,180,220)},
			["Crimson Dark"]        = {A=Color3.fromRGB(240,55,80), A2=Color3.fromRGB(255,100,50), Bg0=Color3.fromRGB(10,3,5), Bg1=Color3.fromRGB(16,5,8), Bg2=Color3.fromRGB(22,7,12), Line=Color3.fromRGB(55,16,24), TxA=Color3.fromRGB(255,235,238), TxB=Color3.fromRGB(210,155,165)},
			["Emerald Night"]       = {A=Color3.fromRGB(40,230,120), A2=Color3.fromRGB(0,255,160), Bg0=Color3.fromRGB(3,9,5), Bg1=Color3.fromRGB(5,14,8), Bg2=Color3.fromRGB(8,20,11), Line=Color3.fromRGB(18,50,28), TxA=Color3.fromRGB(230,255,238), TxB=Color3.fromRGB(148,210,168)},
			["Solar Amber"]         = {A=Color3.fromRGB(255,185,20), A2=Color3.fromRGB(255,90,20), Bg0=Color3.fromRGB(10,6,2), Bg1=Color3.fromRGB(16,10,3), Bg2=Color3.fromRGB(22,14,5), Line=Color3.fromRGB(55,36,10), TxA=Color3.fromRGB(255,248,225), TxB=Color3.fromRGB(218,188,130)},
			["Arctic White"]        = {A=Color3.fromRGB(80,120,255), A2=Color3.fromRGB(120,80,255), Bg0=Color3.fromRGB(240,242,252), Bg1=Color3.fromRGB(224,228,245), Bg2=Color3.fromRGB(208,214,238), Line=Color3.fromRGB(170,178,220), TxA=Color3.fromRGB(18,22,48), TxB=Color3.fromRGB(70,80,130)},
		}
		local function ApplyPreset(p)
			for k,v in pairs(p) do ZNX:SetColor(k,v) end
			local a=p.A or ZNX.Theme.A
			ZNX:SetColor("ADim",Color3.fromRGB(math.floor(a.R*255*.35),math.floor(a.G*255*.35),math.floor(a.B*255*.35)))
			ZNX:SetColor("ABr", Color3.fromRGB(Cl(a.R*255+60,0,255),Cl(a.G*255+60,0,255),Cl(a.B*255+60,0,255)))
			ZNX:SetColor("ASel",Color3.fromRGB(math.floor(a.R*255*.14),math.floor(a.G*255*.14),math.floor(a.B*255*.14)))
			ZNX:SetColor("Scr",a)
			local a2=p.A2 or ZNX.Theme.A2
			ZNX:SetColor("A2Dim",Color3.fromRGB(math.floor(a2.R*255*.35),math.floor(a2.G*255*.35),math.floor(a2.B*255*.35)))
			local bg2=p.Bg2 or ZNX.Theme.Bg2
			ZNX:SetColor("Bg3",Color3.fromRGB(Cl(bg2.R*255+5,0,255),Cl(bg2.G*255+5,0,255),Cl(bg2.B*255+5,0,255)))
			ZNX:SetColor("Bg4",Color3.fromRGB(Cl(bg2.R*255+10,0,255),Cl(bg2.G*255+10,0,255),Cl(bg2.B*255+10,0,255)))
			ZNX:SetColor("BgI",Color3.fromRGB(Cl(bg2.R*255-5,0,255),Cl(bg2.G*255-5,0,255),Cl(bg2.B*255-5,0,255)))
		end
		for pn,pd in pairs(Presets) do
			PSec:AddButton({Name=pn, Callback=function() ApplyPreset(pd); ZNX:Notify({Title="Preset",Message=pn,Duration=2,Type="ok"}) end})
		end
		PSec:AddButton({Name="Resetar tema", Callback=function()
			for k,v in pairs(DT) do ZNX.Theme[k]=v end; ApplyTheme()
			ZNX:Notify({Title="Tema resetado",Duration=2,Type="info"})
		end})

		-- PACKET DETECTOR
		local PktSec=ST:AddSection({Name="Packet Detector"})
		PktSec:AddToggle({Name="Monitorar pacotes suspeitos", Default=false, Save=true, Flag="PktOn",
			Callback=function(v) if v then PKD:start() else PKD:stop() end end})
		PktSec:AddSlider({Name="Limite de tamanho", Min=1, Max=50, Increment=1, Default=5, Suffix="KB", Save=true, Flag="PktKB",
			Callback=function(v) PKD.KB_THRESHOLD=v; PKD.BYTE_THRESHOLD=v*1024 end})
		PktSec:AddSlider({Name="Cooldown entre alertas", Min=5, Max=120, Increment=5, Default=30, Suffix="s", Save=true, Flag="PktCD",
			Callback=function(v) PKD.COOLDOWN=v end})
		PktSec:AddButton({Name="Testar detector", Callback=function()
			task.spawn(function()
				task.wait(.3)
				PKD:showNotification and PKD:showNotification(LP,0.01,{},"Teste") or
				ZNX:Notify({Title="Pacote suspeito detectado",Message="De: "..LP.DisplayName.."\nTamanho: 0.010 MB\nRemote: Teste",Duration=8,Type="danger"})
			end)
		end})

		-- SAVE / LOAD
		local CfgSec=ST:AddSection({Name="Salvar e carregar"})
		local nameBox=CfgSec:AddTextbox({Name="Nome do perfil", Default=wCfg.ConfigName, Placeholder="nome_do_perfil"})
		CfgSec:AddButton({Name="Salvar configuracao", Callback=function()
			local n=nameBox:Get(); if not n or n=="" then n=wCfg.ConfigName end
			sDb=0; SaveCfg(n,false)
		end})
		CfgSec:AddButton({Name="Carregar configuracao", Callback=function()
			local n=nameBox:Get(); if not n or n=="" then n=wCfg.ConfigName end
			local ok=LoadCfg(n,false)
			if not ok then ZNX:Notify({Title="Perfil nao encontrado",Message=n..".json",Duration=3,Type="err"}) end
		end})
		CfgSec:AddButton({Name="Apagar configuracao", Callback=function()
			local n=nameBox:Get(); if not n or n=="" then n=wCfg.ConfigName end
			local ok=SS2:Delete(n)
			ZNX:Notify({Title=ok and "Apagado" or "Erro ao apagar",Message=n,Duration=3,Type=ok and "ok" or "err"})
		end})
		local profDD=CfgSec:AddDropdown({Name="Perfis disponiveis", Options={"(nenhum)"}, Default="(nenhum)",
			Callback=function(v) if v~="(nenhum)" then nameBox:Set(v) end end})
		CfgSec:AddButton({Name="Atualizar lista de perfis", Callback=function()
			local p=SS2:List(); if #p==0 then p={"(nenhum)"} end
			profDD:Refresh(p,true)
			ZNX:Notify({Title=string.format("%d perfil(s)",#p),Duration=2,Type="info"})
		end})

		-- MISC
		local MiscSec=ST:AddSection({Name="Misc"})
		MiscSec:AddDropdown({Name="Posicao das notificacoes", Options={"BottomRight","BottomLeft","TopRight","TopLeft"}, Default=ZNX.NPos,
			Save=true, Flag="NPos", Callback=function(v) ZNX:SetNotifyPosition(v) end})
		MiscSec:AddBind({Name="Tecla para abrir/fechar", Default=Enum.KeyCode[wCfg.ToggleKey] or Enum.KeyCode.M, Callback=function()end})

		-- INFO
		local InfoSec=ST:AddSection({Name="Informacoes"})
		InfoSec:AddLabel("Jogador: "..LP.DisplayName.." (@"..LP.Name..")")
		InfoSec:AddLabel("UID: "..LP.UserId)
		InfoSec:AddLabel("ZNXHUB v5.3  Neon Void")
		InfoSec:AddLabel("Diretorio: "..ZNX.SaveDir.."/")
		local pdlbl=InfoSec:AddLabel("Packet Detector: "..(PKD.Active and "Ativo" or "Inativo"))
		task.spawn(function()
			while Alive() do task.wait(2)
				pdlbl:Set("Packet Detector: "..(PKD.Active and "Ativo" or "Inativo"))
			end
		end)
	end

	BuildSettings()
	if wCfg.SaveConfig then task.defer(function() task.wait(.6); LoadCfg(wCfg.ConfigName,true) end) end
	return TabFn
end

function ZNX:Init() end
return ZNX
