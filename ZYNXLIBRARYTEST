					Tween(card, TweenCache.Fast, { BackgroundColor3 = T.BgHover }):Play()
				end)

				Connect(Btn.MouseLeave, function()
					Tween(card, TweenCache.Fast, { BackgroundColor3 = T.BgCard }):Play()
				end)

				Slider:Set(Slider.Value)
				if sCfg.Flag then NexusLib.Flags[sCfg.Flag] = Slider end
				return Slider
			end

