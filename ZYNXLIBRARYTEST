-- ═══════════════════════════════════════════════════════════════
-- CONFIG SAVE/LOAD (baseado no seu OrionLib)
-- ═══════════════════════════════════════════════════════════════
local saveDebounce = 0
local savePending = false

local function SaveConfig(name)
	if not NexusLib.SaveEnabled or not writefile then return end
	
	local now = tick()
	if now - saveDebounce < 2 then
		if not savePending then
			savePending = true
			task.delay(2, function()
				savePending = false
				SaveConfig(name)
			end)
		end
		return
	end
	saveDebounce = now
	
	task.spawn(function()
		if not isfolder then return end
		if not isfolder(NexusLib.SaveFolder) then
			makefolder(NexusLib.SaveFolder)
		end
		
		local data = { Flags = {}, Theme = {} }
		
		for k, flag in pairs(NexusLib.Flags) do
			if flag.Save then
				if flag.Type == "Colorpicker" then
					data.Flags[k] = {
						Type = "ColorPicker",
						Value = ColorPack(flag.Value)
					}
				else
					data.Flags[k] = {
						Type = flag.Type or "Unknown",
						Value = flag.Value
					}
				end
			end
		end
		
		for k, v in pairs(NexusLib.Theme) do
			if typeof(v) == "Color3" then
				data.Theme[k] = ColorPack(v)
			end
		end
		
		pcall(writefile, NexusLib.SaveFolder.."/"..name..".json", HttpService:JSONEncode(data))
	end)
end

local function LoadConfig(name)
	if not readfile or not isfile then return end
	local path = NexusLib.SaveFolder.."/"..name..".json"
	if not isfile(path) then return end
	
	local ok, data = pcall(function()
		return HttpService:JSONDecode(readfile(path))
	end)
	if not ok then return end
	
	-- Load flags
	task.defer(function()
		for k, fd in pairs(data.Flags or {}) do
			if NexusLib.Flags[k] then
				task.spawn(function()
					if fd.Type == "ColorPicker" and fd.Value then
						NexusLib.Flags[k]:Set(ColorUnpack(fd.Value))
					elseif fd.Value ~= nil then
						NexusLib.Flags[k]:Set(fd.Value)
					end
				end)
			end
		end
	end)
end

