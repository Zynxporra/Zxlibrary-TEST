		})

		local CfgSec = ST:AddSection({ Name = "CONFIG" })

		CfgSec:AddButton({
			Name = "Save Config",
			Callback = function()
				saveDebounce = 0
				SaveConfig(cfg.ConfigName)
				NexusLib:Notify({
					Title = "Config Saved",
					Message = "Saved to "..NexusLib.SaveFolder.."/"..cfg.ConfigName..".json",
					Duration = 4
				})
			end,
		})

		CfgSec:AddBind({
			Name = "Toggle Key",
			Default = Enum.KeyCode[cfg.ToggleKey] or Enum.KeyCode.RightShift,
			Callback = function(key)
				cfg.ToggleKey = key
				NexusLib:Notify({
					Title = "Toggle Key Changed",
					Message = "New key: " .. key,
					Duration = 3
				})
			end,
			Flag = "ToggleKey",
			Save = true,
		})
	end

	CreateSettingsTab()

	if cfg.SaveConfig then
		task.defer(function()
			LoadConfig(cfg.ConfigName)
		end)
	end

	return TabFunction
end

return NexusLib
