-- ── THEME BINDING SYSTEM ─────────────────────────────────────────────
local function Bind(obj,prop,key,fn)
    if not obj or not prop or not key then return obj end
    table.insert(NL._Watchers,{obj=obj,prop=prop,key=key,fn=fn})
    local v=NL.Theme[key]
    if v~=nil then pcall(function() obj[prop]=fn and fn(v) or v end) end
    return obj
end
local function BindFn(fn) table.insert(NL._WatcherFns,fn); pcall(fn) end
local function ApplyTheme()
    local T=NL.Theme
    for _,w in ipairs(NL._Watchers) do
        if w.obj and w.obj.Parent then
            local v=T[w.key]
            if v~=nil then pcall(function() w.obj[w.prop]=w.fn and w.fn(v) or v end) end
        end
    end
    for _,fn in ipairs(NL._WatcherFns) do pcall(fn) end
end
function NL:SetColor(key,val) NL.Theme[key]=val; ApplyTheme() end
function NL:SetTheme(tbl) for k,v in pairs(tbl) do NL.Theme[k]=v end; ApplyTheme() end

