			-- BIND (do seu Orion)
			function E:AddBind(bCfg)
				bCfg = bCfg or {}
				bCfg.Name = bCfg.Name or "Keybind"
				bCfg.Default = bCfg.Default or Enum.KeyCode.Unknown
				bCfg.Hold = bCfg.Hold or false
				bCfg.Callback = bCfg.Callback or function() end
				bCfg.Flag = bCfg.Flag or nil
				bCfg.Save = bCfg.Save or false

				local Blacklist = {
					Enum.KeyCode.Unknown, Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D,
					Enum.KeyCode.Slash, Enum.KeyCode.Tab, Enum.KeyCode.Backspace, Enum.KeyCode.Escape,
					Enum.KeyCode.Up, Enum.KeyCode.Down, Enum.KeyCode.Left, Enum.KeyCode.Right
				}

				local function InBlacklist(k)
					for _, v in pairs(Blacklist) do
						if v == k then return true end
					end
					return false
				end

				local Bind = {
					Value = bCfg.Default.Name or tostring(bCfg.Default),
					Binding = false,
					Holding = false,
					Type = "Bind",
					Save = bCfg.Save
				}

				local card = New("Frame", {
					Parent = parent,
					Size = UDim2.new(1, 0, 0, 38),
					BackgroundColor3 = T.BgCard,
					BorderSizePixel = 0,
				}, {
					New("UICorner", { CornerRadius = UDim.new(0, 6) }),
					New("UIStroke", { Color = T.Stroke, Thickness = 1 }),
				})

				New("TextLabel", {
					Parent = card,
					Position = UDim2.new(0, 12, 0, 0),
					Size = UDim2.new(1, -100, 1, 0),
					BackgroundTransparency = 1,
					Text = bCfg.Name,
					Font = Enum.Font.GothamBold,
					TextSize = 14,
					TextColor3 = T.Text,
					TextXAlignment = Enum.TextXAlignment.Left,
				})

				local keyBox = New("Frame", {
					Parent = card,
					Position = UDim2.new(1, -82, 0.5, -13),
					Size = UDim2.new(0, 70, 0, 26),
					BackgroundColor3 = T.Main,
					BorderSizePixel = 0,
				}, {
					New("UICorner", { CornerRadius = UDim.new(0, 5) }),
					New("UIStroke", { Color = T.Divider, Thickness = 1 }),
				})

				local keyLbl = New("TextLabel", {
					Parent = keyBox,
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = Bind.Value,
					Font = Enum.Font.GothamBold,
					TextSize = 12,
					TextColor3 = T.Accent,
					TextXAlignment = Enum.TextXAlignment.Center,
				})

				local Btn = New("TextButton", {
					Parent = card,
					Size = UDim2.new(1, 0, 1, 0),
					BackgroundTransparency = 1,
					Text = "",
					AutoButtonColor = false,
				})

				Connect(Btn.InputEnded, function(inp)
					if inp.UserInputType == Enum.UserInputType.MouseButton1 and not Bind.Binding then
						Bind.Binding = true
						keyLbl.Text = "..."
						Tween(keyBox:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = T.Accent }):Play()
					end
				end})

				Connect(UserInputService.InputBegan, function(inp, gp)
					if gp then return end
					if Bind.Binding then
						local Key
						pcall(function()
							if not InBlacklist(inp.KeyCode) then
								Key = inp.KeyCode
							end
						end)
						Key = Key or Bind.Value
						Bind:Set(Key)
						Tween(keyBox:FindFirstChildOfClass("UIStroke"), TweenCache.Fast, { Color = T.Divider }):Play()
						SaveConfig(cfg.ConfigName)
					elseif inp.KeyCode.Name == Bind.Value or inp.UserInputType.Name == Bind.Value then
						if bCfg.Hold then
							Bind.Holding = true
							bCfg.Callback(true)
						else
							bCfg.Callback()
						end
					end
				end})

				Connect(UserInputService.InputEnded, function(inp)
					if (inp.KeyCode.Name == Bind.Value or inp.UserInputType.Name == Bind.Value) and bCfg.Hold and Bind.Holding then
						Bind.Holding = false
						bCfg.Callback(false)
					end
				end})

				function Bind:Set(k)
					Bind.Binding = false
					Bind.Value = (type(k) == "string") and k or (k.Name or tostring(k))
					keyLbl.Text = Bind.Value
				end

				Bind:Set(bCfg.Default)
				if bCfg.Flag then NexusLib.Flags[bCfg.Flag] = Bind end
				return Bind
			end

