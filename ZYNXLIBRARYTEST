		-- Infos do usuário em rodapé da aba settings
		local Info=ST:AddSection({Name="sessao"})
		Info:AddLabel("user: "..LP.Name.." / "..LP.DisplayName)
		Info:AddLabel("uid:  "..LP.UserId)
	end

