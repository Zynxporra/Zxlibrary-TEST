            -- KEYBIND
            function EF:AddBind(BC2)
                BC2=BC2 or {}; BC2.Name=BC2.Name or "Keybind"
                BC2.Default=BC2.Default or Enum.KeyCode.Unknown
                BC2.Hold=BC2.Hold or false; BC2.Callback=BC2.Callback or function() end
                BC2.Flag=BC2.Flag or nil; BC2.Save=BC2.Save or false

                local BLst={Enum.KeyCode.Unknown,Enum.KeyCode.W,Enum.KeyCode.A,Enum.KeyCode.S,
                    Enum.KeyCode.D,Enum.KeyCode.Slash,Enum.KeyCode.Tab,Enum.KeyCode.Backspace,
                    Enum.KeyCode.Escape,Enum.KeyCode.Up,Enum.KeyCode.Down,Enum.KeyCode.Left,Enum.KeyCode.Right}
                local function InBL(k) for _,v in pairs(BLst) do if v==k then return true end end end

                local Bnd={Value="",Binding=false,Holding=false,Type="Bind",Save=BC2.Save}
                Bnd.Value=type(BC2.Default)=="userdata" and BC2.Default.Name or tostring(BC2.Default)

                local card=MkCard(36); local click=ClickBtn(card); HoverCard(card,click)
                MkTitle(card,BC2.Name,12,0,-90)
                local KBg=New("Frame",{Parent=card,Position=UDim2.new(1,-82,0.5,-13),
                    Size=UDim2.new(0,70,0,26),BackgroundColor3=NL.Theme.InputBg,
                    BorderSizePixel=0,ZIndex=22},{Crn(5),Str(NL.Theme.Border,1)})
                Bind(KBg,"BackgroundColor3","InputBg")
                local KSt=KBg:FindFirstChildOfClass("UIStroke"); Bind(KSt,"Color","Border")
                local KLbl=New("TextLabel",{Parent=KBg,Size=UDim2.new(1,0,1,0),ZIndex=23,
                    BackgroundTransparency=1,Text=Bnd.Value,Font=Enum.Font.GothamBold,TextSize=12,
                    TextColor3=NL.Theme.Accent,TextXAlignment=Enum.TextXAlignment.Center})
                Bind(KLbl,"TextColor3","Accent")

                Conn(click.InputEnded,function(inp)
                    if inp.UserInputType==Enum.UserInputType.MouseButton1 and not Bnd.Binding then
                        Bnd.Binding=true; KLbl.Text="..."
                        Tw(KSt,TI.Fast,{Color=NL.Theme.Accent})
                    end
                end)
                Conn(UIS.InputBegan,function(inp,gp)
                    if gp then return end
                    if Bnd.Binding then
                        local Key=nil
                        pcall(function() if not InBL(inp.KeyCode) then Key=inp.KeyCode end end)
                        Key=Key or Enum.KeyCode.Unknown; Bnd:Set(Key)
                        Tw(KSt,TI.Fast,{Color=NL.Theme.Border}); Save(WC.ConfigName)
                    elseif inp.KeyCode.Name==Bnd.Value or inp.UserInputType.Name==Bnd.Value then
                        if BC2.Hold then Bnd.Holding=true; BC2.Callback(true) else BC2.Callback() end
                    end
                end)
                Conn(UIS.InputEnded,function(inp)
                    if (inp.KeyCode.Name==Bnd.Value or inp.UserInputType.Name==Bnd.Value)
                    and BC2.Hold and Bnd.Holding then Bnd.Holding=false; BC2.Callback(false) end
                end)
                function Bnd:Set(k)
                    Bnd.Binding=false
                    Bnd.Value=type(k)=="string" and k or (k and k.Name or "Unknown")
                    KLbl.Text=Bnd.Value
                end
                Bnd:Set(BC2.Default)
                if BC2.Flag then NL.Flags[BC2.Flag]=Bnd end
                return Bnd
            end

