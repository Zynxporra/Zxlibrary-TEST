                local Hdr=New("Frame",{Parent=Outer,Size=UDim2.new(1,0,0,36),BackgroundTransparency=1,ZIndex=21})
                MkTitle(Hdr,DC.Name,12,0,-100)
                local SelLbl=New("TextLabel",{Parent=Hdr,Position=UDim2.new(1,-98,0,0),
                    Size=UDim2.new(0,66,1,0),ZIndex=22,BackgroundTransparency=1,
                    Text=tostring(DD.Value),Font=Enum.Font.GothamMedium,TextSize=13,
                    TextColor3=NL.Theme.Accent,TextXAlignment=Enum.TextXAlignment.Right,
                    TextTruncate=Enum.TextTruncate.AtEnd})
                Bind(SelLbl,"TextColor3","Accent")
                local Arrow=New("ImageLabel",{Parent=Hdr,Position=UDim2.new(1,-22,0.5,-9),
                    Size=UDim2.new(0,18,0,18),BackgroundTransparency=1,
                    Image="rbxassetid://7072706796",ImageColor3=NL.Theme.TextDim,ZIndex=22})
                Bind(Arrow,"ImageColor3","TextDim")
                local Sep=New("Frame",{Parent=Outer,Position=UDim2.new(0,0,0,36),
                    Size=UDim2.new(1,0,0,1),BackgroundColor3=NL.Theme.Border,
                    BorderSizePixel=0,ZIndex=21,Visible=false})
                Bind(Sep,"BackgroundColor3","Border")

                local OptSF=MkScroll(Outer,UDim2.new(1,0,1,-37),UDim2.new(0,0,0,37)); OptSF.ZIndex=21
                local OL=List(2); OL.Parent=OptSF; Pad(4,6,4,6).Parent=OptSF; AutoCV(OptSF,OL)

                local function Rebuild()
                    for _,b in pairs(DD.Buttons) do if b and b.Parent then b:Destroy() end end
                    DD.Buttons={}
                    for _,opt in ipairs(DD.Options) do
                        local isSel=opt==DD.Value
                        local ob=New("TextButton",{Parent=OptSF,Size=UDim2.new(1,0,0,28),
                            BackgroundColor3=isSel and Tint(NL.Theme.Accent,NL.Theme.CardBg,0.88) or NL.Theme.WinBgAlt,
                            BorderSizePixel=0,Text="",AutoButtonColor=false,ZIndex=22},{Crn(5)})
                        if isSel then
                            New("Frame",{Parent=ob,Position=UDim2.new(0,4,0.5,-5),
                                Size=UDim2.new(0,3,0,10),BackgroundColor3=NL.Theme.Accent,BorderSizePixel=0,ZIndex=23},{Crn(1)})
                        end
                        local ol=New("TextLabel",{Parent=ob,Position=UDim2.new(0,isSel and 12 or 8,0,0),
                            Size=UDim2.new(1,-16,1,0),ZIndex=23,BackgroundTransparency=1,
                            Text=tostring(opt),Font=isSel and Enum.Font.GothamBold or Enum.Font.GothamMedium,
                            TextSize=13,TextColor3=isSel and NL.Theme.Accent or NL.Theme.Text,
                            TextXAlignment=Enum.TextXAlignment.Left})
                        Conn(ob.MouseEnter,function() Tw(ob,TI.Fast,{BackgroundColor3=NL.Theme.CardHover}) end)
                        Conn(ob.MouseLeave,function()
                            Tw(ob,TI.Fast,{BackgroundColor3=opt==DD.Value
                                and Tint(NL.Theme.Accent,NL.Theme.CardBg,0.88) or NL.Theme.WinBgAlt})
                        end)
                        Conn(ob.MouseButton1Up,function()
                            PlaySFX("Click",0.2); DD:Set(opt); Save(WC.ConfigName)
                        end)
                        DD.Buttons[opt]=ob
                    end
                end

                function DD:Set(val)
                    DD.Value=table.find(DD.Options,val) and val or (DD.Options[1] or "None")
                    SelLbl.Text=tostring(DD.Value); Rebuild()
                    DC.Callback(DD.Value)
                end
                function DD:Refresh(opts,clear)
                    if clear then DD.Options={} end
                    for _,o in ipairs(opts) do if not table.find(DD.Options,o) then table.insert(DD.Options,o) end end
                    if not table.find(DD.Options,DD.Value) then DD.Value=DD.Options[1] or "None" end
                    Rebuild(); SelLbl.Text=tostring(DD.Value)
                end

                local HBtn=ClickBtn(Hdr,26)
                Conn(HBtn.MouseEnter,function() Tw(Outer,TI.Fast,{BackgroundColor3=NL.Theme.CardHover}) end)
                Conn(HBtn.MouseLeave,function() Tw(Outer,TI.Fast,{BackgroundColor3=NL.Theme.CardBg}) end)
                Conn(HBtn.MouseButton1Up,function()
                    DD.Toggled=not DD.Toggled; Sep.Visible=DD.Toggled
                    Tw(Arrow,TI.Fast,{Rotation=DD.Toggled and 180 or 0})
                    local n=math.min(#DD.Options,DC.MaxShown)
                    Tw(Outer,TI.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,36+n*30+8) or UDim2.new(1,0,0,36)})
                    PlaySFX("Click",0.2)
                end)

                Rebuild(); DD:Set(DD.Value)
                if DC.Flag then NL.Flags[DC.Flag]=DD end
                return DD
            end

