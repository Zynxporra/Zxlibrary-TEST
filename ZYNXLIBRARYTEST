				end)
				C(UIS.InputBegan,function(i,gp)
					if gp then return end
					if BO.Binding then
						local K; pcall(function() if not InBL(i.KeyCode) then K=i.KeyCode end end); K=K or BO.Value
						BO:Set(K); Tw(kbg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Line})
						if bCfg.Save then SaveCfg(wCfg.ConfigName,true) end
					elseif i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value then
						if bCfg.Hold then BO.Holding=true; bCfg.Callback(true) else bCfg.Callback() end
					end
				end)
				C(UIS.InputEnded,function(i)
					if(i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value)and bCfg.Hold and BO.Holding then
						BO.Holding=false; bCfg.Callback(false)
					end
				end)
				function BO:Set(k) BO.Binding=false; BO.Value=(type(k)=="string") and k or(k.Name or tostring(k)); kl.Text=BO.Value end
				BO:Set(bCfg.Default); reg(c,bCfg.Name); if bCfg.Flag then ZNX.Flags[bCfg.Flag]=BO end; return BO
			end

