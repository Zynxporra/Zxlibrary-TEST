-- SISTEMA DE SAVE/LOAD ROBUSTO
-- ═══════════════════════════════════════════════════════════════
local SaveSystem = {}

function SaveSystem:EnsureDir()
	if isfolder and not isfolder(ZNX.SaveDir) then
		pcall(makefolder, ZNX.SaveDir)
	end
end

function SaveSystem:Write(name, data)
	if not writefile then return false end
	self:EnsureDir()
	local path = ZNX.SaveDir .. "/" .. name .. ".json"
	local ok, err = pcall(writefile, path, HTTP:JSONEncode(data))
	return ok
end

function SaveSystem:Read(name)
	if not readfile or not isfile then return nil end
	local path = ZNX.SaveDir .. "/" .. name .. ".json"
	if not isfile(path) then return nil end
	local ok, data = pcall(function()
		return HTTP:JSONDecode(readfile(path))
	end)
	return ok and data or nil
end

function SaveSystem:Delete(name)
	if not delfile then return false end
	local path = ZNX.SaveDir .. "/" .. name .. ".json"
	local ok = pcall(delfile, path)
	return ok
end

function SaveSystem:ListProfiles()
	if not listfiles or not isfolder then return {} end
	local profiles = {}
	if not isfolder(ZNX.SaveDir) then return profiles end
	for _, f in ipairs(listfiles(ZNX.SaveDir)) do
		local name = f:match("([^/\\]+)%.json$")
		if name then table.insert(profiles, name) end
	end
	return profiles
end

