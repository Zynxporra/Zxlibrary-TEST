	-- Resize logic
	local resizing = false
	local resizeStart, resizeSize

	Connect(ResizeBtn.InputBegan, function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then
			resizing = true
			resizeStart = Vector2.new(inp.Position.X, inp.Position.Y)
			resizeSize = Vector2.new(Win.AbsoluteSize.X, Win.AbsoluteSize.Y)
		end
	end)

	Connect(UserInputService.InputChanged, function(inp)
		if resizing and inp.UserInputType == Enum.UserInputType.MouseMovement then
			local delta = Vector2.new(inp.Position.X, inp.Position.Y) - resizeStart
			local newWidth = math.clamp(resizeSize.X + delta.X, cfg.MinSize.X, cfg.MaxSize.X)
			local newHeight = math.clamp(resizeSize.Y + delta.Y, cfg.MinSize.Y, cfg.MaxSize.Y)
			Win.Size = UDim2.new(0, newWidth, 0, newHeight)
			MinimizedSize = UDim2.new(0, math.max(300, #cfg.Title * 14 + 200), 0, T.TopbarHeight)
		end
	end)

