						TPlay(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,38 + (Options * 45)) or UDim2.new(1,0,0,38)})
					end
				end)

				if dCfg.Flag then NexusLib.Flags[dCfg.Flag] = DD end
				return DD
			end

