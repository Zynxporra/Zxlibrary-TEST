	-- ABA SETTINGS EMBUTIDA
	-- ══════════════════════════════════════════════════════════
	local function BuildSettings()
		local ST=TabFn:MakeTab({Name="settings",Icon=""})

		local App=ST:AddSection({Name="aparencia"})
		App:AddColorpicker({Name="fundo",Default=ZNX.Theme.Bg,Callback=function(c) ZNX:SetColor("Bg",c) end})
		App:AddColorpicker({Name="painel",Default=ZNX.Theme.Panel,Callback=function(c) ZNX:SetColor("Panel",c) end})
		App:AddColorpicker({Name="linha/item",Default=ZNX.Theme.Row,Callback=function(c)
			ZNX:SetColor("Row",c); ZNX:SetColor("RowHov",Color3.fromRGB(math.min(255,c.R*255+8),math.min(255,c.G*255+8),math.min(255,c.B*255+8)))
			ZNX:SetColor("Input",Color3.fromRGB(math.max(0,c.R*255-6),math.max(0,c.G*255-6),math.max(0,c.B*255-6)))
		end})
		App:AddSlider({Name="opacidade bg imagem",Min=0,Max=100,Increment=5,Default=math.floor((1-wCfg.BgImageAlpha)*100),Suffix="%",Callback=function(v) local t=1-(v/100); BgImg.ImageTransparency=t; BgDim.BackgroundTransparency=0.25+t*.5 end})

		local Acc=ST:AddSection({Name="accent"})
		Acc:AddColorpicker({Name="cor accent",Default=ZNX.Theme.Acc,Callback=function(c)
			ZNX:SetColor("Acc",c); ZNX:SetColor("AccDim",Color3.fromRGB(math.floor(c.R*255*.47),math.floor(c.G*255*.47),math.floor(c.B*255*.47))); ZNX:SetColor("AccGlow",Color3.fromRGB(math.min(255,c.R*255+60),math.min(255,c.G*255+60),math.min(255,c.B*255+60)))
		end})

		local PS=ST:AddSection({Name="presets"})
		local Presets={
			["terminal orange"]={Bg=Color3.fromRGB(6,6,8),Panel=Color3.fromRGB(10,10,13),Row=Color3.fromRGB(14,14,18),Acc=Color3.fromRGB(255,140,0),Line=Color3.fromRGB(28,28,36)},
			["terminal green"]={Bg=Color3.fromRGB(3,8,4),Panel=Color3.fromRGB(5,12,6),Row=Color3.fromRGB(8,16,9),Acc=Color3.fromRGB(0,220,80),Line=Color3.fromRGB(14,36,16)},
			["terminal red"]={Bg=Color3.fromRGB(8,3,3),Panel=Color3.fromRGB(13,5,5),Row=Color3.fromRGB(18,8,8),Acc=Color3.fromRGB(220,50,50),Line=Color3.fromRGB(40,14,14)},
			["terminal blue"]={Bg=Color3.fromRGB(3,5,10),Panel=Color3.fromRGB(5,8,16),Row=Color3.fromRGB(8,12,22),Acc=Color3.fromRGB(60,160,255),Line=Color3.fromRGB(16,26,50)},
			["terminal white"]={Bg=Color3.fromRGB(240,240,235),Panel=Color3.fromRGB(228,228,222),Row=Color3.fromRGB(215,215,208),Acc=Color3.fromRGB(180,80,0),Line=Color3.fromRGB(190,188,180),TxtA=Color3.fromRGB(20,18,14),TxtB=Color3.fromRGB(90,88,80),TxtC=Color3.fromRGB(150,148,140)},
		}
		for pName,pData in pairs(Presets) do
			PS:AddButton({Name=pName,Callback=function()
				for k2,v2 in pairs(pData) do ZNX:SetColor(k2,v2) end
				local a=pData.Acc or ZNX.Theme.Acc; ZNX:SetColor("AccDim",Color3.fromRGB(math.floor(a.R*255*.47),math.floor(a.G*255*.47),math.floor(a.B*255*.47))); ZNX:SetColor("AccGlow",Color3.fromRGB(math.min(255,a.R*255+60),math.min(255,a.G*255+60),math.min(255,a.B*255+60)))
				local r=pData.Row or ZNX.Theme.Row; ZNX:SetColor("RowHov",Color3.fromRGB(math.min(255,r.R*255+8),math.min(255,r.G*255+8),math.min(255,r.B*255+8))); ZNX:SetColor("Input",Color3.fromRGB(math.max(0,r.R*255-6),math.max(0,r.G*255-6),math.max(0,r.B*255-6))); ZNX:SetColor("RowSel",Color3.fromRGB(math.floor(a.R*255*.12),math.floor(a.G*255*.12),math.floor(a.B*255*.12)))
				ZNX:Notify({Title="PRESET",Message=pName,Duration=3})
			end})
		end

		local Cfg=ST:AddSection({Name="config"})
		Cfg:AddButton({Name="salvar config",Callback=function() sDb=0; SaveCfg(wCfg.ConfigName); ZNX:Notify({Title="SALVO",Message=ZNX.SaveDir.."/"..wCfg.ConfigName..".json",Duration=4}) end})
		Cfg:AddButton({Name="resetar tema",Callback=function() for k2,v2 in pairs(DT) do ZNX.Theme[k2]=v2 end; ApplyTheme(); ZNX:Notify({Title="RESET",Message="tema padrao restaurado",Duration=3}) end})
