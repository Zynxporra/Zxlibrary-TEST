            Callback=function(url) if url~="(empty)" then Nexus:Set("BgUrl",url) end end})
        BgSec:AddButton({Name="Clear Background",Callback=function()
            Nexus:Set("BgUrl","")
            Nexus:Notify({Title="Background Cleared",Message="Window background removed.",Type="info",Duration=3})
        end})
        BgSec:AddButton({Name="Remove from Library",Desc="Removes the current URL from saved list",Callback=function()
            local url=Nexus.Theme.BgUrl
            for i,v in ipairs(Nexus._BgLib) do
                if v==url then
                    table.remove(Nexus._BgLib,i)
                    if BgDropRef then BgDropRef:Refresh(#Nexus._BgLib>0 and Nexus._BgLib or {"(empty)"},true) end
                    SaveCfg(WC.ConfigName)
                    Nexus:Notify({Title="Removed",Message="URL removed from library.",Type="warning",Duration=3}); return
                end
            end
            Nexus:Notify({Title="Not Found",Message="Current URL is not in library.",Type="error",Duration=3})
        end})

        -- PRESETS
        local PreSec=ST:AddSection({Name="Theme Presets"})
        local Presets={
            {N="Neon Teal",  D={WinBg=C3(10,10,15),TopbarBg=C3(8,8,13),SidebarBg=C3(9,9,14),CardBg=C3(18,18,28),Border=C3(35,37,58),Accent=C3(0,210,175),TextH1=C3(240,242,255),Text=C3(170,173,200)}},
            {N="Crimson",    D={WinBg=C3(12,6,6),TopbarBg=C3(9,4,4),SidebarBg=C3(10,5,5),CardBg=C3(22,10,10),Border=C3(60,22,22),Accent=C3(220,55,55),TextH1=C3(255,235,235),Text=C3(185,155,155)}},
            {N="Blue Surge", D={WinBg=C3(6,8,18),TopbarBg=C3(4,6,14),SidebarBg=C3(5,7,16),CardBg=C3(10,14,30),Border=C3(28,38,80),Accent=C3(70,140,255),TextH1=C3(230,235,255),Text=C3(155,165,215)}},
            {N="Golden Hour",D={WinBg=C3(16,11,5),TopbarBg=C3(11,7,3),SidebarBg=C3(12,8,4),CardBg=C3(26,18,8),Border=C3(65,45,16),Accent=C3(255,190,40),TextH1=C3(255,248,225),Text=C3(195,170,130)}},
            {N="Void Purple",D={WinBg=C3(9,6,16),TopbarBg=C3(7,4,12),SidebarBg=C3(8,5,14),CardBg=C3(16,10,28),Border=C3(45,28,75),Accent=C3(165,90,255),TextH1=C3(240,232,255),Text=C3(170,150,215)}},
            {N="Forest",     D={WinBg=C3(6,12,8),TopbarBg=C3(4,9,5),SidebarBg=C3(5,10,6),CardBg=C3(10,20,12),Border=C3(24,50,28),Accent=C3(60,200,100),TextH1=C3(220,255,228),Text=C3(140,185,150)}},
            {N="Cyber Pink", D={WinBg=C3(14,6,12),TopbarBg=C3(10,4,9),SidebarBg=C3(12,5,10),CardBg=C3(22,10,20),Border=C3(60,22,55),Accent=C3(255,60,200),TextH1=C3(255,228,250),Text=C3(195,148,190)}},
            {N="Arctic",     D={WinBg=C3(238,240,250),TopbarBg=C3(220,224,240),SidebarBg=C3(228,232,245),CardBg=C3(248,250,255),Border=C3(195,200,225),Accent=C3(50,120,255),TextH1=C3(30,32,52),Text=C3(90,95,135),TrackOff=C3(180,185,215)}},
            {N="Lava",       D={WinBg=C3(15,8,5),TopbarBg=C3(11,5,3),SidebarBg=C3(12,6,4),CardBg=C3(28,14,8),Border=C3(70,30,15),Accent=C3(255,120,30),TextH1=C3(255,240,220),Text=C3(200,165,130)}},
            {N="Ocean",      D={WinBg=C3(4,10,18),TopbarBg=C3(3,7,14),SidebarBg=C3(4,9,16),CardBg=C3(6,16,30),Border=C3(15,40,70),Accent=C3(30,180,255),TextH1=C3(215,240,255),Text=C3(130,175,220)}},
        }
        for _,preset in ipairs(Presets) do
            PreSec:AddButton({Name=preset.N,Callback=function()
                Nexus:SetTheme(preset.D)
                local a=preset.D.Accent or Nexus.Theme.Accent
                Nexus:Set("AccentBright",Lighten(a,0.15)); Nexus:Set("AccentDim",Darken(a,0.25))
                Nexus:Set("AccentAlpha",Darken(a,0.68)); Nexus:Set("TrackOn",Darken(a,0.12)); Nexus:Set("ScrollBar",a)
                local bg=preset.D.CardBg or Nexus.Theme.CardBg
                Nexus:Set("CardHov",Lighten(bg,0.07)); Nexus:Set("CardAct",Lighten(bg,0.03)); Nexus:Set("InputBg",Darken(bg,0.05))
                local w=preset.D.WinBg or Nexus.Theme.WinBg; Nexus:Set("WinBgAlt",Lighten(w,0.05))
                local br=preset.D.Border or Nexus.Theme.Border; Nexus:Set("BorderBright",Lighten(br,0.15))
                Nexus:Notify({Title="Preset: "..preset.N,Message="Theme applied successfully.",Type="success",Duration=3})
            end})
        end

        -- CONFIG
        local CfgSec=ST:AddSection({Name="Config"})
        CfgSec:AddButton({Name="💾  Save Config",Desc="Saves all flags and current theme",Callback=function()
            _sl=0; DoSave(WC.ConfigName)
            Nexus:Notify({Title="Saved",Message=Nexus.SaveDir.."/"..WC.ConfigName..".json",Type="success",Duration=4})
        end})
        CfgSec:AddButton({Name="🔄  Reset Theme",Desc="Restore all default colors",Callback=function()
            for k,v in pairs(DT) do Nexus.Theme[k]=v end; ApplyTheme()
            Nexus:Notify({Title="Reset",Message="Default theme restored.",Type="info",Duration=3})
        end})
        CfgSec:AddButton({Name="🗑  Delete Config File",Callback=function()
            local path=Nexus.SaveDir.."/"..WC.ConfigName..".json"
            if delfile and isfile and isfile(path) then
                pcall(delfile,path)
                Nexus:Notify({Title="Deleted",Message="Config file removed.",Type="warning",Duration=3})
            else
                Nexus:Notify({Title="Not Found",Message="No config file on disk.",Type="error",Duration=3})
            end
        end})
    end -- settings tab

    -- Load saved config after tabs ready
    if WC.SaveConfig then
        task.defer(function() task.wait(0.4); LoadCfg(WC.ConfigName) end)
    end

    return TF
end -- MakeWindow

function Nexus:Init() end -- forward compat

return Nexus
