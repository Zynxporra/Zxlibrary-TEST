local BackgroundController = {
    Current = nil
}

function ZynxLib:SetBackground(type, ...)
    if BackgroundController.Current then
        BackgroundController.Current:Destroy()
        BackgroundController.Current = nil
    end
    
    local args = {...}
    
    if type == "color" then
        local color = args[1] or Color3.fromRGB(30, 0, 30)
        BackgroundController.Current = Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = color,
            BackgroundTransparency = 0,
            ZIndex = 0,
            Parent = ZynxGUI
        })
    elseif type == "gradient" then
        local color1 = args[1] or Color3.fromRGB(40, 0, 40)
        local color2 = args[2] or Color3.fromRGB(100, 20, 120)
        local rotation = args[3] or 135
        
        local frame = Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = 0,
            Parent = ZynxGUI
        })
        
        Create("UIGradient", {
            Color = ColorSequence.new({ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)}),
            Rotation = rotation
        }).Parent = frame
        
        BackgroundController.Current = frame
    end
end

