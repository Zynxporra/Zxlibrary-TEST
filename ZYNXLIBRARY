			for _, tab in pairs(Tabs) do
				if tab:IsA("TextButton") and tab:FindFirstChild("Title") and tab.Title.Text == "⚙️ Orion Config" then
					tab.MouseButton1Click:Fire()
					break
				end
			end
			return SettingsTabObject
		end
		
		SettingsTabCreated = true
		SettingsTabObject = TabFunction:MakeTab({
			Name = "⚙️ Orion Config",
			Icon = "rbxassetid://7072720794",
			PremiumOnly = false
		})
		
		-- BACKGROUND SETTINGS
		SettingsTabObject:AddLabel("───────── Fundo ─────────")
		
		SettingsTabObject:AddDropdown({
			Name = "Tipo de Fundo",
			Options = {"gradient", "color", "none"},
