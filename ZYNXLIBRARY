        -- DROPDOWN
        function TabObj:AddDropdown(config)
            config = config or {}
            config.Name = config.Name or "Dropdown"
            config.Options = config.Options or {}
            config.Default = config.Default or config.Options[1] or "..."
            config.Callback = config.Callback or function() end

            local expanded = false
            local selected = config.Default

            local frame = SetChildren(SetProps(MakeElement("RoundFrame", theme.Second, 0, 10), {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 0, 50),
                ClipsDescendants = true
            }), {
                MakeElement("Stroke", theme.Stroke, 1.5),
                SetProps(MakeElement("Label", config.Name, 15), {
                    Size = UDim2.new(1, -50, 1, 0),
                    Position = UDim2.new(0, 15, 0, 0),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                }),
                SetProps(MakeElement("Label", selected, 14), {
                    Size = UDim2.new(0, 150, 1, 0),
                    Position = UDim2.new(1, -165, 0, 0),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.TextDark,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Name = "Selected"
                }),
                SetProps(MakeElement("Image", "rbxassetid://6031094678"), {
                    Size = UDim2.new(0, 20, 0, 20),
                    Position = UDim2.new(1, -35, 0.5, -10),
                    ImageColor3 = theme.TextDark,
                    Name = "Arrow"
                })
            })

            local list = SetProps(MakeElement("TFrame"), {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 0),
                Position = UDim2.new(0, 10, 0, 55),
                Visible = false
            })

            local function rebuild()
                list:ClearAllChildren()
                local layout = Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4)})
                layout.Parent = list

                for _, opt in ipairs(config.Options) do
                    local btn = SetChildren(SetProps(MakeElement("RoundFrame", theme.Main, 0, 8), {
                        Parent = list,
                        Size = UDim2.new(1, 0, 0, 35),
                        BackgroundTransparency = 0.5
                    }), {
                        SetProps(MakeElement("Label", opt, 14), {
                            Size = UDim2.new(1, -10, 1, 0),
                            Position = UDim2.new(0, 5, 0, 0),
                            Font = Enum.Font.Gotham,
                            TextColor3 = theme.Text,
                            TextXAlignment = Enum.TextXAlignment.Left
                        })
                    })
                    local hit = SetProps(MakeElement("Button"), {Parent = btn, Size = UDim2.new(1, 0, 1, 0)})
                    hit.MouseButton1Click:Connect(function()
                        selected = opt
                        frame.Selected.Text = selected
                        config.Callback(selected)
                        expanded = false
                        list.Visible = false
                        frame.Arrow.Rotation = 0
                        TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 50)}):Play()
                    end)
                end

                list.Size = UDim2.new(1, -20, 0, layout.AbsoluteContentSize.Y)
            end
            rebuild()

            local btn = SetProps(MakeElement("Button"), {Parent = frame, Size = UDim2.new(1, 0, 1, 0)})
            btn.MouseButton1Click:Connect(function()
                expanded = not expanded
                list.Visible = expanded
                frame.Arrow.Rotation = expanded and 180 or 0
                TweenService:Create(frame, TweenInfo.new(0.2), {
                    Size = expanded and UDim2.new(1, 0, 0, 50 + list.Size.Y.Offset + 10) or UDim2.new(1, 0, 0, 50)
                }):Play()
            end)

            local obj = {Value = selected}
            function obj:Refresh(newOpts)
                config.Options = newOpts
                rebuild()
            end
            function obj:Set(new)
                if table.find(config.Options, new) then
                    selected = new
                    frame.Selected.Text = selected
                    config.Callback(selected)
                end
            end
            return obj
        end

        -- PLAYER DROPDOWN
        function TabObj:AddPlayersDropdown(config)
            config = config or {}
            config.Name = config.Name or "Players"
            config.MultipleSelection = config.MultipleSelection or false
            config.Callback = config.Callback or function() end

            local expanded = false
            local selected = {}
            local options = 0

            local frame = SetChildren(SetProps(MakeElement("RoundFrame", theme.Second, 0, 10), {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 0, 55),
                ClipsDescendants = true
            }), {
                MakeElement("Stroke", theme.Stroke, 1.5),
                SetProps(MakeElement("Label", config.Name, 15), {
                    Size = UDim2.new(1, -50, 1, 0),
                    Position = UDim2.new(0, 15, 0, 0),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                }),
                SetProps(MakeElement("Label", "Select...", 14), {
                    Size = UDim2.new(0, 150, 1, 0),
                    Position = UDim2.new(1, -165, 0, 0),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.TextDark,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    Name = "Selected"
                }),
                SetProps(MakeElement("Image", "rbxassetid://6031094678"), {
                    Size = UDim2.new(0, 20, 0, 20),
                    Position = UDim2.new(1, -35, 0.5, -10),
                    ImageColor3 = theme.TextDark,
                    Name = "Arrow"
                })
            })

            local list = Create("ScrollingFrame", {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 150),
                Position = UDim2.new(0, 10, 0, 60),
                BackgroundTransparency = 1,
                Visible = false,
                ScrollBarThickness = 4,
                ScrollBarImageColor3 = theme.Stroke,
                CanvasSize = UDim2.new(0, 0, 0, 0)
            }, {
                Create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4)})
            })

            local function updateList()
                list:ClearAllChildren()
                options = 0
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then
                        local btn = SetChildren(SetProps(MakeElement("RoundFrame", theme.Main, 0, 8), {
                            Parent = list,
                            Size = UDim2.new(1, 0, 0, 50),
                            BackgroundTransparency = 0.5
                        }), {
                            SetProps(MakeElement("Image", "https://www.roblox.com/headshot-thumbnail/image?userId="..plr.UserId.."&width=420&height=420&format=png"), {
                                Size = UDim2.new(0, 35, 0, 35),
                                Position = UDim2.new(0, 8, 0.5, -17),
                                BackgroundTransparency = 1
                            }, {Create("UICorner", {CornerRadius = UDim.new(1, 0)})}),
                            SetProps(MakeElement("Label", plr.DisplayName, 14), {
                                Position = UDim2.new(0, 50, 0, 8),
                                Size = UDim2.new(1, -60, 0, 20),
                                Font = Enum.Font.GothamBold,
                                TextColor3 = theme.Text,
                                TextXAlignment = Enum.TextXAlignment.Left
                            }),
                            SetProps(MakeElement("Label", "@"..plr.Name, 12), {
                                Position = UDim2.new(0, 50, 0, 28),
                                Size = UDim2.new(1, -60, 0, 18),
                                Font = Enum.Font.Gotham,
                                TextColor3 = theme.TextDark,
                                TextXAlignment = Enum.TextXAlignment.Left
                            })
                        })
                        local hit = SetProps(MakeElement("Button"), {Parent = btn, Size = UDim2.new(1, 0, 1, 0)})
                        hit.MouseButton1Click:Connect(function()
                            if config.MultipleSelection then
                                if selected[plr] then
                                    selected[plr] = nil
                                    btn.BackgroundColor3 = theme.Main
                                else
                                    selected[plr] = true
                                    btn.BackgroundColor3 = theme.Stroke
                                end
                                local names = {}
                                for p in pairs(selected) do
                                    table.insert(names, p.Name)
                                end
                                frame.Selected.Text = #names > 0 and table.concat(names, ", ") or "Select..."
                                config.Callback(names)
                            else
                                selected = {[plr] = true}
                                frame.Selected.Text = plr.Name
                                config.Callback(plr)
                                expanded = false
                                list.Visible = false
                                frame.Arrow.Rotation = 0
                                TweenService:Create(frame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 55)}):Play()
                            end
                        end)
                        options = options + 1
                    end
                end
                list.CanvasSize = UDim2.new(0, 0, 0, options * 54)
            end
            updateList()

            Players.PlayerAdded:Connect(updateList)
            Players.PlayerRemoving:Connect(updateList)

            local btn = SetProps(MakeElement("Button"), {Parent = frame, Size = UDim2.new(1, 0, 1, 0)})
            btn.MouseButton1Click:Connect(function()
                expanded = not expanded
                list.Visible = expanded
                frame.Arrow.Rotation = expanded and 180 or 0
                TweenService:Create(frame, TweenInfo.new(0.2), {
                    Size = expanded and UDim2.new(1, 0, 0, 55 + 160) or UDim2.new(1, 0, 0, 55)
                }):Play()
            end)

            return {}
        end

        -- COLORPICKER
        function TabObj:AddColorpicker(config)
            config = config or {}
            config.Name = config.Name or "Color"
            config.Default = config.Default or Color3.fromRGB(255,255,255)
            config.Callback = config.Callback or function() end

            local expanded = false
            local color = config.Default
            local r, g, b = color.R * 255, color.G * 255, color.B * 255

            local frame = SetChildren(SetProps(MakeElement("RoundFrame", theme.Second, 0, 10), {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 0, 50),
                ClipsDescendants = true
            }), {
                MakeElement("Stroke", theme.Stroke, 1.5),
                SetProps(MakeElement("Label", config.Name, 15), {
                    Size = UDim2.new(1, -70, 1, 0),
                    Position = UDim2.new(0, 15, 0, 0),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                }),
                SetChildren(SetProps(MakeElement("RoundFrame", color, 0, 8), {
                    Size = UDim2.new(0, 35, 0, 35),
                    Position = UDim2.new(1, -45, 0.5, -17)
                }), {
                    MakeElement("Stroke", theme.Text, 2)
                })
            })

            -- Painel expandido do colorpicker
            local pickerPanel = SetChildren(SetProps(MakeElement("RoundFrame", theme.Main, 0, 10), {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 120),
                Position = UDim2.new(0, 10, 0, 55),
                Visible = false
            }), {
                MakeElement("Stroke", theme.Stroke, 1),
                MakeElement("List", 0, 5)
            })

            -- Sliders para R, G, B
            local sliders = {}
            local labels = {"R", "G", "B"}
            local values = {r, g, b}
            for i = 1, 3 do
                local sliderFrame = SetChildren(SetProps(MakeElement("RoundFrame", theme.Second, 0, 6), {
                    Parent = pickerPanel,
                    Size = UDim2.new(1, 0, 0, 30)
                }), {
                    MakeElement("Stroke", theme.Stroke, 1),
                    SetProps(MakeElement("Label", labels[i], 14), {
                        Size = UDim2.new(0, 20, 1, 0),
                        Position = UDim2.new(0, 5, 0, 0),
                        Font = Enum.Font.GothamBold,
                        TextColor3 = theme.Text
                    })
                })

                local track = SetChildren(SetProps(MakeElement("Frame"), {
                    Parent = sliderFrame,
                    Size = UDim2.new(1, -50, 0, 6),
                    Position = UDim2.new(0, 30, 0.5, -3),
                    BackgroundColor3 = theme.Main
                }), {
                    Create("UICorner", {CornerRadius = UDim.new(1, 0)})
                })

                local fill = SetChildren(SetProps(MakeElement("Frame"), {
                    Size = UDim2.new(values[i]/255, 0, 1, 0),
                    BackgroundColor3 = Color3.fromRGB(i==1 and 255 or 0, i==2 and 255 or 0, i==3 and 255 or 0)
                }), {
                    Create("UICorner", {CornerRadius = UDim.new(1, 0)})
                })
                fill.Parent = track

                local knob = SetChildren(SetProps(MakeElement("RoundFrame", Color3.new(1,1,1), 1, 0), {
                    Parent = track,
                    Size = UDim2.new(0, 12, 0, 12),
                    Position = UDim2.new(values[i]/255, -6, 0.5, -6)
                }), {
                    MakeElement("Stroke", theme.Stroke, 1)
                })

                local dragging = false
                track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        values[i] = rel * 255
                        fill.Size = UDim2.new(rel, 0, 1, 0)
                        knob.Position = UDim2.new(rel, -6, 0.5, -6)
                        updateColor()
                    end
                end)
                track.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                        values[i] = rel * 255
                        fill.Size = UDim2.new(rel, 0, 1, 0)
                        knob.Position = UDim2.new(rel, -6, 0.5, -6)
                        updateColor()
                    end
                end)

                table.insert(sliders, {fill = fill, knob = knob})
            end

            local function updateColor()
                color = Color3.fromRGB(values[1], values[2], values[3])
                frame:FindFirstChildOfClass("Frame").BackgroundColor3 = color
                config.Callback(color)
            end

            local btn = SetProps(MakeElement("Button"), {Parent = frame, Size = UDim2.new(1, 0, 1, 0)})
            btn.MouseButton1Click:Connect(function()
                expanded = not expanded
                pickerPanel.Visible = expanded
                TweenService:Create(frame, TweenInfo.new(0.2), {
                    Size = expanded and UDim2.new(1, 0, 0, 50 + 130) or UDim2.new(1, 0, 0, 50)
                }):Play()
            end)

            local obj = {Value = color}
            function obj:Set(c)
                color = c
                r, g, b = c.R * 255, c.G * 255, c.B * 255
                values = {r, g, b}
                frame:FindFirstChildOfClass("Frame").BackgroundColor3 = c
                for i, slider in ipairs(sliders) do
                    local rel = values[i] / 255
                    slider.fill.Size = UDim2.new(rel, 0, 1, 0)
                    slider.knob.Position = UDim2.new(rel, -6, 0.5, -6)
                end
                config.Callback(c)
            end
            return obj
        end

        return TabObj
    end

    return WindowObj
end

return OrionLib
