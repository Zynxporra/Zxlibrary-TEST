local BackgroundController = {
    CurrentBackground = nil,
    CurrentType = "none" -- "none", "color", "gradient", "image"
}

function NovaLib:SetBackground(type, ...)
    -- type: "color", "gradient", "image", "none"
    local args = {...}
    
    -- Remover background anterior
    if BackgroundController.CurrentBackground then
        BackgroundController.CurrentBackground:Destroy()
        BackgroundController.CurrentBackground = nil
    end
    
    if type == "none" then
        BackgroundController.CurrentType = "none"
        return
    end
    
    if type == "color" then
        local color = args[1] or Color3.fromRGB(30, 30, 30)
        BackgroundController.CurrentBackground = Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = color,
            BackgroundTransparency = 0,
            ZIndex = 0,
            Parent = Nova
        })
    end
    
    if type == "gradient" then
        local color1 = args[1] or NovaLib.Themes[NovaLib.CurrentTheme].Accent
        local color2 = args[2] or NovaLib.Themes[NovaLib.CurrentTheme].Accent2
        local rotation = args[3] or 45
        
        local frame = Create("Frame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = 0,
            Parent = Nova
        })
        
        Create("UIGradient", {
            Color = ColorSequence.new({ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)}),
            Rotation = rotation
        }, {}).Parent = frame
        
        BackgroundController.CurrentBackground = frame
    end
    
    if type == "image" then
        local imageUrl = args[1] or "rbxassetid://15263889566"
        local transparency = args[2] or 0.5
        
        BackgroundController.CurrentBackground = Create("ImageLabel", {
            Size = UDim2.new(1, 0, 1, 0),
            Image = imageUrl,
            BackgroundTransparency = 1,
            ImageTransparency = transparency,
            ScaleType = Enum.ScaleType.Crop,
            ZIndex = 0,
            Parent = Nova
        })
    end
    
    BackgroundController.CurrentType = type
end

