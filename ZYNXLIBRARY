                    Position = UDim2.new(0, 15, 0, 8),
                    Font = Enum.Font.Gotham,
                    TextColor3 = theme.Text,
                    TextXAlignment = Enum.TextXAlignment.Left
                }),
                SetProps(MakeElement("Label", tostring(value), 15), {
                    Size = UDim2.new(0, 50, 0, 20),
                    Position = UDim2.new(1, -65, 0, 8),
                    Font = Enum.Font.GothamBold,
                    TextColor3 = theme.Stroke,
                    Name = "ValueLabel"
                })
            })

            local track = SetChildren(SetProps(MakeElement("Frame"), {
                Parent = frame,
                Size = UDim2.new(1, -30, 0, 6),
                Position = UDim2.new(0, 15, 1, -25),
                BackgroundColor3 = theme.Main
            }), {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })

            local fill = SetChildren(SetProps(MakeElement("Frame"), {
                Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0),
                BackgroundColor3 = theme.Stroke
            }), {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            fill.Parent = track

            local knob = SetChildren(SetProps(MakeElement("RoundFrame", Color3.new(1,1,1), 1, 0), {
                Parent = track,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new((value - config.Min) / (config.Max - config.Min), -8, 0.5, -8)
            }), {
                MakeElement("Stroke", theme.Stroke, 2)
            })

            local function update(posX)
                local rel = math.clamp((posX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                value = config.Min + (config.Max - config.Min) * rel
                fill.Size = UDim2.new(rel, 0, 1, 0)
                knob.Position = UDim2.new(rel, -8, 0.5, -8)
                frame.ValueLabel.Text = math.floor(value)
                config.Callback(value)
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    update(input.Position.X)
                end
            end)
            track.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    update(input.Position.X)
                end
            end)

            local sliderObj = {Value = value}
            function sliderObj:Set(new)
                value = math.clamp(new, config.Min, config.Max)
                local rel = (value - config.Min) / (config.Max - config.Min)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                knob.Position = UDim2.new(rel, -8, 0.5, -8)
                frame.ValueLabel.Text = math.floor(value)
                config.Callback(value)
            end

            return sliderObj
        end

