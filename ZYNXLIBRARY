local function Create(className, props, children)
    local obj = Instance.new(className)
    for prop, val in pairs(props or {}) do
        obj[prop] = val
    end
    for _, child in pairs(children or {}) do
        child.Parent = obj
    end
    return obj
end

local function MakeDraggable(dragPoint, main)
    local dragging, startPos, startMousePos
    
    dragPoint.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            startPos = main.Position
            startMousePos = Vector2.new(input.Position.X, input.Position.Y)
        end
    end)
    
    dragPoint.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - startMousePos
            main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

