        })
    })

    TweenService:Create(notif, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position = UDim2.new(0, 0, 0, 0)}):Play()

    task.wait(config.Time)
    TweenService:Create(notif, TweenInfo.new(0.3), {Position = UDim2.new(1, 30, 0, 0)}):Play()
    task.wait(0.4)
    container:Destroy()
end

