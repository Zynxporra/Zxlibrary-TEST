		local Dots = {SideResizeBtn:FindFirstChild("Dot1"), SideResizeBtn:FindFirstChild("Dot2"), SideResizeBtn:FindFirstChild("Dot3")}
		
		AddConnection(SideResizeBtn.MouseEnter, function()
			for _, dot in pairs(Dots) do
				if dot then TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundTransparency = 0.2}):Play() end
			end
		end)
		
		AddConnection(SideResizeBtn.MouseLeave, function()
			for _, dot in pairs(Dots) do
				if dot then TweenService:Create(dot, TweenInfo.new(0.15), {BackgroundTransparency = 0.5}):Play() end
			end
		end)
		
		local StartSize, StartPos
		
		AddConnection(SideResizeBtn.InputBegan, function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
				SideResizing = true
				StartSize = WindowStuff.AbsoluteSize
				StartPos = Vector2.new(Input.Position.X, Input.Position.Y)
				for _, dot in pairs(Dots) do
					if dot then TweenService:Create(dot, TweenInfo.new(0.1), {BackgroundTransparency = 0}):Play() end
				end
			end
		end)
		
		AddConnection(UserInputService.InputChanged, function(Input)
			if SideResizing and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
				local Delta = Vector2.new(Input.Position.X - StartPos.X, 0)
				local MaxWidth = MainWindow.AbsoluteSize.X * 0.4
				local MinWidth = 120
				local NewWidth = math.max(MinWidth, math.min(MaxWidth, StartSize.X + Delta.X))
				
				WindowStuff.Size = UDim2.new(0, NewWidth, 1, -50)
				
				for _, ItemContainer in pairs(MainWindow:GetChildren()) do
					if ItemContainer.Name == "ItemContainer" then
						ItemContainer.Size = UDim2.new(1, -NewWidth, 1, -50)
						ItemContainer.Position = UDim2.new(0, NewWidth, 0, 50)
					end
				end
				
				if SearchBox then
					if NewWidth < 100 then
						SearchBox.PlaceholderText = "🔍"
					else
						SearchBox.PlaceholderText = "🔍 Search tabs..."
					end
				end
			end
		end)
		
		AddConnection(UserInputService.InputEnded, function(Input)
			if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
				if SideResizing then
					SideResizing = false
					for _, dot in pairs(Dots) do
						if dot then TweenService:Create(dot, TweenInfo.new(0.2), {BackgroundTransparency = 0.5}):Play() end
					end
				end
			end
		end)
	end

