	-- Animação das letras
	local letterAnimationLoop = nil
	local function startLetterAnimation()
		if letterAnimationLoop then return end
		letterAnimationLoop = task.spawn(function()
			task.wait(2)
			while letterAnimationActive do
				for i = #windowLetters, 1, -1 do
					if not letterAnimationActive then break end
					TweenService:Create(windowLetters[i], TweenInfo.new(0.4, Enum.EasingStyle.Sine), {TextTransparency = 1}):Play()
					task.wait(0.1)
				end
				task.wait(0.8)
				for i = 1, #windowLetters do
					if not letterAnimationActive then break end
					TweenService:Create(windowLetters[i], TweenInfo.new(0.4, Enum.EasingStyle.Sine), {TextTransparency = 0}):Play()
					task.wait(0.1)
				end
				task.wait(5)
			end
			letterAnimationLoop = nil
		end)
	end
	startLetterAnimation()

