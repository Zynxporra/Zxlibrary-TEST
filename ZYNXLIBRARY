                Parent = SliderFrame,
                Size = UDim2.new(1, -30, 0, 6),
                Position = UDim2.new(0, 15, 1, -20),
                BackgroundColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Main,
                BackgroundTransparency = 0
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local SliderFill = Create("Frame", {
                Parent = SliderTrack,
                Size = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), 0, 1, 0),
                BackgroundColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Accent
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local SliderKnob = Create("Frame", {
                Parent = SliderTrack,
                Size = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), -7, 0.5, -7),
                BackgroundColor3 = Color3.new(1, 1, 1)
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local function updateSlider(inputPos)
                local relativePos = math.clamp((inputPos - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
                sliderValue = config.Min + (config.Max - config.Min) * relativePos
                
                SliderFill.Size = UDim2.new(relativePos, 0, 1, 0)
                SliderKnob.Position = UDim2.new(relativePos, -7, 0.5, -7)
                ValueLabel.Text = math.floor(sliderValue)
                
                config.Callback(sliderValue)
            end
            
            SliderTrack.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    updateSlider(input.Position.X)
                end
            end)
            
            SliderTrack.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input.Position.X)
                end
            end)
            
            local SliderObj = {Value = sliderValue}
            function SliderObj:Set(newValue)
                sliderValue = math.clamp(newValue, config.Min, config.Max)
                local percent = (sliderValue - config.Min) / (config.Max - config.Min)
                
                SliderFill.Size = UDim2.new(percent, 0, 1, 0)
                SliderKnob.Position = UDim2.new(percent, -7, 0.5, -7)
                ValueLabel.Text = math.floor(sliderValue)
                
                config.Callback(sliderValue)
            end
            
            return SliderObj
        end
        
        -- DROPDOWN
        function TabObj:AddDropdown(config)
            config = config or {}
            config.Name = config.Name or "Dropdown"
            config.Options = config.Options or {}
            config.Default = config.Default or config.Options[1] or "..."
            config.Callback = config.Callback or function() end
            
            local expanded = false
            local selected = config.Default
            
            local DropdownFrame = Create("Frame", {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 0, 40),
                BackgroundColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Second,
                BackgroundTransparency = 0,
                ClipsDescendants = true
            }, {
                Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
                Create("UIStroke", {
                    Color = NovaLib.Themes[NovaLib.CurrentTheme].Stroke,
                    Thickness = 1,
                    Transparency = 0.5
                })
            })
            
            local DropdownText = Create("TextLabel", {
                Parent = DropdownFrame,
                Size = UDim2.new(1, -50, 0, 40),
                Position = UDim2.new(0, 10, 0, 0),
                BackgroundTransparency = 1,
                Text = config.Name,
                TextColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Text,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local SelectedText = Create("TextLabel", {
                Parent = DropdownFrame,
                Size = UDim2.new(0, 100, 0, 40),
                Position = UDim2.new(1, -120, 0, 0),
                BackgroundTransparency = 1,
                Text = selected,
                TextColor3 = NovaLib.Themes[NovaLib.CurrentTheme].TextDim,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local Arrow = Create("ImageLabel", {
                Parent = DropdownFrame,
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -30, 0.5, -10),
                BackgroundTransparency = 1,
                Image = "rbxassetid://6031094678",
                ImageColor3 = NovaLib.Themes[NovaLib.CurrentTheme].TextDim
            })
            
            local DropdownList = Create("Frame", {
                Parent = DropdownFrame,
                Size = UDim2.new(1, -20, 0, 0),
                Position = UDim2.new(0, 10, 0, 45),
                BackgroundTransparency = 1,
                Visible = false
            })
            
            local function rebuildOptions()
                for _, child in pairs(DropdownList:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, option in pairs(config.Options) do
                    local OptionBtn = Create("TextButton", {
                        Parent = DropdownList,
                        Size = UDim2.new(1, 0, 0, 30),
                        BackgroundColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Main,
                        BackgroundTransparency = 0.3,
                        Text = ""
                    }, {
                        Create("UICorner", {CornerRadius = UDim.new(0, 6)}),
                        Create("TextLabel", {
                            Size = UDim2.new(1, -10, 1, 0),
                            Position = UDim2.new(0, 5, 0, 0),
                            BackgroundTransparency = 1,
                            Text = option,
                            TextColor3 = NovaLib.Themes[NovaLib.CurrentTheme].Text,
                            TextSize = 13,
                            Font = Enum.Font.Gotham,
                            TextXAlignment = Enum.TextXAlignment.Left
                        })
                    })
                    
                    OptionBtn.MouseButton1Click:Connect(function()
                        selected = option
                        SelectedText.Text = selected
                        config.Callback(selected)
                        
                        expanded = false
                        DropdownList.Visible = false
                        Arrow.Rotation = 0
                        TweenService:Create(DropdownFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 40)}):Play()
                    end)
                end
                
                local listHeight = #config.Options * 35
                DropdownList.Size = UDim2.new(1, -20, 0, listHeight)
            end
            
            rebuildOptions()
            
            local DropdownObj = {Value = selected}
            function DropdownObj:Refresh(newOptions)
                config.Options = newOptions
                rebuildOptions()
            end
            
            function DropdownObj:Set(newValue)
                if table.find(config.Options, newValue) then
                    selected = newValue
                    SelectedText.Text = selected
                    config.Callback(selected)
                end
            end
            
            local MainButton = Create("TextButton", {
                Parent = DropdownFrame,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = ""
            })
            
            MainButton.MouseButton1Click:Connect(function()
                expanded = not expanded
                DropdownList.Visible = expanded
                Arrow.Rotation = expanded and 180 or 0
                
                local newHeight = expanded and 40 + (DropdownList.Size.Y.Offset or 0) + 10 or 40
                TweenService:Create(DropdownFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, newHeight)}):Play()
            end)
            
            return DropdownObj
        end
        
        return TabObj
    end
    
    return WindowObj
end

