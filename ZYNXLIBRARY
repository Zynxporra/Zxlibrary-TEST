local function MakeResizable(window, minSize, maxSize)
    local resizing = false
    var startSize, startPos
    
    local resizeHandle = Create("Frame", {
        Parent = window,
        Size = UDim2.new(0, 15, 0, 15),
        Position = UDim2.new(1, -8, 1, -8),
        BackgroundColor3 = ZynxLib.Themes[ZynxLib.CurrentTheme].Accent,
        BackgroundTransparency = 0.5,
        ZIndex = 10
    }, {
        Create("UICorner", {CornerRadius = UDim.new(1, 0)})
    })
    
    resizeHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true
            startSize = window.AbsoluteSize
            startPos = Vector2.new(input.Position.X, input.Position.Y)
            
            TweenService:Create(resizeHandle, TweenInfo.new(0.1), {
                BackgroundTransparency = 0,
                Size = UDim2.new(0, 20, 0, 20)
            }):Play()
        end
    end)
    
    resizeHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = false
            TweenService:Create(resizeHandle, TweenInfo.new(0.2), {
                BackgroundTransparency = 0.5,
                Size = UDim2.new(0, 15, 0, 15)
            }):Play()
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = Vector2.new(input.Position.X, input.Position.Y) - startPos
            local newWidth = math.clamp(startSize.X + delta.X, minSize.X.Offset, maxSize.X.Offset)
            local newHeight = math.clamp(startSize.Y + delta.Y, minSize.Y.Offset, maxSize.Y.Offset)
            
            window.Size = UDim2.new(0, newWidth, 0, newHeight)
        end
    end)
end

