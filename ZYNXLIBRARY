        function TabObj:AddPlayerDropdown(config)
            config = config or {}
            config.Name = config.Name or "Players"
            config.Multiple = config.Multiple or false
            config.Callback = config.Callback or function() end
            
            local expanded = false
            local selected = {}
            local players = {}
            
