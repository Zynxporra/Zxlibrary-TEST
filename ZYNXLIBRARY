        -- SLIDER
        function TabObj:AddSlider(config)
            config = config or {}
            config.Name = config.Name or "Slider"
            config.Min = config.Min or 0
            config.Max = config.Max or 100
            config.Default = config.Default or 50
            config.Callback = config.Callback or function() end
            
            local value = config.Default
            local dragging = false
            
            local frame = Create("Frame", {
                Parent = TabContent,
                Size = UDim2.new(1, 0, 0, 70),
                BackgroundColor3 = Themes[currentTheme].Second,
                BackgroundTransparency = 0
            }, {
                Create("UICorner", {CornerRadius = UDim.new(0, 12)}),
                Create("UIStroke", {
                    Color = Themes[currentTheme].Accent,
                    Thickness = 1.5,
                    Transparency = 0.5
                })
            })
            
            local label = Create("TextLabel", {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 20),
                Position = UDim2.new(0, 15, 0, 8),
                BackgroundTransparency = 1,
                Text = config.Name,
                TextColor3 = Themes[currentTheme].Text,
                TextSize = 15,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local valueLabel = Create("TextLabel", {
                Parent = frame,
                Size = UDim2.new(0, 50, 0, 20),
                Position = UDim2.new(1, -65, 0, 8),
                BackgroundTransparency = 1,
                Text = tostring(value),
                TextColor3 = Themes[currentTheme].Accent,
                TextSize = 15,
                Font = Enum.Font.GothamBold
            })
            
            local track = Create("Frame", {
                Parent = frame,
                Size = UDim2.new(1, -30, 0, 6),
                Position = UDim2.new(0, 15, 1, -25),
                BackgroundColor3 = Themes[currentTheme].Main,
                BackgroundTransparency = 0
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local fill = Create("Frame", {
                Parent = track,
                Size = UDim2.new((value - config.Min) / (config.Max - config.Min), 0, 1, 0),
                BackgroundColor3 = Themes[currentTheme].Accent
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)})
            })
            
            local knob = Create("Frame", {
                Parent = track,
                Size = UDim2.new(0, 16, 0, 16),
                Position = UDim2.new((value - config.Min) / (config.Max - config.Min), -8, 0.5, -8),
                BackgroundColor3 = Color3.new(1, 1, 1)
            }, {
                Create("UICorner", {CornerRadius = UDim.new(1, 0)}),
                Create("UIStroke", {
                    Color = Themes[currentTheme].Accent,
                    Thickness = 2
                })
            })
            
            local function update(posX)
                local rel = math.clamp((posX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
                value = config.Min + (config.Max - config.Min) * rel
                
                fill.Size = UDim2.new(rel, 0, 1, 0)
                knob.Position = UDim2.new(rel, -8, 0.5, -8)
                valueLabel.Text = math.floor(value)
                
                config.Callback(value)
            end
            
            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    update(input.Position.X)
                end
            end)
            
            track.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    update(input.Position.X)
                end
            end)
            
            local sliderObj = {Value = value}
            function sliderObj:Set(newValue)
                value = math.clamp(newValue, config.Min, config.Max)
                local rel = (value - config.Min) / (config.Max - config.Min)
                fill.Size = UDim2.new(rel, 0, 1, 0)
                knob.Position = UDim2.new(rel, -8, 0.5, -8)
                valueLabel.Text = math.floor(value)
                config.Callback(value)
            end
            
            return sliderObj
        end
        
