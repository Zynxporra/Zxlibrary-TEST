                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local arrow = Create("ImageLabel", {
                Parent = frame,
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -35, 0.5, -10),
                BackgroundTransparency = 1,
                Image = "rbxassetid://6031094678",
                ImageColor3 = Themes[currentTheme].TextDim
            })
            
            local list = Create("Frame", {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 0),
                Position = UDim2.new(0, 10, 0, 50),
                BackgroundTransparency = 1,
                Visible = false
            })
            
            local function rebuild()
                for _, child in pairs(list:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, option in pairs(config.Options) do
                    local btn = Create("TextButton", {
                        Parent = list,
                        Size = UDim2.new(1, 0, 0, 35),
                        BackgroundColor3 = Themes[currentTheme].Main,
                        BackgroundTransparency = 0.5,
                        Text = ""
                    }, {
                        Create("UICorner", {CornerRadius = UDim.new(0, 8)}),
                        Create("TextLabel", {
                            Size = UDim2.new(1, -10, 1, 0),
                            Position = UDim2.new(0, 5, 0, 0),
                            BackgroundTransparency = 1,
                            Text = option,
                            TextColor3 = Themes[currentTheme].Text,
                            TextSize = 14,
                            Font = Enum.Font.Gotham,
                            TextXAlignment = Enum.TextXAlignment.Left
                        })
                    })
                    
                    btn.MouseButton1Click:Connect(function()
                        selected = option
                        selectedText.Text = selected
                        config.Callback(selected)
                        
                        expanded = false
                        list.Visible = false
                        arrow.Rotation = 0
                        TweenService:Create(frame, Animations.DropdownClose, {Size = UDim2.new(1, 0, 0, 45)}):Play()
                    end)
                end
                
                list.Size = UDim2.new(1, -20, 0, #config.Options * 40)
            end
            
            rebuild()
            
            local dropdownObj = {Value = selected}
            function dropdownObj:Refresh(newOptions)
                config.Options = newOptions
                rebuild()
            end
            
            function dropdownObj:Set(newValue)
                if table.find(config.Options, newValue) then
                    selected = newValue
                    selectedText.Text = selected
                    config.Callback(selected)
                end
            end
            
            local btn = Create("TextButton", {
                Parent = frame,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = ""
            })
            
            btn.MouseButton1Click:Connect(function()
                expanded = not expanded
                list.Visible = expanded
                arrow.Rotation = expanded and 180 or 0
                
                local newHeight = expanded and 45 + list.Size.Y.Offset + 10 or 45
                TweenService:Create(frame, Animations.DropdownOpen, {Size = UDim2.new(1, 0, 0, newHeight)}):Play()
            end)
            
            return dropdownObj
        end
        
