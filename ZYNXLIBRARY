                Parent = frame,
                Size = UDim2.new(0, 150, 1, 0),
                Position = UDim2.new(1, -165, 0, 0),
                BackgroundTransparency = 1,
                Text = "Select...",
                TextColor3 = Themes[currentTheme].TextDim,
                TextSize = 14,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local arrow = Create("ImageLabel", {
                Parent = frame,
                Size = UDim2.new(0, 20, 0, 20),
                Position = UDim2.new(1, -35, 0.5, -10),
                BackgroundTransparency = 1,
                Image = "rbxassetid://6031094678",
                ImageColor3 = Themes[currentTheme].TextDim
            })
            
            local list = Create("ScrollingFrame", {
                Parent = frame,
                Size = UDim2.new(1, -20, 0, 200),
                Position = UDim2.new(0, 10, 0, 60),
                BackgroundTransparency = 1,
                Visible = false,
                ScrollBarThickness = 4,
                ScrollBarImageColor3 = Themes[currentTheme].Accent,
                CanvasSize = UDim2.new(0, 0, 0, 0)
            }, {
                Create("UIListLayout", {
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding = UDim.new(0, 5)
                })
            })
            
            local function updateList()
                for _, child in pairs(list:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
                
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer then
                        local btn = Create("TextButton", {
                            Parent = list,
                            Size = UDim2.new(1, 0, 0, 45),
                            BackgroundColor3 = Themes[currentTheme].Main,
                            BackgroundTransparency = 0.5,
                            Text = ""
                        }, {
                            Create("UICorner", {CornerRadius = UDim.new(0, 8)})
                        })
                        
                        -- Avatar
                        Create("ImageLabel", {
                            Parent = btn,
                            Size = UDim2.new(0, 30, 0, 30),
                            Position = UDim2.new(0, 8, 0.5, -15),
                            BackgroundTransparency = 1,
                            Image = "https://www.roblox.com/headshot-thumbnail/image?userId=".. plr.UserId .."&width=420&height=420&format=png"
                        }, {
                            Create("UICorner", {CornerRadius = UDim.new(1, 0)})
                        })
                        
                        -- Nome
                        Create("TextLabel", {
                            Parent = btn,
                            Size = UDim2.new(1, -50, 0, 20),
                            Position = UDim2.new(0, 45, 0, 8),
                            BackgroundTransparency = 1,
                            Text = plr.DisplayName,
                            TextColor3 = Themes[currentTheme].Text,
                            TextSize = 14,
                            Font = Enum.Font.GothamBold,
                            TextXAlignment = Enum.TextXAlignment.Left
                        })
                        
                        -- Username
                        Create("TextLabel", {
                            Parent = btn,
                            Size = UDim2.new(1, -50, 0, 18),
                            Position = UDim2.new(0, 45, 0, 28),
                            BackgroundTransparency = 1,
                            Text = "@" .. plr.Name,
                            TextColor3 = Themes[currentTheme].TextDim,
                            TextSize = 12,
                            Font = Enum.Font.Gotham,
                            TextXAlignment = Enum.TextXAlignment.Left
                        })
                        
                        btn.MouseButton1Click:Connect(function()
                            if config.Multiple then
                                if selected[plr] then
                                    selected[plr] = nil
                                    btn.BackgroundColor3 = Themes[currentTheme].Main
                                else
                                    selected[plr] = true
                                    btn.BackgroundColor3 = Themes[currentTheme].Accent
                                end
                                
                                local names = {}
                                for p in pairs(selected) do
                                    table.insert(names, p.Name)
                                end
                                selectedText.Text = #names > 0 and table.concat(names, ", ") or "Select..."
                                config.Callback(selected)
                            else
                                selected = {[plr] = true}
                                selectedText.Text = plr.Name
                                config.Callback(plr)
                                
                                expanded = false
                                list.Visible = false
                                arrow.Rotation = 0
                                TweenService:Create(frame, Animations.DropdownClose, {Size = UDim2.new(1, 0, 0, 55)}):Play()
                            end
                        end)
                    end
                end
                
                list.CanvasSize = UDim2.new(0, 0, 0, list.UIListLayout.AbsoluteContentSize.Y + 10)
            end
            
            updateList()
            
            Players.PlayerAdded:Connect(updateList)
            Players.PlayerRemoving:Connect(updateList)
            
            local dropdownObj = {Value = selected}
            function dropdownObj:Refresh()
