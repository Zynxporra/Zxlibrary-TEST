-- FUNDO PERSONALIZADO
function OrionUltraLib:SetBackground(type, ...)
    local args = {...}
    
    if OrionUltraLib.Background then
        OrionUltraLib.Background:Destroy()
    end
    
    if type == "gradient" then
        local color1 = args[1] or Themes[OrionUltraLib.CurrentTheme].Main
        local color2 = args[2] or Themes[OrionUltraLib.CurrentTheme].Accent
        local rotation = args[3] or 135
        
        local frame = Create("Frame", {
            Parent = OrionUltra,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = 0
        })
        
        Create("UIGradient", {
            Color = ColorSequence.new({ColorSequenceKeypoint.new(0, color1), ColorSequenceKeypoint.new(1, color2)}),
            Rotation = rotation
        }).Parent = frame
        
        OrionUltraLib.Background = frame
    end
end

